# Archivo de ejemplo de variables de entorno para EMED
# La web es ahora completamente estática sin dependencias de WordPress

# Variables de ejemplo que podrías necesitar:
# SITE_URL=https://emed.cl
# CONTACT_EMAIL=contacto@emed.cl

# Configuración FTP para deployment
# Copia estas variables a tu archivo .env y completa con tus credenciales
FTP_HOST=tu_servidor.com
FTP_USER=tu_usuario_ftp
FTP_PASSWORD=tu_password_ftp
FTP_REMOTE_PATH=/ruta/en/servidor

# Instrucciones:
# 1. Copia este archivo a .env
# 2. Configura las variables según tus necesidades
# 3. NO commitear el archivo .env al repositorio (ya está en .gitignore)

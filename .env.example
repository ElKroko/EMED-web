# WordPress Configuration
# URL base de tu instalación WordPress
WP_DOMAIN="http://localhost:8882"

# URL de la API REST de WordPress
WP_API_URL="http://localhost:8882/wp-json/v2"

# URL del endpoint GraphQL (requiere plugin WPGraphQL)
WP_GRAPHQL_URL="http://localhost:8882/graphql"

# WooCommerce API Credentials
# Generar en: WooCommerce → Settings → Advanced → REST API
# Permisos recomendados: Read (solo lectura)
WC_KEY="ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WC_SECRET="cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Instrucciones:
# 1. Copia este archivo a .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. NO commits el archivo .env al repositorio
# 4. Para producción, crea un .env.production con las URLs de producción

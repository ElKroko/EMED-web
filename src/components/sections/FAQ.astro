---
interface FAQItem {
    pregunta: string;
    respuesta: string;
}

interface Props {
    items: FAQItem[];
    className?: string;
    pdfMallaUrl?: string; // New prop for dynamic PDF URL
}

import Accordion from "../ui/Accordion.astro";
const { items, className = "", pdfMallaUrl = "#" } = Astro.props;

const accordionItems = items.map((item, idx) => ({
    title: item.pregunta,
    content: item.respuesta,
    id: `faq-${idx}`,
}));
---

<div class={`faq-section ${className}`}>
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Preguntas frecuentes</h2>
    </div>

    <!-- Card separada con borde suave -->
    <div
        class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 md:p-8"
    >
        <Accordion items={accordionItems} />

        <!-- CTA Final dentro del FAQ -->
        <div
            class="mt-8 pt-8 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-4"
        >
            <div class="text-center md:text-left">
                <h4 class="font-bold text-gray-800 mb-1">
                    ¿Dudas con las fechas o cupos?
                </h4>
                <p class="text-sm text-gray-600">
                    Te enviamos el calendario completo de la próxima cohorte.
                </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                <button
                    onclick="scrollToContactForm()"
                    class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-sm font-bold rounded-lg text-white bg-celeste hover:bg-turquesa transition-all shadow-sm whitespace-nowrap"
                >
                    Consultar próxima edición
                </button>
                <button
                    onclick={`window.open('${pdfMallaUrl}', '_blank')`}
                    class="inline-flex items-center justify-center px-6 py-3 border border-gray-200 text-sm font-medium rounded-lg text-gray-600 bg-gray-50 hover:bg-gray-100 transition-colors whitespace-nowrap"
                >
                    Descargar malla
                </button>
            </div>
        </div>
    </div>
</div>

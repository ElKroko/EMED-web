---
import { getDiplomados } from '../../lib/productos';

export interface Props {
  heading?: string;
  subheading?: string;
  className?: string;
  maxItems?: number;
}

const {
  heading = "Nuestros Programas",
  subheading = "Especialízate en diferentes áreas de la mediación con nuestros programas certificados",
  className = "",
  maxItems = 6
} = Astro.props;

// Obtener diplomados desde datos estáticos
const productos = getDiplomados();

// Mapear productos a formato del componente
const programas = productos.slice(0, maxItems).map(producto => {
  // Determinar si es destacado (mediación familiar)
  const esDestacado = producto.slug.includes('mediacion-familiar') || producto.destacado;

  // Determinar URL según el tipo
  const urlBase = producto.tipo === 'Diplomado' ? '/diplomados' : '/cursos';
  const url = `${urlBase}/${producto.slug}`;

  return {
    title: producto.nombre,
    description: producto.descripcion_corta || 'Programa especializado en técnicas de mediación.',
    duration: producto.duracion || 'Por definir',
    modality: producto.modalidad || 'Por definir',
    tipo: producto.tipo,
    price: producto.precio_formateado,
    highlight: esDestacado,
    imagen: producto.imagen,
    url: url
  };
});
---

<section class={`programs-grid py-20 bg-crema ${className}`}>
  <div class="container mx-auto px-4 relative z-10">
    
    <!-- Título de la sección -->
    <div class="text-center mb-16 relative z-20">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-black mb-6 text-center">
        {heading}
      </h2>
      <p class="text-xl md:text-2xl text-gray-700 max-w-3xl mx-auto leading-relaxed text-center">
        {subheading}
      </p>
    </div>

    <!-- Grid de programas -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12 relative z-20">
      {programas.map((programa) => (
        <a
          href={programa.url}
          class={`program-card bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 relative overflow-hidden block cursor-pointer group ${programa.highlight ? 'destacado-card' : ''}`}
        >

          <!-- Imagen del programa -->
          <div class="relative h-40 overflow-hidden">
            <img
              src={programa.imagen || 'https://images.unsplash.com/photo-1521791136064-7986c2920216?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'}
              alt={programa.title}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />

            {programa.highlight && (
              <div class="absolute top-2 right-2">
                <span class="text-4xl drop-shadow-lg">⭐</span>
              </div>
            )}

            <div class="absolute top-2 left-2">
              <span class={`inline-block px-2 py-1 rounded-full text-xs font-bold ${
                programa.tipo === 'Diplomado' ? 'bg-naranja text-white' : 'bg-turquesa text-white'
              }`}>
                {programa.tipo}
              </span>
            </div>
          </div>

          <div class="p-4 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-naranja transition-colors duration-300">
              {programa.title}
            </h3>

            <p class="text-gray-600 text-base leading-relaxed mb-3 line-clamp-2">
              {programa.description}
            </p>

            <div class="space-y-1 mb-3">
              <div class="flex items-center text-sm text-gray-600">
                <svg class="w-4 h-4 mr-1 text-turquesa" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{programa.duration}</span>
              </div>

              <div class="flex items-center text-sm text-gray-600">
                <svg class="w-4 h-4 mr-1 text-turquesa" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <span>{programa.modality}</span>
              </div>

              {programa.price && (
                <div class="flex items-center text-base mt-2">
                  <svg class="w-4 h-4 mr-1 text-naranja" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                  </svg>
                  <div class="flex flex-col">
                    <span class="font-bold text-naranja text-lg">{programa.price}</span>
                    <span class="text-xs text-gray-500 font-normal">Consulta por facilidades de pago</span>
                  </div>
                </div>
              )}
            </div>

            <div class="mt-auto pt-2">
              <span class={`inline-flex items-center justify-center w-full px-4 py-2 text-sm font-bold rounded-lg transition-all duration-300 ${programa.highlight ? 'bg-naranja group-hover:bg-amarillo text-white' : 'bg-celeste group-hover:bg-turquesa text-white'}`}>
                Ver Detalles
                <svg class="ml-1 w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA principal -->
    <div class="text-center relative z-20">
      <a 
        href="/diplomados" 
        class="inline-flex items-center px-8 py-4 bg-naranja font-semibold text-lg rounded-lg hover:bg-amarillo hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 main-cta-button"
      >
        Ver Todos los Diplomados
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .program-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 400px;
    text-decoration: none;
  }

  .program-card:hover {
    transform: translateY(-4px);
  }

  .destacado-card {
    box-shadow: 0 4px 20px rgba(238, 128, 12, 0.15);
  }

  .destacado-card:hover {
    box-shadow: 0 8px 30px rgba(238, 128, 12, 0.25);
  }

  .main-cta-button {
    color: white !important;
  }

  .main-cta-button:hover {
    color: white !important;
  }

  .secondary-cta-button {
    color: var(--color-celeste) !important;
    border-color: var(--color-celeste) !important;
  }

  .secondary-cta-button:hover {
    background-color: var(--color-celeste) !important;
    color: white !important;
  }

  /* Limitar líneas de descripción */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .space-x-4 > * + * {
      margin-left: 0;
      margin-top: 1rem;
    }
    .space-x-4 {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }
  }
</style>
---
interface Props {
  horasOnline?: number;
  horasPresencial?: number;
  detallesOnline?: string[];
  detallesPresencial?: string[];
  className?: string;
}

const {
  horasOnline = 170,
  horasPresencial = 50,
  detallesOnline = [
    "Clases sincrónicas semanales",
    "Plataforma LMS avanzada",
    "Material descargable",
    "Foros de discusión",
  ],
  detallesPresencial = [
    "Talleres prácticos intensivos",
    "Simulacros con actores",
    "Pasantía obligatoria",
    "Networking profesional",
  ],
  className = "",
} = Astro.props;
---

<div class={`metodologia-hibrida ${className}`}>
  <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-3">
    Metodología
  </h2>

  <p class="text-gray-600 leading-relaxed text-lg mb-6">
    Modalidad híbrida que combina <strong>clases teóricas online</strong> con <strong
      >talleres prácticos presenciales</strong
    >. La pasantía final es 100% presencial según normativa del Ministerio de
    Justicia.
  </p>

  <div class="grid md:grid-cols-2 gap-6">
    <div
      class="bg-gradient-to-br from-celeste/10 to-celeste/5 border border-celeste/20 rounded-lg p-4"
    >
      <h3 class="font-bold text-gray-800 mb-2 flex items-center">
        <svg
          class="w-5 h-5 text-celeste mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
        Modalidad Online ({horasOnline} horas)
      </h3>
      <ul class="text-sm text-gray-600 space-y-1">
        {detallesOnline.map((detalle) => <li>• {detalle}</li>)}
      </ul>
    </div>
    <div
      class="bg-gradient-to-br from-turquesa/10 to-turquesa/5 border border-turquesa/20 rounded-lg p-4"
    >
      <h3 class="font-bold text-gray-800 mb-2 flex items-center">
        <svg
          class="w-5 h-5 text-turquesa mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
          ></path>
        </svg>
        Modalidad Presencial ({horasPresencial} horas)
      </h3>
      <ul class="text-sm text-gray-600 space-y-1">
        {detallesPresencial.map((detalle) => <li>• {detalle}</li>)}
      </ul>
    </div>
  </div>
</div>

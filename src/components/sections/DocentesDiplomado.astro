---
import { Image } from "astro:assets";

interface Docente {
    nombre: string;
    profesion: string;
    descripcion: string;
    imagen: string;
}

interface Props {
    docentes: Docente[];
}

const { docentes = [] } = Astro.props;

// Importar todas las imágenes de docentes
const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/images/docentes/*.{webp,jpg,jpeg,png}",
);
---

{
    docentes.length > 0 && (
        <section class="docentes-section py-12 bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 md:px-10">
                <div class="mb-8">
                    <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">
                        Cuerpo Docente
                    </h2>
                    <p class="text-gray-600 max-w-2xl leading-relaxed">
                        Aprende de mediadores escolares, psicólogos
                        educacionales y expertos en convivencia con amplia
                        experiencia en establecimientos públicos y privados.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {docentes.map((docente, index) => {
                        const imageEntry = Object.entries(images).find(
                            ([path]) => path.endsWith(docente.imagen),
                        );
                        // La entrada es [path, loadFn], así que tomamos loadFn
                        const imageLoader = imageEntry
                            ? imageEntry[1]
                            : undefined;

                        // Colores para los avatares si no hay imagen (o como decorativo)
                        const colors = [
                            "bg-orange-100 text-orange-600",
                            "bg-teal-100 text-teal-600",
                            "bg-purple-100 text-purple-600",
                            "bg-blue-100 text-blue-600",
                        ];
                        const colorClass = colors[index % colors.length];

                        return (
                            <div class="docente-card group flex items-start gap-4 p-4 rounded-xl bg-gray-50 border border-transparent hover:bg-white hover:border-gray-200 hover:shadow-lg transition-all duration-300">
                                <div class="relative flex-shrink-0">
                                    <div
                                        class={`w-14 h-14 rounded-full overflow-hidden flex items-center justify-center font-bold text-lg ${!imageLoader ? colorClass : "bg-gray-200"}`}
                                    >
                                        {imageLoader ? (
                                            <Image
                                                src={imageLoader()}
                                                alt={docente.nombre}
                                                class="w-full h-full object-cover"
                                            />
                                        ) : (
                                            <span>
                                                {docente.nombre
                                                    .split(" ")
                                                    .map((n) => n[0])
                                                    .join("")
                                                    .substring(0, 2)}
                                            </span>
                                        )}
                                    </div>
                                </div>

                                <div class="flex-1 min-w-0">
                                    <h3 class="text-base font-bold text-gray-900 group-hover:text-primary transition-colors truncate">
                                        {docente.nombre}
                                    </h3>
                                    <p class="text-sm font-medium text-gray-500 mb-0.5 truncate">
                                        {docente.profesion}
                                    </p>
                                    <p class="text-xs text-gray-400 leading-snug line-clamp-2">
                                        {docente.descripcion}
                                    </p>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>
        </section>
    )
}

<style>
    /* Opcional: Ajustes finos si Tailwind no es suficiente */
    .docente-card {
        /* Smooth transition for the hover effect */
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>

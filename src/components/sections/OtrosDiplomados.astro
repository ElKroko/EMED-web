---
export interface Props {
    currentSlug: string;
}

const { currentSlug } = Astro.props;

const allDiplomados = [
    {
        slug: "mediacion-familiar",
        title: "Diplomado en Mediación Familiar",
        hours: "220 horas",
        modality: "Online + Presencial",
        image: "https://images.unsplash.com/photo-1609220136736-443140cffec6?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
    },
    {
        slug: "mediacion-escolar",
        title: "Diplomado en Mediación Escolar",
        hours: "240 horas",
        modality: "100% Online",
        image: "https://images.unsplash.com/photo-1544717297-fa95b6ee9643?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
    },
    {
        slug: "mediacion-laboral",
        title: "Diplomado en Mediación Laboral",
        hours: "240 horas",
        modality: "100% Online",
        image: "https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
    },
];

const diplomadosToShow = allDiplomados.filter((d) => d.slug !== currentSlug);
---

<div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
    <h2
        class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6"
    >
        Otros Diplomados que te Pueden Interesar
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
        {
            diplomadosToShow.map((diplomado) => (
                <a
                    href={`/diplomados/${diplomado.slug}`}
                    class="group flex flex-col bg-gray-50 border border-gray-100 rounded-2xl overflow-hidden hover:bg-white hover:shadow-lg hover:border-celeste/30 transition-all duration-300"
                >
                    <div class="relative h-48 overflow-hidden">
                        <img
                            src={diplomado.image}
                            alt={diplomado.title}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            loading="lazy"
                        />
                        <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm text-gray-900 text-xs font-bold px-3 py-1 rounded-full shadow-sm">
                            {diplomado.modality}
                        </div>
                    </div>
                    <div class="p-6 flex-1 flex flex-col">
                        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-celeste transition-colors">
                            {diplomado.title}
                        </h3>
                        <div class="flex items-center text-sm text-gray-600 mb-4">
                            <svg
                                class="w-5 h-5 mr-1.5 text-celeste/80"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                            {diplomado.hours}
                        </div>
                        <div class="mt-auto inline-flex items-center text-celeste font-bold text-sm">
                            Ver Detalles
                            <svg
                                class="ml-1.5 w-4 h-4 group-hover:translate-x-1 transition-transform"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 5l7 7-7 7"
                                />
                            </svg>
                        </div>
                    </div>
                </a>
            ))
        }
    </div>
</div>

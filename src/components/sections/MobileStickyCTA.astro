---
interface Props {
    title: string;
    price: string;
    duration: string;
    modality: string;
    whatsappLink: string;
}

const { title, price, duration, modality, whatsappLink } = Astro.props;
---

<div
    id="mobile-sticky-cta"
    class="md:hidden pointer-events-none z-50 fixed inset-0 opacity-0 transition-opacity duration-300 invisible"
>
    <!-- Bottom Drawer: Minimalist List Design -->
    <div
        class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md shadow-[0_-8px_30px_rgba(0,0,0,0.12)] p-4 pb-8 pointer-events-auto transform translate-y-full transition-transform duration-500 ease-out rounded-t-[2.5rem] border-t border-gray-100/50"
        id="mobile-sticky-bottom"
    >
        <div class="max-w-md mx-auto space-y-4">
            <!-- Header: Title & Compact Details -->
            <div class="text-center space-y-2">
                <h2
                    class="text-gray-900 font-extrabold text-sm uppercase tracking-wider"
                >
                    {title}
                </h2>

                <div
                    class="flex items-center justify-center gap-2 text-[11px] text-gray-500 font-bold uppercase tracking-tight"
                >
                    <span>{duration}</span>
                    <span class="text-gray-300">•</span>
                    <span>{modality}</span>
                    <span class="text-gray-300">•</span>
                    <span class="text-celeste">{price}</span>
                </div>
            </div>

            <!-- Minimalist Actions -->
            <div class="flex gap-3">
                <button
                    id="sticky-consultar-btn"
                    class="flex-[1] bg-naranja text-white font-bold py-3.5 px-4 rounded-2xl text-[13px] shadow-lg shadow-naranja/20 active:scale-95 transition-all flex items-center justify-center gap-2"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                        ></path>
                    </svg>
                    <span>Consultar</span>
                </button>

                <a
                    href={whatsappLink}
                    target="_blank"
                    class="flex-[1] bg-[#25D366] text-white font-bold py-3.5 px-4 rounded-2xl text-[13px] shadow-lg shadow-green-500/20 active:scale-95 transition-all flex items-center justify-center gap-2"
                    style="color: white !important;"
                >
                    <svg
                        class="w-4 h-4"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                        ></path>
                    </svg>
                    <span>WhatsApp</span>
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    function initMobileSticky() {
        const hero = document.querySelector(".hero-programa");
        const container = document.getElementById("mobile-sticky-cta");
        const bottomBar = document.getElementById("mobile-sticky-bottom");
        const consultBtn = document.getElementById("sticky-consultar-btn");

        if (consultBtn) {
            consultBtn.addEventListener("click", (e) => {
                e.preventDefault();
                const contactForm = document.getElementById("contact-form");
                if (contactForm) {
                    contactForm.scrollIntoView({
                        behavior: "smooth",
                    });
                }
            });
        }

        if (!hero || !container || !bottomBar) return;

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    const isScrolledPastHero =
                        !entry.isIntersecting &&
                        entry.boundingClientRect.top < 0;

                    if (isScrolledPastHero) {
                        container.classList.remove("invisible", "opacity-0");
                        requestAnimationFrame(() => {
                            bottomBar.classList.remove("translate-y-full");
                        });
                    } else {
                        bottomBar.classList.add("translate-y-full");
                        setTimeout(() => {
                            if (
                                bottomBar.classList.contains("translate-y-full")
                            ) {
                                container.classList.add("opacity-0");
                                setTimeout(() => {
                                    if (
                                        bottomBar.classList.contains(
                                            "translate-y-full",
                                        )
                                    ) {
                                        container.classList.add("invisible");
                                    }
                                }, 300);
                            }
                        }, 50);
                    }
                });
            },
            {
                threshold: 0,
                rootMargin: "0px",
            },
        );

        observer.observe(hero);
    }

    document.addEventListener("astro:page-load", initMobileSticky);
    document.addEventListener("DOMContentLoaded", initMobileSticky);
</script>

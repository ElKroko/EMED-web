---
import nch2728Logo from '../../assets/images/pages/nch2728.png';
import ipchileLogo from '../../assets/images/brands/IPCHILE.png';
import emedAcreditado from '../../assets/images/pages/emed_acreditado.png';

export interface Badge {
  name: string;
  src: string;
  alt: string;
}

export interface Props {
  heading?: string;
  sub?: string;
  description?: string;
  mascotSrc?: string;
  nch2728LogoSrc?: string;
  ipchileLogoSrc?: string;
  className?: string;
  sub_description?: string;
}

const {
  heading = "Te capacitamos con acreditación",
  sub = "Sistema de Gestión de Calidad",
  description = "EMED, a través de su OTEC EcoWorking Capacitaciones SpA, cumple la <strong>norma chilena NCh2728 de gestión de calidad en educación</strong> para comercializar, diseñar, planificar y ejecutar capacitaciones. Además, el <strong>Diplomado en Mediación Familiar</strong> cuenta con <strong>certificación de IPCHILE</strong>, institución de educación superior reconocida por el Estado, dando cumplimiento a la <strong>Circular 3511-2025 del Ministerio de Justicia</strong>.",
  sub_description = "*Certificada hasta diciembre 2028",
  mascotSrc = emedAcreditado.src,
  nch2728LogoSrc = nch2728Logo.src,
  ipchileLogoSrc = ipchileLogo.src,
  className = ""
} = Astro.props;
---

<section class={`accreditation-banner relative py-20 bg-crema ${className}`}>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-5 gap-12 items-center">
      
      <!-- Contenido principal - 60% -->
      <div class="col-span-3 text-left">
        <h2 class="text-6xl md:text-5xl lg:text-6xl font-bold text-black mb-4 leading-tight">
          {heading}
        </h2>
        
        <!-- Subtítulo -->
        <h3 class="text-2xl md:text-3xl font-light text-gray-400 mb-8 py-4">
          {sub}
        </h3>
        
        <!-- Párrafo descripción -->
        <p class="text-base md:text-lg text-gray-700 mb-8 leading-relaxed max-w-lg py-2" set:html={description}>
        </p>
        
        <!-- Sub descripción -->
        <p class="text-sm text-gray-500 mt-4 pt-6">
          {sub_description}
        </p>
      </div>

      <!-- Mascota y Logos de Certificación - 40% -->
      <div class="col-span-2 flex flex-col items-center justify-center space-y-8">

        <!-- Mascota -->
        {mascotSrc && (
          <div class="mascot-container relative">
            <div class="relative group">
              <img
                src={mascotSrc}
                alt="EMED Acreditado"
                class="w-48 h-48 md:w-56 md:h-56 object-contain group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          </div>
        )}

        <!-- Logos de Certificación -->
        <div class="grid grid-cols-2 gap-8 w-full max-w-md">

          <!-- Logo NCh2728 -->
          <div class="logo-container flex items-center justify-center p-6 transition-all duration-300">
            <img
              src={nch2728LogoSrc}
              alt="Certificación NCh2728 Sistema de Gestión de Calidad en Educación"
              class="w-full h-auto max-h-32 object-contain group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>

          <!-- Logo IPCHILE -->
          <div class="logo-container flex items-center justify-center p-6 transition-all duration-300">
            <img
              src={ipchileLogoSrc}
              alt="IPCHILE - Instituto Profesional de Chile"
              class="w-full h-auto max-h-32 object-contain group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>

        </div>

      </div>

    </div>

  </div>
</section>

<style>
  .accreditation-banner {
    position: relative;
  }

  .logo-container {
    animation: float 6s ease-in-out infinite;
  }

  .logo-container:nth-child(1) {
    animation-delay: 0.5s;
  }

  .logo-container:nth-child(2) {
    animation-delay: 1s;
  }

  .mascot-container {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }
</style>
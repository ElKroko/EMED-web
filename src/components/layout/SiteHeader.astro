---
export interface NavLink {
  label: string;
  href: string;
  children?: NavLink[];
}

export interface Props {
  links?: NavLink[];
  logoSrc?: string;
}

const {
  links = [
    { label: "HOME", href: "/" },
    {
      label: "DIPLOMADOS",
      href: "/diplomados",
      children: [
        { label: "Mediación Familiar", href: "/diplomados/mediacion-familiar" },
        { label: "Mediación Escolar", href: "/diplomados/mediacion-escolar" },
        { label: "Mediación Laboral", href: "/diplomados/mediacion-laboral" },
      ],
    },
    // { label: 'CURSOS', href: '/cursos' }, // Temporalmente oculto - en desarrollo
    { label: "NOSOTROS", href: "/nosotros" },
    { label: "ADMISIÓN", href: "/admision" },
    { label: "CONTACTO", href: "/contacto" },
  ],
  logoSrc = "/images/common/emed_logo.svg",
} = Astro.props;
---

<header
  class="site-header fixed top-0 left-0 right-0 z-50 bg-celeste shadow-md transition-all duration-300"
>
  <div class="container mx-auto">
    <nav class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a href="/" class="logo-link flex items-center">
        <img
          src={logoSrc}
          alt="EMED Logo"
          class="h-12 w-auto object-contain max-w-[200px]"
          style="height: 48px;"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-8">
        {
          links.map((link) => (
            <div class="relative group">
              <a
                href={link.href}
                class="nav-link font-bold tracking-wide hover:opacity-80 transition-all duration-200 relative drop-shadow-sm flex items-center"
                style="color: var(--color-white);"
              >
                {link.label}
                {link.children && (
                  <svg
                    class="w-4 h-4 ml-1 transform group-hover:rotate-180 transition-transform duration-200"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                )}
              </a>

              {link.children && (
                <div class="absolute left-0 mt-2 w-56 bg-celeste rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 z-50 border border-white/20 overflow-hidden">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-3 text-sm text-white hover:bg-white/10 transition-colors duration-200 font-medium border-b border-white/10 last:border-none"
                      style="color: white !important;"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))
        }
      </div>

      <!-- Mobile Menu Button -->
      <button
        class="mobile-menu-button lg:hidden flex items-center justify-center w-10 h-10 text-white hover:text-gray-200 transition-colors duration-200"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
      >
        <svg
          class="hamburger-icon w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          class="close-icon w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </nav>

    <!-- Mobile Navigation Menu -->
    <div
      class="mobile-menu lg:hidden hidden fixed top-[80px] left-0 w-full h-[calc(100vh-80px)] bg-celeste z-40 overflow-y-auto"
    >
      <div class="container mx-auto px-4 py-6 flex flex-col h-full">
        <div class="space-y-1">
          {
            links.map((link) => (
              <div class="border-b border-white/10 last:border-none">
                <a
                  href={link.href}
                  class="mobile-nav-link block py-4 text-xl font-bold text-white tracking-wide transition-all duration-300 hover:text-white/80 flex justify-between items-center group"
                >
                  <span>{link.label}</span>
                  {link.children && (
                    <svg
                      class="w-5 h-5 text-white/50 group-hover:text-white transition-colors"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  )}
                </a>
                {link.children && (
                  <div class="pl-4 space-y-2 mb-4 mt-1 border-l-2 border-white/20 ml-2">
                    {link.children.map((child) => (
                      <a
                        href={child.href}
                        class="block py-2 px-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg text-base font-medium transition-all duration-200"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))
          }
        </div>

        <!-- Mobile Menu Footer Info -->
        <div class="mt-auto pt-8 pb-12 text-white/60 text-sm text-center">
          <p>
            © {new Date().getFullYear()} EMED. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </div>
  </div>
</header>
<script>
  class SiteHeader {
    header: HTMLElement | null;
    mobileMenuButton: HTMLElement | null;
    mobileMenu: HTMLElement | null;
    hamburgerIcon: HTMLElement | null;
    closeIcon: HTMLElement | null;
    isMenuOpen: boolean;

    constructor() {
      this.header = document.querySelector(".site-header");
      this.mobileMenuButton = document.querySelector(".mobile-menu-button");
      this.mobileMenu = document.querySelector(".mobile-menu");
      this.hamburgerIcon = document.querySelector(".hamburger-icon");
      this.closeIcon = document.querySelector(".close-icon");
      this.isMenuOpen = false;

      this.init();
    }

    init() {
      // Mobile menu toggle
      this.mobileMenuButton?.addEventListener("click", () =>
        this.toggleMobileMenu(),
      );

      // Close mobile menu when clicking on links
      const mobileLinks = document.querySelectorAll(".mobile-menu a");
      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => this.closeMobileMenu());
      });

      // Handle scroll for sticky header effect
      window.addEventListener("scroll", () => this.handleScroll());

      // Handle resize to close mobile menu
      window.addEventListener("resize", () => {
        if (window.innerWidth >= 1024 && this.isMenuOpen) {
          this.closeMobileMenu();
        }
      });
    }

    toggleMobileMenu() {
      if (this.isMenuOpen) {
        this.closeMobileMenu();
      } else {
        this.openMobileMenu();
      }
    }

    openMobileMenu() {
      this.isMenuOpen = true;
      this.mobileMenu?.classList.remove("hidden");
      this.mobileMenu?.classList.add("flex"); // Ensure flex layout for full height
      this.hamburgerIcon?.classList.add("hidden");
      this.closeIcon?.classList.remove("hidden");
      this.mobileMenuButton?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
      this.header?.classList.add("bg-celeste"); // Ensure solid background when open
    }

    closeMobileMenu() {
      this.isMenuOpen = false;
      this.mobileMenu?.classList.add("hidden");
      this.mobileMenu?.classList.remove("flex");
      this.hamburgerIcon?.classList.remove("hidden");
      this.closeIcon?.classList.add("hidden");
      this.mobileMenuButton?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";

      // Revert background if at top
      if (window.scrollY <= 100) {
        this.header?.classList.remove("bg-celeste");
      }
    }

    handleScroll() {
      const scrollY = window.scrollY;

      if (scrollY > 100 || this.isMenuOpen) {
        this.header?.classList.add("header-scrolled");
      } else {
        this.header?.classList.remove("header-scrolled");
      }
    }
  }

  // Initialize header when DOM is loaded
  document.addEventListener("DOMContentLoaded", () => {
    new SiteHeader();
  });
</script>

<style>
  .site-header {
    backdrop-filter: blur(8px);
    background-color: rgba(
      126,
      197,
      214,
      0.95
    ); /* Default bg to avoid transparency issues */
  }

  .site-header.header-scrolled,
  .site-header.bg-celeste {
    background-color: var(--color-celeste);
    box-shadow: var(--shadow-lg);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-white);
    transition: width var(--transition-fast);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .mobile-menu {
    animation: fadeIn 0.3s ease-out;
    background-color: var(--color-celeste);
    /* Subtle gradient for premium feel */
    background: linear-gradient(180deg, var(--color-celeste) 0%, #6bbecf 100%);
  }

  /* Force white text on all mobile menu links */
  .mobile-menu a {
    color: white !important;
  }

  .mobile-menu a:hover {
    color: rgba(255, 255, 255, 0.9) !important;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Ensure header doesn't cover content */
  body {
    padding-top: 80px;
  }

  @media (max-width: 1023px) {
    body {
      padding-top: 72px;
    }

    .mobile-menu {
      top: 72px;
      height: calc(100vh - 72px);
    }
  }
</style>

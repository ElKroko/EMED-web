---
export interface Props {
  type?:
    | "general"
    | "programa"
    | "admision"
    | "financiamiento"
    | "empresa"
    | "contacto";
  program?: string;
  source?: string;
  title?: string;
  subtitle?: string;
  showUrgency?: boolean;
  className?: string;
}

const {
  type = "general",
  program = "",
  source = "contacto-general",
  title = "¿Tienes alguna consulta?",
  subtitle = "Habla con uno de nuestros asesores académicos",
  showUrgency = false,
  className = "",
} = Astro.props;

// Personalizar mensajes según el tipo
const getFormConfig = (type: string, program: string) => {
  switch (type) {
    case "programa":
      return {
        title: `Consulta sobre ${program}`,
        subtitle:
          "Un asesor académico te contactará para resolver todas tus dudas",
        buttonText: "Solicitar Información",
        urgencyText: "¡Últimas vacantes disponibles!",
      };
    case "financiamiento":
      return {
        title: "Solicita Información sobre Financiamiento",
        subtitle:
          "Te ayudamos con opciones empresariales, becas y facilidades de pago",
        buttonText: "Consultar Financiamiento",
        urgencyText: "Becas limitadas - ¡Consulta ahora!",
      };
    case "empresa":
      return {
        title: "Capacitación para tu Organización",
        subtitle: "Programas corporativos diseñados para equipos y empresas",
        buttonText: "Solicitar Propuesta",
        urgencyText: "Descuentos especiales para grupos",
      };
    case "admision":
      return {
        title: "Inicia tu Proceso de Admisión",
        subtitle: "Te guiamos paso a paso en tu inscripción",
        buttonText: "Comenzar Admisión",
        urgencyText: "Proceso de admisión abierto",
      };
    default:
      return {
        title: "Contáctanos",
        subtitle: "Resuelve todas tus dudas con nuestros asesores",
        buttonText: "Enviar Consulta",
        urgencyText: "Respuesta en menos de 2 horas",
      };
  }
};

const config = getFormConfig(type, program);
const formTitle = title || config.title;
const formSubtitle = subtitle || config.subtitle;
---

<div class={`contact-form-container bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden ${className}`}>

  <!-- Barra de acento superior -->
  <div class="h-1.5 bg-gradient-to-r from-celeste to-turquesa"></div>

  <!-- Header -->
  <div class="px-6 md:px-8 pt-7 pb-5 text-center">
    {
      showUrgency && (
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-naranja/10 text-naranja rounded-full text-xs font-semibold mb-4 tracking-wide">
          <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"
              clip-rule="evenodd"
            />
          </svg>
          {config.urgencyText}
        </div>
      )
    }
    <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-1.5 leading-tight">
      {formTitle}
    </h3>
    <p class="text-gray-500 text-sm md:text-base">
      {formSubtitle}
    </p>
  </div>

  <!-- Separador -->
  <div class="mx-6 md:mx-8 h-px bg-gray-100"></div>

  <!-- Formulario -->
  <form
    class="contact-form px-6 md:px-8 py-6 space-y-7"
    data-type={type}
    data-program={program}
    data-source={source}
  >
    <!-- Campos ocultos para tracking -->
    <input type="hidden" name="form_type" value={type} />
    <input type="hidden" name="program" value={program} />
    <input type="hidden" name="source" value={source} />
    <input type="hidden" name="timestamp" value="" />

    <!-- Honeypot anti-spam -->
    <div style="display:none" aria-hidden="true">
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <!-- Sección: Tus datos -->
    <fieldset class="space-y-4">
      <legend class="text-[10px] font-bold uppercase tracking-widest text-gray-400 pb-1">Tus datos</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-field-wrap">
          <label for="nombre" class="form-label">
            Nombre completo <span class="text-naranja">*</span>
          </label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="form-input"
            placeholder="Tu nombre completo"
          />
        </div>
        <div class="form-field-wrap">
          <label for="email" class="form-label">
            Email <span class="text-naranja">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="form-input"
            placeholder="tu@email.com"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-field-wrap">
          <label for="telefono" class="form-label">
            Teléfono <span class="text-naranja">*</span>
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </span>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              required
              class="form-input pl-9"
              placeholder="+56 9 1234 5678"
            />
          </div>
        </div>

        {
          type === "empresa" ? (
            <div class="form-field-wrap">
              <label for="empresa" class="form-label">
                Nombre de la empresa <span class="text-naranja">*</span>
              </label>
              <input
                type="text"
                id="empresa"
                name="empresa"
                required
                class="form-input"
                placeholder="Nombre de tu organización"
              />
            </div>
          ) : (
            <div class="form-field-wrap">
              <label for="ciudad" class="form-label">Ciudad</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </span>
                <input
                  type="text"
                  id="ciudad"
                  name="ciudad"
                  class="form-input pl-9"
                  placeholder="Tu ciudad"
                />
              </div>
            </div>
          )
        }
      </div>

      <div class="form-field-wrap">
        <label for="profesion" class="form-label">Profesión</label>
        <input
          type="text"
          id="profesion"
          name="profesion"
          class="form-input"
          placeholder="Ej: Abogado/a, Psicólogo/a, Trabajador/a Social…"
        />
      </div>

      {
        type === "empresa" && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="form-field-wrap">
              <label for="num_participantes" class="form-label">
                Número de participantes <span class="text-naranja">*</span>
              </label>
              <select id="num_participantes" name="num_participantes" required class="form-select">
                <option value="">Selecciona</option>
                <option value="1-5">1-5 personas</option>
                <option value="6-15">6-15 personas</option>
                <option value="16-30">16-30 personas</option>
                <option value="30+">Más de 30 personas</option>
              </select>
            </div>
            <div class="form-field-wrap">
              <label for="sector" class="form-label">Sector de la empresa</label>
              <input
                type="text"
                id="sector"
                name="sector"
                class="form-input"
                placeholder="Ej: Salud, Educación, etc."
              />
            </div>
          </div>
        )
      }
    </fieldset>

    <!-- Sección: Tu consulta -->
    <fieldset class="space-y-4">
      <legend class="text-[10px] font-bold uppercase tracking-widest text-gray-400 pb-1">Tu consulta</legend>

      {
        type === "general" && (
          <div class="form-field-wrap">
            <label for="interes" class="form-label">
              ¿Qué te interesa? <span class="text-naranja">*</span>
            </label>
            <select id="interes" name="interes" required class="form-select">
              <option value="">Selecciona tu interés</option>
              <option value="mediacion-familiar">Mediación Familiar</option>
              <option value="mediacion-escolar">Mediación Escolar</option>
              <option value="mediacion-laboral">Mediación Laboral</option>
              <option value="cursos-especializacion">Cursos de Especialización</option>
              <option value="informacion-general">Información General</option>
            </select>
          </div>
        )
      }

      {
        type === "financiamiento" && (
          <div class="form-field-wrap">
            <label for="financiamiento_tipo" class="form-label">
              Tipo de financiamiento de interés <span class="text-naranja">*</span>
            </label>
            <select id="financiamiento_tipo" name="financiamiento_tipo" required class="form-select">
              <option value="">Selecciona una opción</option>
              <option value="financiamiento-empresa">Financiamiento Empresarial</option>
              <option value="beca-cofinanciamiento">Beca de Cofinanciamiento</option>
              <option value="facilidades-pago">Facilidades de Pago</option>
            </select>
          </div>
        )
      }

      <div class="form-field-wrap">
        <label for="mensaje" class="form-label">
          {type === "programa" ? "Preguntas específicas sobre el programa" : "Mensaje"}
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="3"
          class="form-input resize-none"
          placeholder={type === "programa"
            ? `Cuéntanos qué te gustaría saber sobre ${program}`
            : "Cuéntanos cómo podemos ayudarte"}
        ></textarea>
      </div>
    </fieldset>

    <!-- Sección: Cómo contactarte -->
    <fieldset class="space-y-4">
      <legend class="text-[10px] font-bold uppercase tracking-widest text-gray-400 pb-1">Cómo contactarte</legend>

      <!-- Pill checkboxes -->
      <div>
        <p class="text-sm font-medium text-gray-600 mb-3">¿Cómo prefieres que te contactemos?</p>
        <div class="flex flex-wrap gap-2">
          <label class="contact-pill cursor-pointer">
            <input
              type="checkbox"
              name="contacto_preferencia[]"
              value="whatsapp"
              class="sr-only"
            />
            <span class="pill-label">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
              </svg>
              WhatsApp
            </span>
          </label>

          <label class="contact-pill cursor-pointer">
            <input
              type="checkbox"
              name="contacto_preferencia[]"
              value="llamada"
              class="sr-only"
            />
            <span class="pill-label">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Llamada
            </span>
          </label>

          <label class="contact-pill cursor-pointer">
            <input
              type="checkbox"
              name="contacto_preferencia[]"
              value="email"
              class="sr-only"
            />
            <span class="pill-label">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Email
            </span>
          </label>
        </div>
      </div>

      <!-- Horario preferido -->
      <div class="form-field-wrap">
        <label for="horario_preferido" class="form-label">Horario preferido para ser contactado</label>
        <select id="horario_preferido" name="horario_preferido" class="form-select">
          <option value="">Sin preferencia</option>
          <option value="mañana">Mañana (9:00 - 12:00)</option>
          <option value="tarde">Tarde (14:00 - 18:00)</option>
        </select>
      </div>
    </fieldset>

    <!-- Términos y Cloudflare -->
    <div class="space-y-4">
      <label class="flex items-start gap-3 cursor-pointer group">
        <div class="relative mt-0.5 shrink-0">
          <input
            type="checkbox"
            id="terminos"
            name="terminos"
            required
            class="sr-only"
          />
          <div class="terminos-box w-5 h-5 rounded border-2 border-gray-300 transition-all duration-200 flex items-center justify-center shrink-0">
            <svg class="checkmark-icon w-3 h-3 text-white opacity-0 transition-opacity duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        </div>
        <span class="text-xs text-gray-500 leading-relaxed">
          Acepto que EMED me contacte para brindarme información sobre sus programas y acepto la
          <a href="/politica-privacidad" class="text-celeste hover:underline font-medium">Política de Privacidad</a>
        </span>
      </label>

      <div class="cf-turnstile" data-sitekey="0x4AAAAAACyTSkU-5pQP68n-" data-theme="light"></div>
    </div>

    <!-- Botón de envío -->
    <button
      type="submit"
      class="w-full h-13 flex items-center justify-center gap-2.5 bg-gradient-to-r from-celeste to-turquesa text-white font-bold text-base rounded-2xl hover:shadow-lg hover:shadow-celeste/30 hover:brightness-105 active:scale-[0.99] transition-all duration-200 cursor-pointer"
    >
      {config.buttonText}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </button>

    <!-- Mensaje de envío exitoso -->
    <div class="form-success hidden bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-2xl p-6 text-center">
      <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h4 class="text-green-800 font-bold text-lg mb-1">¡Consulta enviada!</h4>
      <p class="text-green-700 text-sm">
        Un asesor académico te contactará en las próximas 2 horas.
      </p>
    </div>
  </form>

  <!-- WhatsApp directo -->
  <div class="px-6 md:px-8 pb-7">
    <div class="flex items-center gap-3 mb-4">
      <div class="flex-1 h-px bg-gray-100"></div>
      <span class="text-xs text-gray-400 font-medium whitespace-nowrap">o habla ahora mismo</span>
      <div class="flex-1 h-px bg-gray-100"></div>
    </div>
    <a
      href="https://wa.me/56965620939?text=Hola,%20tengo%20una%20consulta%20sobre%20los%20programas%20de%20EMED"
      target="_blank"
      class="whatsapp-direct-btn flex items-center justify-center gap-3 w-full py-3.5 bg-green-50 hover:bg-green-100 border border-green-200 text-green-700 font-semibold text-sm rounded-2xl transition-colors duration-200 cursor-pointer"
    >
      <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
        ></path>
      </svg>
      Escribir por WhatsApp
    </a>
  </div>
</div>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  class ContactFormHandler {
    forms;
    whatsappNumber;

    constructor() {
      // @ts-ignore
      this.forms = document.querySelectorAll(".contact-form");
      this.whatsappNumber = "56965620939"; // Número oficial
      this.init();
    }

    init() {
      this.forms.forEach((form) => {
        const el = form as HTMLElement;
        if (el.dataset.handlerAttached) return;
        el.dataset.handlerAttached = "true";

        // Agregar timestamp cuando se carga el formulario
        const timestampField = form.querySelector('input[name="timestamp"]') as HTMLInputElement | null;
        if (timestampField) {
          timestampField.value = new Date().toISOString();
        }

        // Manejar envío del formulario
        form.addEventListener("submit", (e) => this.handleSubmit(e));
      });

      // Manejar botones de WhatsApp directo para que incluyan datos del formulario si existen
      const directButtons = document.querySelectorAll(".whatsapp-direct-btn");
      directButtons.forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const container = btn.closest(".contact-form-container");
          const form = container?.querySelector("form");

          if (form) {
            const formData = new FormData(form);
            const hasData =
              formData.get("nombre") ||
              formData.get("email") ||
              formData.get("mensaje");

            if (hasData) {
              e.preventDefault();
              const msg = this.formatWhatsAppMessage(formData);
              const whatsappUrl = `https://wa.me/${this.whatsappNumber}?text=${msg}`;
              window.open(whatsappUrl, "_blank");
            }
            // Si no hay datos, dejamos que el link funcione normalmente con su mensaje predeterminado
          }
        });
      });
    }

    formatWhatsAppMessage(formData: FormData) {
      let msg = `*Nueva Consulta desde Web*\n\n`;

      const nombre = formData.get("nombre");
      const email = formData.get("email");
      const telefono = formData.get("telefono");

      if (nombre) msg += `*Nombre:* ${nombre}\n`;
      if (email) msg += `*Email:* ${email}\n`;
      if (telefono) msg += `*Teléfono:* ${telefono}\n`;

      const profesion = formData.get("profesion");
      if (profesion) msg += `*Profesión:* ${profesion}\n`;

      const empresa = formData.get("empresa");
      const ciudad = formData.get("ciudad");
      if (empresa) msg += `*Empresa:* ${empresa}\n`;
      if (ciudad) msg += `*Ciudad:* ${ciudad}\n`;

      const program = formData.get("program");
      const interes = formData.get("interes");
      if (program) msg += `*Programa:* ${program}\n`;
      if (interes) msg += `*Interés:* ${interes}\n`;

      const financiamiento = formData.get("financiamiento_tipo");
      if (financiamiento) msg += `*Financiamiento:* ${financiamiento}\n`;

      const sector = formData.get("sector");
      if (sector) msg += `*Sector:* ${sector}\n`;

      const numParticipantes = formData.get("num_participantes");
      if (numParticipantes) msg += `*Participantes:* ${numParticipantes}\n`;

      // Obtener preferencias (puede haber múltiples)
      // @ts-ignore
      const preferencias = formData.getAll("contacto_preferencia[]");

      if (preferencias.length > 0) {
        msg += `*Preferencia Contacto:* ${preferencias.join(", ")}\n`;
      }

      const horario = formData.get("horario_preferido");
      if (horario) msg += `*Horario:* ${horario}\n`;

      const mensaje = formData.get("mensaje");
      if (mensaje) msg += `\n*Mensaje:*\n${mensaje}`;

      return encodeURIComponent(msg);
    }

    async handleSubmit(e: Event) {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);
      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const successMessage = form.parentElement?.querySelector(".form-success");

      // Verificar si WhatsApp está seleccionado
      // @ts-ignore
      const preferencias = formData.getAll("contacto_preferencia[]");
      const isWhatsApp = preferencias.includes("whatsapp");

      // Deshabilitar botón
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.innerHTML = "Enviando...";
      }

      try {
        const response = await fetch("/send_mail.php", {
          method: "POST",
          body: formData,
        });

        let result;
        const text = await response.text();
        try {
          result = JSON.parse(text);
        } catch (e) {
          // Si no es JSON válido, asumimos error o éxito basado en status
          result = { status: response.ok ? "success" : "error", message: text };
        }

        if (response.ok && (result.status === "success" || !result.status)) {
          // Éxito
          form.style.display = "none";
          if (successMessage) {
            successMessage.classList.remove("hidden");

            // Si el usuario quería WhatsApp, le mostramos un botón para continuar allí
            if (isWhatsApp) {
              const p = successMessage.querySelector("p");
              if (p) {
                p.innerHTML = `Hemos enviado un correo de confirmación.<br><br>
                 <a href="https://wa.me/${this.whatsappNumber}?text=${this.formatWhatsAppMessage(formData)}"
                    target="_blank"
                    class="inline-block mt-2 px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition-colors">
                    Continuar en WhatsApp
                 </a>`;
              }
            }
          }
        } else {
          throw new Error(result.message || "Error al enviar el mensaje");
        }
      } catch (error) {
        console.error("Error enviando formulario:", error);

        // Si falla el email le ofrecemos WhatsApp como alternativa
        if (
          confirm(
            "Hubo un problema con el envío del correo. ¿Deseas enviar la información por WhatsApp?",
          )
        ) {
          const msg = this.formatWhatsAppMessage(formData);
          const whatsappUrl = `https://wa.me/${this.whatsappNumber}?text=${msg}`;
          window.open(whatsappUrl, "_blank");
        }

        if (submitButton) {
          submitButton.disabled = false;
          submitButton.innerHTML = "Enviar Consulta";
        }
      }
    }
  }

  // Inicializar cuando el DOM esté listo
  document.addEventListener("DOMContentLoaded", () => {
    new ContactFormHandler();
  });
</script>


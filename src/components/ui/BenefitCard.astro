---
export interface Props {
  title: string;
  text: string;
  icon?: string;
  className?: string;
}

const { 
  title,
  text,
  icon,
  className = ""
} = Astro.props;
---

<div class={`benefit-card bg-white border border-white border-opacity-50 rounded-lg p-6 hover:border-opacity-100 hover:shadow-lg transition-all duration-300 group ${className}`}>
  
  {icon && (
    <div class="benefit-icon text-3xl mb-4 group-hover:scale-110 transition-transform duration-300">
      {icon}
    </div>
  )}
  
  <h3 class="benefit-title text-xl font-semibold text-gray-700 mb-3 group-hover:text-gray-800 transition-colors duration-300">
    {title}
  </h3>
  
  <p class="benefit-text text-gray-600 leading-relaxed group-hover:text-gray-700 transition-all duration-300" set:html={text} />
  
</div>


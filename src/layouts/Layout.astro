---
import "../styles/global.css";
import "@fontsource-variable/inter";
import "@fontsource/ubuntu/400.css";
import "@fontsource/ubuntu/500.css";
import "@fontsource/ubuntu/700.css";
import SiteHeader from "../components/layout/SiteHeader.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";

export interface Props {
	title?: string;
	description?: string;
}

const {
	title = "EMED - Formando Mediadores desde 2005",
	description = "Centro de formaciГіn especializado en mediaciГіn familiar, escolar y laboral. Programas acreditados con metodologГӯa prГЎctica y certificaciГіn reconocida.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="mediaciГіn, formaciГіn, capacitaciГіn, mediador, resoluciГіn conflictos, EMED"
		/>
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta
			http-equiv="Content-Security-Policy"
			content="script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; script-src-elem 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; img-src 'self' data: https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://region1.google-analytics.com https://stats.g.doubleclick.net;"
		/>
		<!-- Meta Pixel Code -->
		<script>
			!(function (f, b, e, v, n, t, s) {
				if (f.fbq) return;
				n = f.fbq = function () {
					n.callMethod
						? n.callMethod.apply(n, arguments)
						: n.queue.push(arguments);
				};
				if (!f._fbq) f._fbq = n;
				n.push = n;
				n.loaded = !0;
				n.version = "2.0";
				n.queue = [];
				t = b.createElement(e);
				t.async = !0;
				t.src = v;
				s = b.getElementsByTagName(e)[0];
				s.parentNode.insertBefore(t, s);
			})(
				window,
				document,
				"script",
				"https://connect.facebook.net/en_US/fbevents.js",
			);
			fbq("init", "963747371462256");
			fbq("track", "PageView");
		</script>
		<noscript
			><img
				height="1"
				width="1"
				style="display:none"
				src="https://www.facebook.com/tr?id=963747371462256&ev=PageView&noscript=1"
			/></noscript
		>
		<!-- End Meta Pixel Code -->
		<!-- Google tag (gtag.js) -->
		<script src="https://www.googletagmanager.com/gtag/js?id=G-437494561"
		></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());

			gtag("config", "G-437494561");
		</script>

		<!-- Google Tag Manager -->
		<script>
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({
					"gtm.start": new Date().getTime(),
					event: "gtm.js",
				});
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s),
					dl = l != "dataLayer" ? "&l=" + l : "";
				j.setAttribute("async", "true");
				j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
				f.parentNode.insertBefore(j, f);
			})(window, document, "script", "dataLayer", "GTM-M7FMVPHG");
		</script>
		<!-- End Google Tag Manager -->
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript
			><iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-M7FMVPHG"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe></noscript
		>
		<!-- End Google Tag Manager (noscript) -->
		<SiteHeader logoSrc="/images/common/emed_logo.svg" />
		<main>
			<slot />
		</main>
		<SiteFooter />
		<script>
			// рҹҺЁ Digitalismo Developer Credit вҖ” ASCII Art
			const lines = [
				"",
				"   в–Ҳв–Ҳв–Ҳв–Ҳ   в–Ҳ  в–Ҳв–Ҳв–Ҳ  в–Ҳ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳ  в–Ҳ     в–Ҳ в–Ҳв–Ҳв–Ҳ в–Ҳ   в–Ҳ  в–Ҳв–Ҳв–Ҳ   ",
				"   в–Ҳ   в–Ҳ  в–Ҳ в–Ҳ     в–Ҳ   в–Ҳ   в–Ҳ   в–Ҳ в–Ҳ     в–Ҳ в–Ҳ   в–Ҳв–Ҳ в–Ҳв–Ҳ в–Ҳ   в–Ҳ  ",
				"   в–Ҳ   в–Ҳ  в–Ҳ в–Ҳ  в–Ҳв–Ҳ в–Ҳ   в–Ҳ   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳ     в–Ҳ в–Ҳв–Ҳв–Ҳ в–Ҳ в–Ҳ в–Ҳ в–Ҳ   в–Ҳ  ",
				"   в–Ҳ   в–Ҳ  в–Ҳ в–Ҳ   в–Ҳ в–Ҳ   в–Ҳ   в–Ҳ   в–Ҳ в–Ҳ     в–Ҳ   в–Ҳ в–Ҳ   в–Ҳ в–Ҳ   в–Ҳ  ",
				"   в–Ҳв–Ҳв–Ҳв–Ҳ   в–Ҳ  в–Ҳв–Ҳв–Ҳ  в–Ҳ   в–Ҳ   в–Ҳ   в–Ҳ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳ в–Ҳв–Ҳв–Ҳ в–Ҳ   в–Ҳ  в–Ҳв–Ҳв–Ҳ   ",
				"",
				"   рҹҡҖ ВЎHola, dev! Nos encanta que tengas curiosidad",
				"   Este sitio fue desarrollado por Digitalismo.                 ",
				"   рҹҢҗ www.digitalismo.cl                                        ",
				"   вңүпёҸ  hola@digitalismo.cl вҖ” ВЎTrabajemos juntos!                 ",
				"",
			];
			const colors = [
				"#7B2FF7",
				"#7633F3",
				"#7137EF",
				"#6C3BEB",
				"#673FE7",
				"#6243E3",
				"#5D47DF",
				"#584BDB",
				"#534FD7",
				"#4E53D3",
				"#4957CF",
				"#445BCB",
				"#3F5FC7",
				"#3A63C3",
				"#3567BF",
				"#306BBB",
				"#2B6FB7",
				"#2673B3",
				"#2177AF",
				"#1C7BAB",
				"#177FA7",
				"#1283A3",
				"#22D1EE",
			];
			lines.forEach((line, i) => {
				const c = colors[Math.min(i, colors.length - 1)];
				console.log(
					`%c${line}`,
					`color:${c};font-family:monospace;font-size:12px;font-weight:bold;`,
				);
			});
		</script>
	</body>
</html>

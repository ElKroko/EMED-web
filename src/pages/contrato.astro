<script>
    // Programa condicional
    const progSelect = document.getElementById("programa") as HTMLSelectElement;
    const otroPW = document.getElementById("otro-programa-wrapper");
    const otroPI = document.getElementById("otroprograma") as HTMLInputElement;
    if (progSelect) {
        progSelect.addEventListener("change", () => {
            if (progSelect.value === "Otro") {
                otroPW?.classList.remove("hidden");
                otroPI?.setAttribute("required", "");
            } else {
                otroPW?.classList.add("hidden");
                otroPI?.removeAttribute("required");
                if (otroPI) otroPI.value = "";
            }
        });
    }

    // Timestamp
    const ts = document.querySelector(
        'input[name="timestamp"]',
    ) as HTMLInputElement;
    if (ts) ts.value = new Date().toISOString();

    // RUT formatting
    const rutInput = document.getElementById("rut") as HTMLInputElement;
    if (rutInput) {
        rutInput.addEventListener("input", () => {
            let val = rutInput.value.replace(/[^0-9kK]/g, "");
            if (val.length > 1) {
                const body = val.slice(0, -1);
                const dv = val.slice(-1).toUpperCase();
                let formatted = "";
                for (let i = body.length - 1, count = 0; i >= 0; i--, count++) {
                    if (count > 0 && count % 3 === 0)
                        formatted = "." + formatted;
                    formatted = body[i] + formatted;
                }
                rutInput.value = formatted + "-" + dv;
            }
        });
    }

    // File upload visual feedback
    document
        .querySelectorAll('.file-upload-area input[type="file"]')
        .forEach((input) => {
            input.addEventListener("change", (e) => {
                const target = e.target as HTMLInputElement;
                const area = target.closest(".file-upload-area");
                const nameEl = area?.querySelector(".file-name");
                if (target.files && target.files[0] && nameEl) {
                    const file = target.files[0];
                    if (file.size > 5 * 1024 * 1024) {
                        alert("El archivo supera el tamaño máximo de 5 MB.");
                        target.value = "";
                        return;
                    }
                    nameEl.textContent = `✓ ${file.name} (${(file.size / 1024).toFixed(0)} KB)`;
                    nameEl.classList.remove("text-gray-400");
                    nameEl.classList.add("text-green-600", "font-medium");
                    area?.classList.add("border-green-400", "bg-green-50/50");
                    area?.classList.remove("border-gray-300");
                }
            });
        });

    // Scroll indicator
    const contractDiv = document.getElementById("contract-text");
    const scrollInd = document.getElementById("scroll-indicator");
    if (contractDiv && scrollInd) {
        contractDiv.addEventListener("scroll", () => {
            if (
                contractDiv.scrollTop + contractDiv.clientHeight >=
                contractDiv.scrollHeight - 50
            ) {
                scrollInd.style.display = "none";
            }
        });
    }

    // Form submission
    const form = document.getElementById("contrato-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
        "btn-submit",
    ) as HTMLButtonElement;
    const successDiv = document.getElementById("form-success");

    if (form) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            successDiv?.classList.add("hidden");

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = `<svg class="animate-spin w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Enviando...`;
            }

            const formData = new FormData(form);

            try {
                const response = await fetch("/send_contrato.php", {
                    method: "POST",
                    body: formData,
                });
                let result;
                const text = await response.text();
                try {
                    result = JSON.parse(text);
                } catch {
                    result = {
                        status: response.ok ? "success" : "error",
                        message: text,
                    };
                }

                if (
                    response.ok &&
                    (result.status === "success" || !result.status)
                ) {
                    window.location.href = "/contrato-firmado";
                } else {
                    throw new Error(result.message || "Error al enviar");
                }
            } catch (error) {
                console.error("Error:", error);
                if (
                    confirm(
                        "Hubo un problema al enviar. ¿Deseas contactarnos por WhatsApp?",
                    )
                ) {
                    window.open(
                        "https://wa.me/56965620939?text=Hola,%20tuve%20problemas%20al%20enviar%20el%20contrato%20desde%20la%20web",
                        "_blank",
                    );
                }
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = `<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>Firmar y Enviar Contrato`;
                }
            }
        });
    }
</script>


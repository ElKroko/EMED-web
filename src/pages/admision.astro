---
import Layout from "../layouts/Layout.astro";
import CtaFinal from "../components/sections/CtaFinal.astro";
import { Image } from "astro:assets";
import admisionBanner from "../assets/images/pages/foto-4.webp";
import salaClases from "../assets/images/pages/sala-de-clases.webp";
import fotoModalidad from "../assets/images/pages/foto-2.webp";

const programRows = [
  {
    program: "Diplomado Mediación Familiar",
    presencial: true,
    sincronica: true,
    asincronica: true,
    online: true,
  },
  {
    program: "Diplomado Mediación Escolar",
    presencial: false,
    sincronica: true,
    asincronica: true,
    online: true,
  },
  {
    program: "Diplomado Mediación Laboral",
    presencial: false,
    sincronica: true,
    asincronica: true,
    online: true,
  },
  {
    program: "Cursos de Especialización",
    presencial: false,
    sincronica: false,
    asincronica: true,
    online: true,
  },
];

const benefits = [
  {
    title: "Acompañamiento cercano",
    description:
      "Tutorías, feedback en vivo y laboratorio de casos reales para un aprendizaje efectivo.",
    icon: "users",
  },
  {
    title: "Excelencia formación",
    description:
      "Diseños académicos rigurosos y evaluación formativa para que seas un mediador experto.",
    icon: "academic",
  },
  {
    title: "Flexibilidad real",
    description:
      "Modalidades 100% online y semipresencial con horarios compatibles con tu vida laboral.",
    icon: "clock",
  },
  {
    title: "Respaldo y certificaciones",
    description:
      "Convenios y certificación vigente (Minju) para potenciar tu desarrollo profesional.",
    icon: "badge",
  },
];
---

<Layout
  title="Admisión - EMED | Proceso de Inscripción y Modalidades"
  description="Conoce nuestro proceso de admisión, modalidades de estudio y opciones de financiamiento. Fórmate como mediador profesional con EMED."
>
  <div class="bg-crema min-h-screen font-sans">
    <!-- Hero Section -->
    <section class="relative py-24 lg:py-32 overflow-hidden">
      <!-- Background Image with Overlay -->
      <div class="absolute inset-0 z-0">
        <Image
          src={admisionBanner}
          alt="Admisión EMED"
          class="w-full h-full object-cover object-center"
        />
        <div
          class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/30"
        >
        </div>
      </div>

      <!-- Hero Content -->
      <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <nav class="flex items-center space-x-2 text-white/80 text-sm mb-6">
            <a href="/" class="hover:text-white transition-colors">Inicio</a>
            <span>/</span>
            <span class="text-white font-medium">Admisión</span>
          </nav>

          <!-- Badges -->
          <div class="flex flex-wrap gap-3 mb-6">
            <span
              class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-bold bg-naranja text-white shadow-lg"
            >
              Admisión 2026 Abierta
            </span>
            <span
              class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-white/20 text-white backdrop-blur-sm"
            >
              Cupos Limitados
            </span>
          </div>

          <h1
            class="text-4xl md:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight"
          >
            Comienza tu camino en la <br />
            <span class="text-celeste">Mediación Profesional</span>
          </h1>

          <p class="text-xl text-white/90 mb-10 max-w-2xl leading-relaxed">
            Te acompañamos durante todo el proceso para garantizar las mejores
            prácticas de formación académica y profesional. Únete a la comunidad
            de mediadores más grande del país.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/diplomados"
              class="inline-flex justify-center items-center px-8 py-4 bg-celeste text-white font-bold rounded-xl hover:bg-turquesa transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1"
            >
              Ver Programas
              <svg
                class="w-5 h-5 ml-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="/contacto"
              class="inline-flex justify-center items-center px-8 py-4 bg-white/10 text-white font-bold rounded-xl hover:bg-white/20 transition-all duration-300 backdrop-blur-sm border border-white/30"
            >
              Contactar Asesor
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-20 lg:py-24 bg-crema relative z-10">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold text-gray-800 mb-6">
            Fórmate con <span class="text-naranja">Excelencia</span>
          </h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            Nuestra metodología está diseñada para transformar profesionales en
            mediadores expertos, combinando teoría rigurosa con práctica
            intensiva.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {
            benefits.map((benefit, index) => (
              <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 group">
                <div class="w-14 h-14 rounded-2xl bg-celeste/10 text-celeste flex items-center justify-center mb-6 text-2xl group-hover:bg-celeste group-hover:text-white transition-colors duration-300">
                  {benefit.icon === "users" && (
                    <svg
                      class="w-7 h-7"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                      />
                    </svg>
                  )}
                  {benefit.icon === "academic" && (
                    <svg
                      class="w-7 h-7"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 14l9-5-9-5-9 5 9 5z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                      />
                    </svg>
                  )}
                  {benefit.icon === "clock" && (
                    <svg
                      class="w-7 h-7"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                  )}
                  {benefit.icon === "badge" && (
                    <svg
                      class="w-7 h-7"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                      />
                    </svg>
                  )}
                </div>
                <h3 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-celeste transition-colors">
                  {benefit.title}
                </h3>
                <p class="text-gray-600 leading-relaxed text-sm">
                  {benefit.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Modalities Section -->
    <section class="py-20 bg-crema relative">
      <div class="container mx-auto px-6">
        <div class="flex flex-col lg:flex-row items-center gap-16">
          <div class="lg:w-1/2">
            <h2 class="text-3xl md:text-5xl font-bold text-gray-800 mb-6">
              Elige tu <span class="text-turquesa">Modalidad Ideal</span>
            </h2>
            <p class="text-lg text-gray-600 mb-8 leading-relaxed">
              Sabemos que cada estudiante tiene necesidades diferentes. Por eso
              hemos diseñado modalidades que se adaptan a tu ritmo de vida sin
              sacrificar la calidad académica.
            </p>

            <div class="space-y-6">
              <div
                class="flex p-6 bg-white rounded-2xl border border-gray-100 hover:border-turquesa/30 transition-all"
              >
                <div class="flex-shrink-0 mr-6">
                  <div
                    class="w-12 h-12 rounded-full bg-turquesa/10 text-turquesa flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
                      ></path></svg
                    >
                  </div>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800 mb-2">
                    Clases Sincrónicas en Vivo
                  </h4>
                  <p class="text-gray-600 text-sm">
                    Interactúa directamente con docentes y compañeros. Resuelve
                    dudas al instante y participa en discusiones enriquecedoras
                    en tiempo real.
                  </p>
                </div>
              </div>

              <div
                class="flex p-6 bg-white rounded-2xl border border-gray-100 hover:border-celeste/30 transition-all"
              >
                <div class="flex-shrink-0 mr-6">
                  <div
                    class="w-12 h-12 rounded-full bg-celeste/10 text-celeste flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                      ></path></svg
                    >
                  </div>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800 mb-2">
                    Campus Virtual 24/7
                  </h4>
                  <p class="text-gray-600 text-sm">
                    Accede a material de estudio, grabaciones de clases y
                    recursos complementarios en cualquier momento y desde
                    cualquier lugar.
                  </p>
                </div>
              </div>

              <div
                class="flex p-6 bg-white rounded-2xl border border-gray-100 hover:border-naranja/30 transition-all"
              >
                <div class="flex-shrink-0 mr-6">
                  <div
                    class="w-12 h-12 rounded-full bg-naranja/10 text-naranja flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                      ></path></svg
                    >
                  </div>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800 mb-2">
                    Prácticas Presenciales
                  </h4>
                  <p class="text-gray-600 text-sm">
                    Desarrolla habilidades prácticas esenciales mediante
                    role-playing y casos simulados bajo supervisión experta (en
                    programas seleccionados).
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="lg:w-1/2">
            <div
              class="bg-gradient-to-br from-celeste to-turquesa p-1 rounded-3xl transform rotate-2 hover:rotate-0 transition-transform duration-500 shadow-2xl"
            >
              <div
                class="bg-white rounded-[22px] overflow-hidden h-full shadow-xl"
              >
                <Image
                  src={fotoModalidad}
                  alt="Estudiantes en clase"
                  class="w-full h-full object-cover object-center scale-125"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Financing Section -->
    <section class="py-24 bg-crema">
      <div class="container mx-auto px-6">
        <div
          class="bg-gradient-to-r from-gray-900 to-blue-900 rounded-3xl shadow-2xl overflow-hidden relative"
        >
          <!-- Overlay pattern -->
          <div
            class="absolute inset-0 opacity-10"
            style="background-image: url('data:image/svg+xml,...');"
          >
          </div>

          <div
            class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 p-10 lg:p-16 items-center"
          >
            <div>
              <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
                Financiamiento y Becas
              </h2>
              <p class="text-blue-100 text-lg mb-8 leading-relaxed">
                Creemos que la formación de calidad debe ser accesible. Por eso,
                disponemos de diversas alternativas de financiamiento para
                apoyarte en tu desarrollo profesional.
              </p>

              <div class="space-y-4 mb-10">
                <div class="flex items-start">
                  <div class="flex-shrink-0 mt-1">
                    <svg
                      class="w-5 h-5 text-naranja"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      ><path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path></svg
                    >
                  </div>
                  <p class="ml-3 text-white">
                    Becas parciales por matrícula anticipada
                  </p>
                </div>
                <div class="flex items-start">
                  <div class="flex-shrink-0 mt-1">
                    <svg
                      class="w-5 h-5 text-naranja"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      ><path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path></svg
                    >
                  </div>
                  <p class="ml-3 text-white">
                    Facilidades de pago en cuotas sin interés (Tarjeta de
                    Crédito)
                  </p>
                </div>
                <div class="flex items-start">
                  <div class="flex-shrink-0 mt-1">
                    <svg
                      class="w-5 h-5 text-naranja"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      ><path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path></svg
                    >
                  </div>
                  <p class="ml-3 text-white">
                    Descuentos especiales para instituciones y grupos
                  </p>
                </div>
              </div>

              <a
                href="/contacto"
                class="inline-block px-8 py-3 bg-naranja text-white font-bold rounded-full hover:bg-amarillo hover:text-gray-900 transition-colors duration-300"
              >
                Consultar Financiamiento
              </a>
            </div>

            <div class="flex justify-center">
              <div class="bg-white p-8 rounded-2xl shadow-xl max-w-sm w-full">
                <div class="text-center mb-6">
                  <span
                    class="text-gray-500 font-semibold uppercase tracking-wider text-sm"
                    >Validado por</span
                  >
                </div>
                <img
                  src="/images/pages/nch2728.webp"
                  alt="Norma Chilena 2728"
                  class="h-20 object-contain mx-auto mb-4"
                />
                <p class="text-center text-sm text-gray-500 mt-4 px-4">
                  Organismo Técnico de Capacitación (OTEC) certificado bajo
                  norma NCh2728
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison Table Section -->
    <section class="py-20 lg:py-24 bg-crema">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold text-gray-800 mb-6">
            Comparativa de Programas
          </h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            Encuentra la modalidad perfecta para tu especialización. Todos
            nuestros programas diplomados incluyen certificación.
          </p>
        </div>

        <div
          class="max-w-5xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100"
        >
          <div class="overflow-x-auto">
            <table class="w-full min-w-[800px]">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="py-6 px-6 text-left font-bold text-gray-800 w-1/3"
                    >Programa</th
                  >
                  <th class="py-6 px-4 text-center font-bold text-gray-800">
                    <div class="flex flex-col items-center">
                      <span class="w-3 h-3 rounded-full bg-celeste mb-2"></span>
                      Asincrónico
                    </div>
                  </th>
                  <th class="py-6 px-4 text-center font-bold text-gray-800">
                    <div class="flex flex-col items-center">
                      <span class="w-3 h-3 rounded-full bg-turquesa mb-2"
                      ></span>
                      Sincrónico
                    </div>
                  </th>
                  <th class="py-6 px-4 text-center font-bold text-gray-800">
                    <div class="flex flex-col items-center">
                      <span class="w-3 h-3 rounded-full bg-naranja mb-2"></span>
                      Presencial
                    </div>
                  </th>
                  <th class="py-6 px-4 text-center font-bold text-gray-800"
                    >Tipo</th
                  >
                </tr>
              </thead>
              <tbody>
                {
                  programRows.map((program, index) => (
                    <tr
                      class={`border-b border-gray-100 hover:bg-celeste/5 transition-colors ${index % 2 === 0 ? "bg-white" : "bg-gray-50/50"}`}
                    >
                      <td class="py-5 px-6 font-semibold text-gray-800">
                        {program.program}
                      </td>

                      <td class="py-5 px-4 text-center">
                        {program.asincronica ? (
                          <div class="w-8 h-8 rounded-full bg-celeste/10 text-celeste mx-auto flex items-center justify-center">
                            <svg
                              class="w-5 h-5"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"
                              />
                            </svg>
                          </div>
                        ) : (
                          <span class="text-gray-300">-</span>
                        )}
                      </td>

                      <td class="py-5 px-4 text-center">
                        {program.sincronica ? (
                          <div class="w-8 h-8 rounded-full bg-turquesa/10 text-turquesa mx-auto flex items-center justify-center">
                            <svg
                              class="w-5 h-5"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"
                              />
                            </svg>
                          </div>
                        ) : (
                          <span class="text-gray-300">-</span>
                        )}
                      </td>

                      <td class="py-5 px-4 text-center">
                        {program.presencial ? (
                          <div class="w-8 h-8 rounded-full bg-naranja/10 text-naranja mx-auto flex items-center justify-center">
                            <svg
                              class="w-5 h-5"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"
                              />
                            </svg>
                          </div>
                        ) : (
                          <span class="text-gray-300">-</span>
                        )}
                      </td>

                      <td class="py-5 px-4 text-center">
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold text-gray-600 bg-gray-200">
                          {program.program.includes("Diplomado")
                            ? "Diplomado"
                            : "Curso"}
                        </span>
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
          <div
            class="bg-blue-50/50 p-4 border-t border-blue-100 flex items-start gap-3"
          >
            <svg
              class="w-5 h-5 text-blue-600 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path></svg
            >
            <p class="text-sm text-blue-800">
              <strong>Nota:</strong> El Diplomado de Mediación Familiar incluye una
              fase de pasantía presencial obligatoria por normativa del Ministerio
              de Justicia.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Final Contextual -->
    <CtaFinal pagina="admision" />
  </div>
</Layout>

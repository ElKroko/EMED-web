import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import TwoColumnBlock from '../components/sections/TwoColumnBlock.astro';
import Accordion from '../components/ui/Accordion.astro';

// Información de contacto
const contactInfo = {
  address: "Román Díaz 117, oficina 209\nProvidencia, Santiago, Chile",
  phone: "+569 6562 0939",
  whatsapp: "+569 6562 0939",
  email: "info@emed.cl",
  horarios: "Lunes a Viernes: 9:00 - 18:00"
};

// FAQ rápidas para lead qualification
const faqs = [
  {
    question: "¿Ofrecen modalidad online?",
    answer: "Sí. Trabajamos en formatos sincrónico, asincrónico y presencial, para adaptarnos a tu disponibilidad."
  },
  {
    question: "¿Tienen financiamiento?",
    answer: "Sí. Contamos con opciones de financiamiento empresarial para programas de mediación laboral y escolar. Además, ofrecemos pagos en cuotas y descuentos por tarjeta de crédito o pago al contado."
  },
  {
    question: "¿Los programas están acreditados?",
    answer: "Sí. Contamos con certificación NCh2728, que garantiza la calidad de nuestros procesos educativos. Además, el Diplomado en Mediación Familiar posee certificación de IPCHILE (institución de educación superior reconocida por el Estado), en línea con la circular vigente del Ministerio de Justicia."
  }
];
---

<Layout 
  title="Contacto - EMED | Habla con un Asesor Académico"
  description="Contáctanos para resolver tus dudas sobre nuestros programas de mediación. Asesores académicos especializados te guiarán en tu proceso de inscripción."
>
  <div class="bg-crema min-h-screen">

  <!-- Hero Section con SVG celeste -->
  <section class="hero-contacto relative overflow-hidden py-24">
    <!-- SVG de fondo celeste -->
    <div class="absolute inset-0">
      <svg viewBox="0 0 1200 800" class="w-full h-full" preserveAspectRatio="none">
        <path d="M0,0 L1200,0 L1200,650 C1000,620 800,660 600,640 C400,620 200,660 0,650 Z" fill="#7EC5D6"/>
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="text-center text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Hablemos sobre tu futuro
        </h1>
        <p class="text-xl md:text-2xl mb-8 max-w-3xl mx-auto leading-relaxed">
          Nuestros asesores académicos están listos para guiarte en tu carrera como mediador profesional
        </p>

        <!-- CTAs rápidos -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/56912345678?text=Hola,%20quiero%20información%20sobre%20los%20programas%20de%20EMED"
            target="_blank"
            class="inline-flex items-center px-6 py-3 md:px-8 md:py-4 bg-green-500 text-white font-bold text-base md:text-lg rounded-xl hover:bg-green-600 transform hover:scale-105 transition-all duration-200 shadow-xl"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            WhatsApp Inmediato
          </a>

          <a
            href="tel:+56223456789"
            class="inline-flex items-center px-6 py-3 md:px-8 md:py-4 bg-white/20 backdrop-blur-sm text-white font-bold text-base md:text-lg rounded-xl hover:bg-white/30 transition-all duration-200 border border-white/30"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Llamar Ahora
          </a>
        </div>
      </div>
    </div>

    <!-- Forma orgánica inferior -->
    <div class="absolute bottom-0 left-0 right-0 h-24">
      <svg viewBox="0 0 1200 120" class="w-full h-full" preserveAspectRatio="none">
        <path d="M0,120 C300,80 500,60 600,80 C700,100 900,60 1200,80 L1200,120 Z" fill="#FEF3E2"/>
      </svg>
    </div>
  </section>

  <!-- Sección principal: Formulario + Información -->
  <section class="py-16 bg-transparent">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Formulario principal (2/3) -->
        <div class="lg:col-span-2">
          <ContactForm
            type="general"
            title="¿Tienes dudas?"
            subtitle="Si nos escribes en horario hábil, te respondemos dentro de 2 horas; fuera de ese horario, a más tardar al día hábil siguiente."
            showUrgency={false}
          />
        </div>

        <!-- Información de Contacto (1/3) -->
        <div class="lg:col-span-1 space-y-6">

          <!-- Información principal -->
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-200">
            <h3 class="text-2xl font-bold text-gray-800 mb-6">Información de Contacto</h3>

            <div class="space-y-4">
              <!-- Teléfono -->
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-celeste mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <div>
                  <p class="font-semibold text-gray-900">Teléfono</p>
                  <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="text-celeste hover:text-turquesa transition-colors">
                    {contactInfo.phone}
                  </a>
                </div>
              </div>

              <!-- WhatsApp -->
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-celeste mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
                <div>
                  <p class="font-semibold text-gray-900">WhatsApp</p>
                  <a href={`https://wa.me/${contactInfo.whatsapp.replace(/[\s+]/g, '')}`} target="_blank" class="text-celeste hover:text-turquesa transition-colors">
                    {contactInfo.whatsapp}
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-celeste mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <p class="font-semibold text-gray-900">Email</p>
                  <a href={`mailto:${contactInfo.email}`} class="text-celeste hover:text-turquesa transition-colors">
                    {contactInfo.email}
                  </a>
                </div>
              </div>

              <!-- Horarios -->
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-celeste mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="font-semibold text-gray-900">Horarios de atención</p>
                  <p class="text-gray-700 text-sm leading-relaxed" set:html={contactInfo.horarios.replace('\n', '<br>')}></p>
                </div>
              </div>

              <!-- Dirección -->
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-celeste mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="font-semibold text-gray-900">Dirección</p>
                  <p class="text-gray-700 text-sm leading-relaxed" set:html={contactInfo.address.replace('\n', '<br>')}></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Nota sobre atención presencial -->
          <div class="bg-celeste/10 border-l-4 border-celeste rounded-lg p-4">
            <div class="flex items-start space-x-3">
              <svg class="w-5 h-5 text-celeste mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <p class="text-gray-700 text-sm leading-relaxed">
                <strong class="text-gray-800">Atención presencial:</strong> Disponible con cita previa agendada por WhatsApp o teléfono.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-transparent">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
          Preguntas Frecuentes
        </h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">
          Resuelve tus dudas más comunes antes de contactarnos
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        <Accordion items={faqs.map(f => ({ title: f.question, content: f.answer }))} />
      </div>

      <div class="text-center mt-12">
        <p class="text-gray-800 text-lg mb-4 font-medium">¿No encuentras la respuesta que buscas?</p>
        <a
          href="#contact-form"
          class="inline-flex items-center px-6 py-3 bg-celeste text-white font-bold rounded-lg hover:bg-turquesa transition-colors duration-200 shadow-md hover:shadow-lg"
        >
          Hacer una consulta específica
        </a>
      </div>
    </div>
  </section>

  <!-- Ubicación -->
  <section class="py-16 bg-transparent">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
          Nuestra Ubicación
        </h2>
        <p class="text-gray-600 text-lg">
          Visítanos en nuestras oficinas en el corazón de Santiago
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Google Maps -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-200">
          <div class="h-96 w-full">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3329.8!2d-70.615!3d-33.424!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzPCsDI1JzI2LjQiUyA3MMKwMzYnNTQuMCJX!5e0!3m2!1ses!2scl!4v1234567890123!5m2!1ses!2scl"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación EMED - Román Díaz 117, oficina 209">
            </iframe>
          </div>
        </div>

        <!-- Información de ubicación -->
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Cómo llegar</h3>

          <div class="space-y-6">
            <div class="bg-white rounded-lg p-4 border border-gray-200">
              <h4 class="font-bold text-gray-900 mb-2 text-lg">🚇 Metro</h4>
              <p class="text-gray-700">Estación Manuel Montt (Línea 1) - 5 minutos caminando</p>
            </div>

            <div class="bg-white rounded-lg p-4 border border-gray-200">
              <h4 class="font-bold text-gray-900 mb-2 text-lg">🚌 Bus</h4>
              <p class="text-gray-700">Múltiples recorridos por Av. Providencia</p>
            </div>

            <div class="bg-white rounded-lg p-4 border border-gray-200">
              <h4 class="font-bold text-gray-900 mb-2 text-lg">🚗 Auto</h4>
              <p class="text-gray-700">Estacionamientos disponibles en el edificio</p>
            </div>
          </div>

          <div class="mt-8">
            <a
              href="https://www.google.com/maps/search/Román+Díaz+117,+oficina+209,+Providencia,+Santiago"
              target="_blank"
              class="inline-flex items-center px-6 py-3 bg-naranja text-white font-semibold rounded-lg hover:bg-amarillo transition-colors duration-200"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  </div>
</Layout>

<script>
  // Funcionalidad del acordeón de FAQs (Manejado por componente)
</script>

<style>
  /* Forzar colores correctos en todos los botones */
  a[class*="bg-"],
  button[class*="bg-"] {
    color: white !important;
    text-decoration: none !important;
  }

  a[class*="bg-"]:hover,
  button[class*="bg-"]:hover {
    color: white !important;
    text-decoration: none !important;
  }

  /* Animación suave para el scroll */
  html {
    scroll-behavior: smooth;
  }

  /* Animación para el acordeón */
  .faq-answer {
    transition: all 0.3s ease-in-out;
  }

  .faq-icon {
    transition: transform 0.3s ease-in-out;
  }
</style>
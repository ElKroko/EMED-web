---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/forms/ContactForm.astro";
import TwoColumnBlock from "../components/sections/TwoColumnBlock.astro";
// Accordion replaced with inline implementation

// Información de contacto
const contactInfo = {
  address: "Román Díaz 117, oficina 209\nProvidencia, Santiago, Chile",
  phone: "+569 6562 0939",
  whatsapp: "+569 6562 0939",
  email: "info@emediacion.cl",
  horarios: "Lunes a Viernes: 9:00 - 18:00",
};
---

<Layout
  title="Contacto - EMED | Habla con un Asesor Académico"
  description="Contáctanos para resolver tus dudas sobre nuestros programas de mediación. Asesores académicos especializados te guiarán en tu proceso de inscripción."
>
  <div class="bg-crema min-h-screen">
    <!-- Hero Section Simple -->
    <section class="bg-celeste relative overflow-hidden py-24">
      <div class="container mx-auto px-4 relative z-10">
        <div class="text-center text-white">
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight"
          >
            Hablemos sobre
            <span class="relative inline-block">
              tu futuro
              <svg
                class="absolute w-full h-[0.5em] -bottom-2 left-0 text-amarillo"
                viewBox="0 0 200 9"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M2.00025 6.99997C25.0003 2.99999 74.5002 -2.00002 198.001 2.50001"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"></path>
              </svg>
            </span>
          </h1>
          <p class="text-xl md:text-2xl mb-8 max-w-3xl mx-auto leading-relaxed">
            Nuestros asesores académicos están listos para guiarte en tu carrera
            como mediador profesional
          </p>

          <!-- CTAs rápidos -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="https://wa.me/56965620939?text=Hola,%20quiero%20información%20sobre%20los%20programas%20de%20EMED"
              target="_blank"
              class="inline-flex items-center px-6 py-3 md:px-8 md:py-4 bg-green-500 text-white font-bold text-base md:text-lg rounded-xl hover:bg-green-600 transform hover:scale-105 transition-all duration-200 shadow-xl"
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path>
              </svg>
              WhatsApp Inmediato
            </a>

            <a
              href="tel:+56223456789"
              class="inline-flex items-center px-6 py-3 md:px-8 md:py-4 bg-white/20 backdrop-blur-sm text-white font-bold text-base md:text-lg rounded-xl hover:bg-white/30 transition-all duration-200 border border-white/30"
            >
              <svg
                class="w-5 h-5 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              Llamar Ahora
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección principal: Formulario + Información -->
    <section class="py-16 bg-transparent">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
          <!-- Formulario principal (2/3) -->
          <div class="lg:col-span-2">
            <ContactForm
              type="general"
              title="¿Tienes dudas?"
              subtitle="Si nos escribes en horario hábil, te respondemos dentro de 2 horas; fuera de ese horario, a más tardar al día hábil siguiente."
              showUrgency={false}
            />
          </div>

          <!-- Información de Contacto (1/3) -->
          <div class="lg:col-span-1 space-y-6">
            <!-- Información principal -->
            <div
              class="bg-white rounded-2xl shadow-lg p-6 border border-gray-200"
            >
              <h3 class="text-2xl font-bold text-gray-800 mb-6">
                Información de Contacto
              </h3>

              <div class="space-y-4">
                <!-- Teléfono -->
                <div class="flex items-start space-x-3">
                  <svg
                    class="w-5 h-5 text-celeste mt-1 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path>
                  </svg>
                  <div>
                    <p class="font-semibold text-gray-900">Teléfono</p>
                    <a
                      href={`tel:${contactInfo.phone.replace(/\s/g, "")}`}
                      class="text-celeste hover:text-turquesa transition-colors"
                    >
                      {contactInfo.phone}
                    </a>
                  </div>
                </div>

                <!-- WhatsApp -->
                <div class="flex items-start space-x-3">
                  <svg
                    class="w-5 h-5 text-celeste mt-1 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                    ></path>
                  </svg>
                  <div>
                    <p class="font-semibold text-gray-900">WhatsApp</p>
                    <a
                      href={`https://wa.me/${contactInfo.whatsapp.replace(/[\s+]/g, "")}`}
                      target="_blank"
                      class="text-celeste hover:text-turquesa transition-colors"
                    >
                      {contactInfo.whatsapp}
                    </a>
                  </div>
                </div>

                <!-- Email -->
                <div class="flex items-start space-x-3">
                  <svg
                    class="w-5 h-5 text-celeste mt-1 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                  <div>
                    <p class="font-semibold text-gray-900">Email</p>
                    <a
                      href={`mailto:${contactInfo.email}`}
                      class="text-celeste hover:text-turquesa transition-colors"
                    >
                      {contactInfo.email}
                    </a>
                  </div>
                </div>

                <!-- Horarios -->
                <div class="flex items-start space-x-3">
                  <svg
                    class="w-5 h-5 text-celeste mt-1 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <div>
                    <p class="font-semibold text-gray-900">
                      Horarios de atención
                    </p>
                    <p class="text-gray-700 text-sm leading-relaxed">
                      {contactInfo.horarios}
                    </p>
                  </div>
                </div>

                <!-- Dirección -->
                <div class="flex items-start space-x-3">
                  <svg
                    class="w-5 h-5 text-celeste mt-1 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <div>
                    <p class="font-semibold text-gray-900">Dirección</p>
                    <p
                      class="text-gray-700 text-sm leading-relaxed whitespace-pre-line"
                    >
                      {contactInfo.address}
                    </p>
                  </div>
                </div>

                <!-- Atención Presencial -->
                <div
                  class="flex items-start space-x-3 pt-4 border-t border-gray-100"
                >
                  <svg
                    class="w-5 h-5 text-celeste mt-1 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                    ></path>
                  </svg>
                  <div>
                    <p class="font-semibold text-gray-900">
                      Atención Presencial
                    </p>
                    <p class="text-gray-700 text-sm leading-relaxed">
                      Disponible con cita previa agendada por WhatsApp o
                      teléfono.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-16 bg-transparent">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
            Preguntas Frecuentes
          </h2>
          <p class="text-gray-600 text-lg max-w-2xl mx-auto">
            Resuelve tus dudas más comunes antes de contactarnos
          </p>
        </div>

        <div class="max-w-3xl mx-auto space-y-4">
          <!-- QA Item 1 -->
          <details
            class="group bg-white rounded-xl shadow-sm border border-gray-100 open:ring-2 open:ring-celeste/20 open:shadow-md transition-all duration-300"
            open
          >
            <summary
              class="flex justify-between items-center w-full p-6 text-left cursor-pointer list-none focus:outline-none"
            >
              <span
                class="text-lg font-bold text-gray-800 group-open:text-celeste transition-colors"
                >¿Ofrecen modalidad online?</span
              >
              <span
                class="text-celeste group-open:rotate-180 transition-transform duration-300"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </span>
            </summary>
            <div
              class="px-6 pb-6 pt-0 text-gray-600 leading-relaxed border-t border-transparent group-open:border-gray-50"
            >
              Sí. Trabajamos en formatos sincrónico, asincrónico y presencial,
              para adaptarnos a tu disponibilidad y preferencias de aprendizaje.
            </div>
          </details>

          <!-- QA Item 2 -->
          <details
            class="group bg-white rounded-xl shadow-sm border border-gray-100 open:ring-2 open:ring-celeste/20 open:shadow-md transition-all duration-300"
          >
            <summary
              class="flex justify-between items-center w-full p-6 text-left cursor-pointer list-none focus:outline-none"
            >
              <span
                class="text-lg font-bold text-gray-800 group-open:text-celeste transition-colors"
                >¿Tienen financiamiento?</span
              >
              <span
                class="text-celeste group-open:rotate-180 transition-transform duration-300"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </span>
            </summary>
            <div
              class="px-6 pb-6 pt-0 text-gray-600 leading-relaxed border-t border-transparent group-open:border-gray-50"
            >
              Sí. Contamos con opciones de financiamiento empresarial para
              programas de mediación laboral y escolar. Además, ofrecemos
              facilidades de pago en cuotas y descuentos preferenciales por pago
              al contado o tarjeta de crédito.
            </div>
          </details>

          <!-- QA Item 3 -->
          <details
            class="group bg-white rounded-xl shadow-sm border border-gray-100 open:ring-2 open:ring-celeste/20 open:shadow-md transition-all duration-300"
          >
            <summary
              class="flex justify-between items-center w-full p-6 text-left cursor-pointer list-none focus:outline-none"
            >
              <span
                class="text-lg font-bold text-gray-800 group-open:text-celeste transition-colors"
                >¿Los programas están acreditados?</span
              >
              <span
                class="text-celeste group-open:rotate-180 transition-transform duration-300"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </span>
            </summary>
            <div
              class="px-6 pb-6 pt-0 text-gray-600 leading-relaxed border-t border-transparent group-open:border-gray-50"
            >
              Absolutamente. Contamos con certificación NCh2728, lo que
              garantiza la calidad de nuestros procesos. El Diplomado en
              Mediación Familiar cuenta además con la certificación de IPCHILE
              (institución reconocida por el Estado), cumpliendo con todas las
              normativas del Ministerio de Justicia.
            </div>
          </details>

          <!-- QA Item 4 -->
          <details
            class="group bg-white rounded-xl shadow-sm border border-gray-100 open:ring-2 open:ring-celeste/20 open:shadow-md transition-all duration-300"
          >
            <summary
              class="flex justify-between items-center w-full p-6 text-left cursor-pointer list-none focus:outline-none"
            >
              <span
                class="text-lg font-bold text-gray-800 group-open:text-celeste transition-colors"
                >¿Entregan certificado al finalizar?</span
              >
              <span
                class="text-celeste group-open:rotate-180 transition-transform duration-300"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </span>
            </summary>
            <div
              class="px-6 pb-6 pt-0 text-gray-600 leading-relaxed border-t border-transparent group-open:border-gray-50"
            >
              Sí, todos nuestros programas diplomados incluyen un certificado
              oficial digital que acredita las horas cursadas, la aprobación de
              los módulos y las competencias adquiridas durante el programa.
            </div>
          </details>

          <!-- QA Item 5 -->
          <details
            class="group bg-white rounded-xl shadow-sm border border-gray-100 open:ring-2 open:ring-celeste/20 open:shadow-md transition-all duration-300"
          >
            <summary
              class="flex justify-between items-center w-full p-6 text-left cursor-pointer list-none focus:outline-none"
            >
              <span
                class="text-lg font-bold text-gray-800 group-open:text-celeste transition-colors"
                >¿Cuál es la duración de los diplomados?</span
              >
              <span
                class="text-celeste group-open:rotate-180 transition-transform duration-300"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </span>
            </summary>
            <div
              class="px-6 pb-6 pt-0 text-gray-600 leading-relaxed border-t border-transparent group-open:border-gray-50"
            >
              La duración varía según el programa específico, oscilando
              generalmente entre las 120 y 220 horas cronológicas (incluyendo
              horas de trabajo autónomo y prácticas cuando corresponde). Revisa
              la ficha de cada diplomado para el detalle exacto.
            </div>
          </details>

          <!-- QA Item 6 -->
          <details
            class="group bg-white rounded-xl shadow-sm border border-gray-100 open:ring-2 open:ring-celeste/20 open:shadow-md transition-all duration-300"
          >
            <summary
              class="flex justify-between items-center w-full p-6 text-left cursor-pointer list-none focus:outline-none"
            >
              <span
                class="text-lg font-bold text-gray-800 group-open:text-celeste transition-colors"
                >¿Cuándo inician las clases?</span
              >
              <span
                class="text-celeste group-open:rotate-180 transition-transform duration-300"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </span>
            </summary>
            <div
              class="px-6 pb-6 pt-0 text-gray-600 leading-relaxed border-t border-transparent group-open:border-gray-50"
            >
              Tenemos fechas de inicio flexibles a lo largo de todo el año para
              nuestros distintos programas. Te recomendamos contactar a un
              asesor para conocer la próxima fecha disponible para el programa
              de tu interés.
            </div>
          </details>

          <!-- QA Item 7 -->
          <details
            class="group bg-white rounded-xl shadow-sm border border-gray-100 open:ring-2 open:ring-celeste/20 open:shadow-md transition-all duration-300"
          >
            <summary
              class="flex justify-between items-center w-full p-6 text-left cursor-pointer list-none focus:outline-none"
            >
              <span
                class="text-lg font-bold text-gray-800 group-open:text-celeste transition-colors"
                >¿Necesito conocimientos previos?</span
              >
              <span
                class="text-celeste group-open:rotate-180 transition-transform duration-300"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </span>
            </summary>
            <div
              class="px-6 pb-6 pt-0 text-gray-600 leading-relaxed border-t border-transparent group-open:border-gray-50"
            >
              Para la mayoría de nuestros diplomados se requiere contar con un
              título técnico de nivel superior o profesional. Sin embargo,
              algunos cursos libres están abiertos a todo público. Revisa los
              requisitos específicos en la página de cada oferta académica.
            </div>
          </details>
        </div>

        <div class="text-center mt-12">
          <p class="text-gray-800 text-lg mb-4 font-medium">
            ¿No encuentras la respuesta que buscas?
          </p>
          <a
            href="#contact-form"
            class="inline-flex items-center px-6 py-3 bg-celeste text-white font-bold rounded-lg hover:bg-turquesa transition-colors duration-200 shadow-md hover:shadow-lg"
          >
            Hacer una consulta específica
          </a>
        </div>
      </div>
    </section>

    <!-- Ubicación -->
    <section class="py-16 bg-transparent">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="text-center mb-12">

---
import Layout from "../layouts/Layout.astro";
import CtaFinal from "../components/sections/CtaFinal.astro";
import { Image } from "astro:assets";
import quienesSomosBanner from "../assets/images/pages/quienes-somos-banner.webp";

// Iconos de valores
import IconoExcelencia from "../assets/images/common/iconos/Excelencia.svg";
import IconoEtica from "../assets/images/common/iconos/Etica.svg";
import IconoCompromiso from "../assets/images/common/iconos/Compromiso.svg";
import IconoTransformacion from "../assets/images/common/iconos/Transformación.svg";

// Fotos Docentes
import imgClaudiaTassara from "../assets/images/docentes/claudia-tassara.webp";
import imgJuanPabloLetelier from "../assets/images/docentes/juan-pablo-letelier.webp";
import imgMariaNataliaCastro from "../assets/images/docentes/maria-natalia-castro.webp";
import imgDanielCarreno from "../assets/images/docentes/daniel-carreno.webp";
import imgConstanzaNavarrete from "../assets/images/docentes/constanza-navarrete.webp";
import imgWalterOyarzo from "../assets/images/docentes/walter-oyarzo.webp";
import imgNathalieNoechwicz from "../assets/images/docentes/nathalie-noechwicz.webp";
import imgJavierVidargas from "../assets/images/docentes/javier-vidargas.webp";
import imgCarlaGuardia from "../assets/images/docentes/carla-guardia.webp";
import imgCeciliaRamosMejia from "../assets/images/docentes/cecilia-ramos-mejia.webp";
import imgDanielBustelo from "../assets/images/docentes/daniel-bustelo.webp";
import imgCamilaPalacios from "../assets/images/docentes/camila-palacios.webp";
import imgVicentePerelli from "../assets/images/docentes/vicente-perelli.webp";
import imgAnnLizetteMurua from "../assets/images/docentes/ann-lizette-murua.webp";

// Equipo EMED (Directivo/Administrativo)
const equipoEMED = [
  {
    nombre: "Claudia Tassara",
    cargo: "Directora Académica",
    initials: "CT",
    color: "turquesa",
    imagen: imgClaudiaTassara,
  },

  {
    nombre: "Vicente Perelli",
    cargo: "Estratega Digital",
    initials: "VP",
    color: "celeste",
    imagen: imgVicentePerelli,
  },
  {
    nombre: "Camila Palacios",
    cargo: "Coordinación Académica",
    initials: "CP",
    color: "naranja",
    imagen: imgCamilaPalacios,
  },
  {
    nombre: "Ann Lizette Murúa",
    cargo: "Orientadora Académica",
    initials: "AM",
    color: "amarillo",
    imagen: imgAnnLizetteMurua,
    imgStyle: "object-position: center 30%",
  },
];

// Docentes Nacionales
const docentesNacionales = [
  {
    nombre: "Juan Pablo Letelier",
    profesion: "Trabajador Social",
    descripcion: "Mediador Familiar, Escolar y Laboral.",
    initials: "JL",
    color: "naranja",
    imagen: imgJuanPabloLetelier,
  },
  {
    nombre: "Claudia Tassara",
    profesion: "Abogada",
    descripcion: "Mediadora Familiar, Escolar y Laboral.",
    initials: "CT",
    color: "turquesa",
    imagen: imgClaudiaTassara,
  },
  {
    nombre: "María Natalia Castro",
    profesion: "Psicóloga",
    descripcion: "Mediadora Familiar y Escolar.",
    initials: "MC",
    color: "celeste",
    imagen: imgMariaNataliaCastro,
  },
  {
    nombre: "Daniel Carreño (Miccael Sais)",
    profesion: "Terapeuta",
    descripcion: "Mediador Escolar y Laboral.",
    initials: "DC",
    color: "celeste",
    imagen: imgDanielCarreno,
  },
  {
    nombre: "Constanza Navarrete",
    profesion: "Abogada",
    descripcion: "Mediadora Familiar.",
    initials: "CN",
    color: "turquesa",
    imagen: imgConstanzaNavarrete,
  },
  {
    nombre: "Walter Oyarzo",
    profesion: "Abogado",
    descripcion: "Mediador Laboral.",
    initials: "WO",
    color: "purple-600",
    imagen: imgWalterOyarzo,
  },
];

// Docentes Internacionales
const docentesInternacionales = [
  {
    nombre: "Nathalie Noechwicz",
    profesion: "Mediadora",
    descripcion: "Mediadora experta en mediación restaurativa",
    initials: "NN",
    color: "celeste",
    imagen: imgNathalieNoechwicz,
  },
  {
    nombre: "Javier Vidargas",
    profesion: "Mediador",
    descripcion: "Mediador experto en mediación penal",
    initials: "JV",
    color: "naranja",
    imagen: imgJavierVidargas,
  },
  {
    nombre: "Carla Guardia",
    profesion: "Mediadora",
    descripcion: "Mediadora experta en comunidades LGBTIQ+",
    initials: "CG",
    color: "turquesa",
    imagen: imgCarlaGuardia,
  },
  {
    nombre: "Cecilia Ramos Mejía",
    profesion: "Mediadora",
    descripcion: "Mediadora experta en mediación escolar",
    initials: "CR",
    color: "purple-600",
    imagen: imgCeciliaRamosMejia,
  },
  {
    nombre: "Daniel Bustelo",
    profesion: "Mediador",
    descripcion: "Mediador y Creador de la escuela de la función mediadora",
    initials: "DB",
    color: "naranja",
    imagen: imgDanielBustelo,
  },
];
---

<Layout
  title="Nosotros - EMED | Quienes Somos"
  description="Conoce nuestro equipo de profesionales especializados en mediación, nuestra misión, visión y docentes nacionales e internacionales."
>
  <div class="bg-crema min-h-screen">
    <!-- Hero: Quienes Somos -->
    <section class="hero-nosotros relative overflow-hidden py-24 bg-celeste">
      <div class="container mx-auto px-4 relative z-10">
        <div
          class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto"
        >
          <!-- Contenido de texto -->
          <div class="text-white">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8 leading-tight"
            >
              Quienes Somos
            </h1>

            <div class="space-y-6 text-lg md:text-xl leading-relaxed">
              <p>
                Somos EMED – Centro de Estudios de Mediación, una institución
                pionera con más de 20 años de trayectoria formando mediadores en
                Chile.
              </p>

              <p>
                Nos dedicamos a transformar la sociedad a través del diálogo,
                capacitando profesionales con herramientas prácticas para la
                gestión constructiva de conflictos en los ámbitos familiar,
                escolar y laboral.
              </p>

              <div
                class="flex items-center gap-4 p-4 bg-white/10 rounded-lg backdrop-blur-sm border border-white/20"
              >
                <span class="text-4xl">🎓</span>
                <div>
                  <p class="font-bold text-lg">Certificación Académica</p>
                  <p class="text-sm opacity-90">
                    Nuestros diplomados cuentan con certificación del Instituto
                    Profesional de Chile (IPCHILE).
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Imagen del equipo -->
          <div class="relative">
            <div
              class="bg-white rounded-2xl p-4 shadow-2xl transform -rotate-2 hover:rotate-0 transition-transform duration-300"
            >
              <Image
                src={quienesSomosBanner}
                alt="Equipo EMED"
                class="w-full h-64 md:h-80 object-cover rounded-xl"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección Unificada: Nuestro Propósito y Valores -->
    <section class="proposito-section relative bg-crema py-16 overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Header con título y propósito -->
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
              Nuestro Propósito
            </h2>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
              Promover una cultura de <strong class="text-turquesa"
                >paz y diálogo</strong
              >, entregando formación de excelencia que habilite a las personas
              para ser <strong class="text-naranja">agentes de cambio</strong> en
              sus comunidades.
            </p>
          </div>

          <!-- Grid principal: 3 columnas en desktop -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Columna 1: Nuestra Misión -->
            <div
              class="proposito-card group relative bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 overflow-hidden"
            >
              <div
                class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-celeste to-turquesa"
              >
              </div>

              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-lg bg-celeste/10 flex items-center justify-center group-hover:scale-110 transition-transform"
                >
                  <svg
                    class="w-5 h-5 text-celeste"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-gray-800">Nuestra Misión</h3>
              </div>

              <p class="text-gray-600 text-sm leading-relaxed mb-4">
                Formar mediadores de excelencia, éticos y comprometidos,
                entregando herramientas teóricas y prácticas para facilitar
                procesos de diálogo y construcción de acuerdos sostenibles.
              </p>

              <div
                class="flex items-center gap-2 text-xs text-celeste font-medium"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                <span>Transformamos conflictos en oportunidades</span>
              </div>
            </div>

            <!-- Columna 2: Nuestra Visión -->
            <div
              class="proposito-card group relative bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 overflow-hidden"
            >
              <div
                class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-naranja to-amarillo"
              >
              </div>

              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-lg bg-naranja/10 flex items-center justify-center group-hover:scale-110 transition-transform"
                >
                  <svg
                    class="w-5 h-5 text-naranja"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                    ></path>
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-gray-800">Nuestra Visión</h3>
              </div>

              <p class="text-gray-600 text-sm leading-relaxed mb-4">
                Ser la institución líder en formación de mediadores en Chile y
                Latinoamérica, impulsando la profesionalización de la mediación
                como vía para la resolución pacífica de conflictos.
              </p>

              <div
                class="flex items-center gap-2 text-xs text-naranja font-medium"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                <span>Expandiendo la cultura de paz</span>
              </div>
            </div>

            <!-- Columna 3: Lo Que Nos Diferencia -->
            <div
              class="proposito-card group relative bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 overflow-hidden"
            >
              <div
                class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-turquesa to-celeste"
              >
              </div>

              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-lg bg-turquesa/10 flex items-center justify-center group-hover:scale-110 transition-transform"
                >
                  <svg
                    class="w-5 h-5 text-turquesa"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                    ></path>
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-gray-800">
                  Lo Que Nos Diferencia
                </h3>
              </div>

              <!-- Mini badges de diferenciadores -->
              <div class="space-y-2">
                <div
                  class="flex items-center gap-2 p-2 bg-celeste/5 rounded-lg"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-celeste"></span>
                  <span class="text-sm text-gray-700"
                    ><strong class="text-celeste">Formación práctica</strong> con
                    casos reales</span
                  >
                </div>
                <div
                  class="flex items-center gap-2 p-2 bg-turquesa/5 rounded-lg"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-turquesa"></span>
                  <span class="text-sm text-gray-700"
                    ><strong class="text-turquesa">Acompañamiento</strong> personalizado</span
                  >
                </div>
                <div
                  class="flex items-center gap-2 p-2 bg-naranja/5 rounded-lg"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-naranja"></span>
                  <span class="text-sm text-gray-700"
                    ><strong class="text-naranja">Certificación IRAM</strong> reconocida</span
                  >
                </div>
              </div>
            </div>
          </div>

          <!-- Nuestros Valores con iconos -->
          <div class="mt-12 pt-8 border-t border-gray-200/50">
            <p class="text-center text-sm text-gray-400 font-medium mb-8">
              Nuestros valores
            </p>
            <div
              class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto"
            >
              <!-- Excelencia -->
              <div class="flex flex-col items-center gap-3 group">
                <div
                  class="w-20 h-20 flex items-center justify-center rounded-2xl bg-celeste/10 group-hover:bg-celeste/20 transition-colors"
                >
                  <Image
                    src={IconoExcelencia}
                    alt="Excelencia"
                    class="w-12 h-12"
                  />
                </div>
                <span class="text-base font-semibold text-gray-700"
                  >Excelencia</span
                >
              </div>
              <!-- Ética -->
              <div class="flex flex-col items-center gap-3 group">
                <div
                  class="w-20 h-20 flex items-center justify-center rounded-2xl bg-turquesa/10 group-hover:bg-turquesa/20 transition-colors"
                >
                  <Image src={IconoEtica} alt="Ética" class="w-12 h-12" />
                </div>
                <span class="text-base font-semibold text-gray-700">Ética</span>
              </div>
              <!-- Compromiso -->
              <div class="flex flex-col items-center gap-3 group">
                <div
                  class="w-20 h-20 flex items-center justify-center rounded-2xl bg-naranja/10 group-hover:bg-naranja/20 transition-colors"
                >
                  <Image
                    src={IconoCompromiso}
                    alt="Compromiso"
                    class="w-12 h-12"
                  />
                </div>
                <span class="text-base font-semibold text-gray-700"
                  >Compromiso</span
                >
              </div>
              <!-- Transformación -->
              <div class="flex flex-col items-center gap-3 group">
                <div
                  class="w-20 h-20 flex items-center justify-center rounded-2xl bg-amarillo/10 group-hover:bg-amarillo/20 transition-colors"
                >
                  <Image
                    src={IconoTransformacion}
                    alt="Transformación"
                    class="w-12 h-12"
                  />
                </div>
                <span class="text-base font-semibold text-gray-700"
                  >Transformación</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección: Nuestro Equipo -->
    <section class="equipos-section relative py-20 bg-crema">
      <div class="container mx-auto px-4">
        <!-- Título principal -->
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-6">
            Nuestro Equipo Profesional
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Profesionales especializados con amplia experiencia en mediación y
            formación académica de excelencia
          </p>
        </div>

        <!-- Equipo EMED (Directivo) -->
        <div class="mb-20">
          <div class="flex items-center justify-center mb-12">
            <div class="w-16 h-1 bg-celeste"></div>
            <h3 class="text-2xl md:text-3xl font-bold text-celeste mx-6">
              Equipo EMED
            </h3>
            <div class="w-16 h-1 bg-celeste"></div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
            {
              equipoEMED.map((miembro) => (
                <div class="team-card bg-white border border-gray-100 rounded-2xl p-5 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group text-center">
                  <div
                    class={`w-20 h-20 mx-auto mb-3 rounded-full flex items-center justify-center text-2xl font-bold bg-gradient-to-br from-${miembro.color}/20 to-${miembro.color}/10 shadow-md group-hover:shadow-lg transition-all duration-300 text-${miembro.color} border-2 border-${miembro.color}/30 overflow-hidden`}
                  >
                    {miembro.imagen ? (
                      <Image
                        src={miembro.imagen}
                        alt={miembro.nombre}
                        class="w-full h-full object-cover"
                        style={miembro.imgStyle || ""}
                      />
                    ) : (
                      miembro.initials
                    )}
                  </div>

                  <h4 class="text-sm font-bold text-gray-800 mb-1">
                    {miembro.nombre}
                  </h4>
                  <p class={`text-xs font-medium text-${miembro.color}`}>
                    {miembro.cargo}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Docentes Nacionales -->
        <div class="mb-20">
          <div class="flex items-center justify-center mb-12">
            <div class="w-16 h-1 bg-turquesa"></div>
            <h3 class="text-2xl md:text-3xl font-bold text-turquesa mx-6">
              Docentes Nacionales
            </h3>
            <div class="w-16 h-1 bg-turquesa"></div>
          </div>

          <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto"
          >
            {
              docentesNacionales.map((docente) => (
                <div class="team-card bg-white border border-gray-100 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group">
                  <div class="text-center">
                    <div
                      class={`w-24 h-24 mx-auto mb-4 rounded-full flex items-center justify-center text-3xl font-bold bg-gray-50 shadow-md group-hover:shadow-lg transition-all duration-300 text-${docente.color} overflow-hidden`}
                    >
                      {docente.imagen ? (
                        <Image
                          src={docente.imagen}
                          alt={docente.nombre}
                          class="w-full h-full object-cover"
                        />
                      ) : (
                        docente.initials
                      )}
                    </div>

                    <h4 class="text-base font-bold text-gray-800 mb-1">
                      {docente.nombre}
                    </h4>
                    <p class={`text-sm font-medium mb-3 text-${docente.color}`}>
                      {docente.profesion}
                    </p>
                    <p class="text-xs text-gray-600 leading-relaxed">
                      {docente.descripcion}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Docentes Internacionales -->
        <div class="mb-20">
          <div class="flex items-center justify-center mb-12">
            <div class="w-16 h-1 bg-naranja"></div>
            <h3 class="text-2xl md:text-3xl font-bold text-naranja mx-6">
              Docentes Internacionales
            </h3>
            <div class="w-16 h-1 bg-naranja"></div>
          </div>

          <div class="flex flex-wrap justify-center gap-8 max-w-6xl mx-auto">
            {
              docentesInternacionales.map((docente) => (
                <div class="team-card bg-white border border-gray-100 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.34rem)]">
                  <div class="text-center">
                    <div
                      class={`w-28 h-28 mx-auto mb-6 rounded-full flex items-center justify-center text-4xl font-bold bg-gray-50 shadow-md group-hover:shadow-lg transition-all duration-300 text-${docente.color} overflow-hidden`}
                    >
                      {docente.imagen ? (
                        <Image
                          src={docente.imagen}
                          alt={docente.nombre}
                          class="w-full h-full object-cover"
                        />
                      ) : (
                        docente.initials
                      )}
                    </div>

                    <h4 class="text-xl font-bold text-gray-800 mb-2">
                      {docente.nombre}
                    </h4>
                    <p class={`text-sm font-medium mb-2 text-${docente.color}`}>
                      {docente.profesion}
                    </p>
                    <p class="text-sm text-gray-600 leading-relaxed">
                      {docente.descripcion}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Final Contextual -->
    <CtaFinal pagina="nosotros" />
  </div>
</Layout>

<style>
  .hero-nosotros {
    min-height: 70vh;
  }

  .proposito-section {
    /* Sección compacta sin min-height forzado */

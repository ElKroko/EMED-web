---
import Layout from '../layouts/Layout.astro';

// Array de fotos para rotar entre los miembros del equipo
const fotos = [
  "https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80",
  "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80", 
  "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
];

// Función para obtener foto basada en índice
const getFoto = (index) => fotos[index % fotos.length];
---

<Layout 
  title="Nosotros - EMED | Quienes Somos"
  description="Conoce nuestro equipo de profesionales especializados en mediación, nuestra misión, visión y docentes nacionales e internacionales."
>
  <div class="bg-crema min-h-screen">
  
    <!-- Hero: Quienes Somos -->
    <section class="hero-nosotros relative overflow-hidden py-24 bg-celeste">
      <div class="container mx-auto px-4 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
          
          <!-- Contenido de texto -->
          <div class="text-white">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8 leading-tight">
              Quienes Somos
            </h1>
            
            <div class="space-y-6 text-lg md:text-xl leading-relaxed">
              <p>
                Somos EMED – Centro de Estudios de Mediación, una institución pionera con más de 20 años de trayectoria formando mediadores en Chile.
              </p>
              
              <p>
                Nos dedicamos a transformar la sociedad a través del diálogo, capacitando profesionales con herramientas prácticas para la gestión constructiva de conflictos en los ámbitos familiar, escolar y laboral.
              </p>
              
              <div class="flex items-center gap-4 p-4 bg-white/10 rounded-lg backdrop-blur-sm border border-white/20">
                 <span class="text-4xl">🎓</span>
                 <div>
                   <p class="font-bold text-lg">Certificación Académica</p>
                   <p class="text-sm opacity-90">Nuestros diplomados cuentan con certificación del Instituto Profesional de Chile (IPCHILE).</p>
                 </div>
              </div>
            </div>
          </div>
          
          <!-- Imagen del equipo -->
          <div class="relative">
            <div class="bg-white rounded-2xl p-4 shadow-2xl transform -rotate-2 hover:rotate-0 transition-transform duration-300">
              <img 
                src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
                alt="Equipo EMED"
                class="w-full h-64 md:h-80 object-cover rounded-xl"
                loading="lazy"
              />
            </div>
          </div>
          
        </div>
      </div>
    </section>

    <!-- Sección: Promesa de Valor -->
    <section class="promesa-valor-section relative py-20 bg-crema">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="bg-gradient-to-br from-celeste/10 via-turquesa/5 to-naranja/10 rounded-3xl p-8 md:p-12 border-2 border-celeste/30 shadow-xl">
            <div class="flex items-start space-x-4 mb-6">
              <div class="flex-shrink-0">
                <svg class="w-12 h-12 text-celeste" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-4">
                  Promesa de Valor
                </h2>
                <p class="text-lg md:text-xl text-gray-700 leading-relaxed">
                  <strong class="text-celeste">Formación práctica</strong>, <strong class="text-turquesa">acompañamiento cercano</strong> y <strong class="text-naranja">certificaciones reconocidas</strong> que elevan tu empleabilidad y tu impacto social.
                </p>
              </div>
            </div>

            <!-- Beneficios clave -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
              <div class="bg-white/70 backdrop-blur-sm rounded-xl p-4 border border-celeste/20">
                <div class="flex items-center space-x-2 mb-2">
                  <svg class="w-5 h-5 text-celeste flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                  </svg>
                  <h3 class="font-bold text-gray-800">Formación Práctica</h3>
                </div>
                <p class="text-sm text-gray-600">Metodología activa con casos reales</p>
              </div>

              <div class="bg-white/70 backdrop-blur-sm rounded-xl p-4 border border-turquesa/20">
                <div class="flex items-center space-x-2 mb-2">
                  <svg class="w-5 h-5 text-turquesa flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                  <h3 class="font-bold text-gray-800">Acompañamiento</h3>
                </div>
                <p class="text-sm text-gray-600">Soporte personalizado durante tu formación</p>
              </div>

              <div class="bg-white/70 backdrop-blur-sm rounded-xl p-4 border border-naranja/20">
                <div class="flex items-center space-x-2 mb-2">
                  <svg class="w-5 h-5 text-naranja flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <h3 class="font-bold text-gray-800">Certificación</h3>
                </div>
                <p class="text-sm text-gray-600">Acreditación IRAM reconocida</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección: Misión y Visión -->
    <section class="mision-vision-section relative overflow-hidden py-32 z-10">
      <!-- SVG de fondo amarillo -->
      <!-- Fondo limpio -->
      <div class="absolute inset-0 -z-10">
      </div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-5xl mx-auto text-center">
          
          <!-- Título introductorio -->
          <div class="mb-16">
            <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-8 leading-tight">
              Nuestro Propósito
            </h2>
            <p class="text-xl md:text-2xl text-gray-700 leading-relaxed max-w-3xl mx-auto">
              Promover una cultura de paz y diálogo, entregando formación de excelencia que habilite a las personas para ser agentes de cambio en sus comunidades y entornos laborales.
            </p>
          </div>

          <!-- Misión -->
          <div class="mb-20">
            <div class="flex items-center justify-center mb-8">
              <div class="w-16 h-1 bg-gray-400"></div>
              <h3 class="text-3xl md:text-4xl font-bold text-gray-800 mx-6">
                NUESTRA MISIÓN
              </h3>
              <div class="w-16 h-1 bg-gray-400"></div>
            </div>
            
            <div class="bg-white/90 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-gray-200 shadow-2xl">
              <p class="text-xl md:text-2xl text-gray-800 leading-relaxed font-medium">
                <span class="text-2xl md:text-3xl font-bold text-amarillo">"</span>
                Formar mediadores de excelencia, éticos y comprometidos, entregando herramientas teóricas y prácticas que les permitan facilitar procesos de diálogo y construcción de acuerdos sostenibles en diversos contextos sociales.

                <span class="text-2xl md:text-3xl font-bold text-amarillo">"</span>
              </p>
              
              <div class="mt-8 pt-6 border-t border-gray-200">
                <p class="text-lg text-gray-600 leading-relaxed">
                  Creemos que cada conflicto es una oportunidad de crecimiento, 
                  y nuestro compromiso es acompañar a las personas en este proceso 
                  de transformación personal y social.
                </p>
              </div>
            </div>
          </div>
          
          <!-- Visión -->
          <div>
            <div class="flex items-center justify-center mb-8">
              <div class="w-16 h-1 bg-gray-400"></div>
              <h3 class="text-3xl md:text-4xl font-bold text-gray-800 mx-6">
                NUESTRA VISIÓN
              </h3>
              <div class="w-16 h-1 bg-gray-400"></div>
            </div>
            
            <div class="bg-white/90 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-gray-200 shadow-2xl">
              <p class="text-xl md:text-2xl text-gray-800 leading-relaxed font-medium">
                <span class="text-2xl md:text-3xl font-bold text-amarillo">"</span>
                Ser reconocidos como la institución líder en formación de mediadores en Chile y Latinoamérica, impulsando la profesionalización de la mediación como vía privilegiada para la resolución pacífica de conflictos y la construcción del tejido social.
                <span class="text-2xl md:text-3xl font-bold text-amarillo">"</span>
              </p>
              
              <div class="mt-8 pt-6 border-t border-gray-200">
                <p class="text-lg text-gray-600 leading-relaxed">
                  Aspiramos a expandir la cultura de paz y diálogo en Chile y toda América Latina, 
                  formando mediadores que transformen conflictos en oportunidades de entendimiento.
                </p>
              </div>
            </div>
          </div>

          <!-- Elementos decorativos -->
          <div class="mt-16 flex justify-center space-x-8">
            <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
            <div class="w-3 h-3 bg-gray-500 rounded-full"></div>
            <div class="w-3 h-3 bg-gray-600 rounded-full"></div>
            <div class="w-3 h-3 bg-gray-500 rounded-full"></div>
            <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
          </div>
          
        </div>
      </div>
      
      <!-- Forma orgánica inferior -->
      <div class="absolute bottom-0 left-0 right-0 h-24">
        <svg viewBox="0 0 1200 120" class="w-full h-full" preserveAspectRatio="none">
          <path d="M0,120 C300,80 500,60 600,80 C700,100 900,60 1200,80 L1200,120 Z" fill="#FEF7E8"/>
        </svg>
      </div>
    </section>

    <!-- Sección: Nuestro Equipo -->
    <section class="equipos-section relative py-20 bg-white">
      
      <!-- Línea divisoria ondulada -->
      <div class="absolute top-0 left-0 right-0 h-24">
        <svg viewBox="0 0 1200 120" class="w-full h-full" preserveAspectRatio="none">
          <path d="M0,0 C300,40 500,20 600,40 C700,60 900,20 1200,40 L1200,0 Z" fill="#FEF7E8"/>
        </svg>
      </div>
      
      <div class="container mx-auto px-4 pt-16">
        
        <!-- Título principal -->
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-6">
            Nuestro Equipo Profesional
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Profesionales especializados con amplia experiencia en mediación y formación académica de excelencia
          </p>
        </div>

        <!-- Equipo Directivo -->
        <div class="mb-20">
          <div class="flex items-center justify-center mb-12">
            <div class="w-16 h-1 bg-celeste"></div>
            <h3 class="text-2xl md:text-3xl font-bold text-celeste mx-6">
              Equipo Directivo
            </h3>
            <div class="w-16 h-1 bg-celeste"></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
            {[...Array(4)].map((_, index) => (
              <div class="team-card bg-white border border-gray-100 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="text-center">
                  <div class="w-20 h-20 mx-auto mb-4 rounded-full overflow-hidden shadow-md group-hover:shadow-lg transition-shadow duration-300">
                    <img 
                      src={getFoto(index)}
                      alt="Director"
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    />
                  </div>
                  <h4 class="text-lg font-bold text-gray-800 mb-1">Dr. María González</h4>
                  <p class="text-sm font-medium text-celeste mb-3">Directora Académica</p>
                  <p class="text-xs text-gray-600 leading-relaxed">
                    Especialista en Mediación Familiar con 15+ años de experiencia docente
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Docentes Nacionales -->
        <div class="mb-20">
          <div class="flex items-center justify-center mb-12">
            <div class="w-16 h-1 bg-turquesa"></div>
            <h3 class="text-2xl md:text-3xl font-bold text-turquesa mx-6">
              Docentes Nacionales
            </h3>
            <div class="w-16 h-1 bg-turquesa"></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 max-w-6xl mx-auto">
            {[...Array(7)].map((_, index) => (
              <div class="team-card bg-white border border-gray-100 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="text-center">
                  <div class="w-16 h-16 mx-auto mb-4 rounded-full overflow-hidden shadow-md group-hover:shadow-lg transition-shadow duration-300">
                    <img 
                      src={getFoto(index + 4)}
                      alt="Docente"
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    />
                  </div>
                  <h4 class="text-base font-bold text-gray-800 mb-1">Ps. Carlos Mendoza</h4>
                  <p class="text-sm font-medium text-turquesa mb-3">Mediación Escolar</p>
                  <p class="text-xs text-gray-600 leading-relaxed">
                    Psicólogo especializado en resolución de conflictos educativos
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Docentes Internacionales -->
        <div class="mb-20">
          <div class="flex items-center justify-center mb-12">
            <div class="w-16 h-1 bg-naranja"></div>
            <h3 class="text-2xl md:text-3xl font-bold text-naranja mx-6">
              Docentes Internacionales
            </h3>
            <div class="w-16 h-1 bg-naranja"></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
            {[...Array(3)].map((_, index) => (
              <div class="team-card bg-white border border-gray-100 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="text-center">
                  <div class="w-24 h-24 mx-auto mb-6 rounded-full overflow-hidden shadow-md group-hover:shadow-lg transition-shadow duration-300">
                    <img 
                      src={getFoto(index + 11)}
                      alt="Docente Internacional"
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    />
                  </div>
                  <h4 class="text-xl font-bold text-gray-800 mb-2">Dr. Ana Rodríguez</h4>
                  <p class="text-sm font-medium text-naranja mb-2">Universidad de Buenos Aires</p>
                  <p class="text-sm font-medium text-gray-500 mb-4">Mediación Comunitaria</p>
                  <p class="text-sm text-gray-600 leading-relaxed">
                    Doctora en Psicología Social con especialización en mediación comunitaria. Autora de 5 publicaciones internacionales sobre resolución de conflictos.
                  </p>
                  
                  <div class="mt-4 pt-4 border-t border-gray-100">
                    <a href="#" class="inline-flex items-center text-xs text-naranja hover:text-amarillo transition-colors duration-200">
                      <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M12.586 4.586a2 2 0 112.828 2.828l-3 3a2 2 0 01-2.828 0 1 1 0 00-1.414 1.414 4 4 0 005.656 0l3-3a4 4 0 00-5.656-5.656l-1.5 1.5a1 1 0 101.414 1.414l1.5-1.5z" clip-rule="evenodd"></path>
                        <path fill-rule="evenodd" d="M7.414 15.414a2 2 0 01-2.828-2.828l3-3a2 2 0 012.828 0 1 1 0 001.414-1.414 4 4 0 00-5.656 0l-3 3a4 4 0 105.656 5.656l1.5-1.5a1 1 0 10-1.414-1.414l-1.5 1.5z" clip-rule="evenodd"></path>
                      </svg>
                      Ver perfil completo
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- CTA de contacto -->
        <div class="text-center bg-gradient-to-r from-celeste/10 to-turquesa/10 rounded-2xl p-8 border border-celeste/20">
          <h3 class="text-2xl font-bold text-gray-800 mb-4">
            ¿Quieres conocer más sobre nuestro equipo?
          </h3>
          <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
            Nuestros profesionales están disponibles para resolver tus consultas sobre nuestros programas de formación
          </p>
          <a 
            href="/contacto"
            class="inline-flex items-center px-8 py-4 bg-celeste text-white font-bold text-lg rounded-xl hover:bg-turquesa transform hover:scale-105 transition-all duration-200 shadow-lg"
          >
            Contactar con Nuestro Equipo
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.007 8.007 0 01-7-4 8 8 0 017-4c4.418 0 8-3.582 8-8z"></path>
            </svg>
          </a>
        </div>
        
      </div>
    </section>

  </div>
</Layout>

<style>
  .hero-nosotros {
    min-height: 70vh;
  }
  
  .mision-vision-section {
    min-height: 100vh;
  }
  
  .equipos-section {
    min-height: auto;
  }
  
  /* Efectos de cristal para las cajas de misión y visión */
  .mision-vision-section .bg-white\/10 {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.1);
  }
  
  /* Animaciones suaves para elementos decorativos */
  .mision-vision-section .rounded-full {
    animation: pulse-subtle 3s ease-in-out infinite;
  }
  
  .mision-vision-section .rounded-full:nth-child(2) {
    animation-delay: 0.6s;
  }
  
  .mision-vision-section .rounded-full:nth-child(3) {
    animation-delay: 1.2s;
  }
  
  .mision-vision-section .rounded-full:nth-child(4) {
    animation-delay: 1.8s;
  }
  
  .mision-vision-section .rounded-full:nth-child(5) {
    animation-delay: 2.4s;
  }
  
  @keyframes pulse-subtle {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }
  
  /* Estilos para tarjetas del equipo */
  .team-card {
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  
  .team-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(126, 197, 214, 0.1), transparent);
    transition: left 0.5s;
  }
  
  .team-card:hover::before {
    left: 100%;
  }
  
  .team-card:hover {
    border-color: var(--color-celeste);
    transform: translateY(-8px);
  }
  
  .team-card .group:hover img {
    transform: scale(1.1);
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    .team-card {
      transform: none !important;
    }
    
    .team-card:hover {
      transform: translateY(-4px) !important;
    }
  }
</style>
<script>
  // Accordion behavior: Close others when one opens
  // This script runs on client-side to add the exclusive open behavior
  document.addEventListener('astro:page-load', () => {
    const detailsElements = document.querySelectorAll("details.group");

    detailsElements.forEach((detail) => {
      if (!(detail instanceof HTMLDetailsElement)) return;

      const summary = detail.querySelector("summary");
      if (summary) {
        summary.addEventListener("click", (e) => {
          // If we are clicking to open (currently closed)
          if (!detail.open) {
            // Close all others
            detailsElements.forEach((other) => {
              if (
                other !== detail &&
                other instanceof HTMLDetailsElement &&
                other.open
              ) {
                other.removeAttribute("open");
              }
            });
          }
        });
      }
    });
  });
</script>


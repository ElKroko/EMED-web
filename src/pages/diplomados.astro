---
import Layout from '../layouts/Layout.astro';
import { getDiplomados } from '../lib/productos';
import CtaFinal from "../components/sections/CtaFinal.astro";
// FAQs data - content as plain text will be rendered directly
const faqsDiplomados = [
  {
    title: "¿Ofrecen modalidad online?",
    content: "Sí. Trabajamos en formatos sincrónico (clases por zoom), y asincrónico (clases grabadas y material disponible en plataforma).",
    data: null
  },
  {
    title: "¿Tienen financiamiento?",
    content: "Sí. Contamos con opciones de financiamiento empresarial para programas de mediación laboral y escolar. Además, ofrecemos facilidades de pago en cuotas y descuentos preferenciales por pago al contado o tarjeta de crédito.",
    data: null
  },
  {
    title: "¿Los programas están acreditados?",
    content: "Absolutamente. Contamos con certificación NCh2728, lo que garantiza la calidad de nuestros procesos. El Diplomado en Mediación Familiar cuenta además con la certificación de IPCHILE (institución reconocida por el Estado), cumpliendo con todas las normativas del Ministerio de Justicia.",
    data: null
  },
  {
    title: "¿Entregan certificado al finalizar?",
    content: "Sí, todos nuestros programas diplomados incluyen un certificado oficial digital que acredita las horas cursadas, la aprobación de los módulos y las competencias adquiridas durante el programa.",
    data: null
  },
  {
    title: "¿Cuál es la duración de los diplomados?",
    content: "La duración varía según el programa específico, oscilando generalmente entre las 120 y 220 horas cronológicas (incluyendo horas de trabajo autónomo y prácticas cuando corresponde). Revisa la ficha de cada diplomado para el detalle exacto.",
    data: null
  },
  {
    title: "¿Cuándo inician las clases?",
    content: "Tenemos fechas de inicio flexibles a lo largo de todo el año para nuestros distintos programas. Te recomendamos contactar a un asesor para conocer la próxima fecha disponible para el programa de tu interés.",
    data: null
  },
  {
    title: "¿Necesito conocimientos previos?",
    content: "Para la mayoría de nuestros diplomados se requiere contar con un título técnico de nivel superior o profesional. Sin embargo, algunos cursos libres están abiertos a todo público. Revisa los requisitos específicos en la página de cada oferta académica.",
    data: null
  }
];

// Obtener diplomados desde datos estáticos
const diplomadosRaw = getDiplomados();

// Mapear a formato para la UI
const diplomadosFinales = diplomadosRaw.map(producto => {
  // Determinar badges
  let badges: string[] = [];
  if (producto.slug === 'mediacion-familiar') {
    badges = ['MÁS POPULAR'];
  }

  return {
    id: producto.slug,
    titulo: producto.nombre,
    descripcion: producto.descripcion_corta,
    duracion: producto.duracion,
    modalidad: producto.modalidad,
    precio: producto.precio_formateado,
    destacado: producto.destacado,
    imagen: producto.imagen,
    badges: badges,
    url: `/diplomados/${producto.slug}`,
    beneficios: producto.beneficios || []
  };
});
---

<Layout
  title="Diplomados - EMED | Especializaciones en Mediación"
  description="Descubre nuestros diplomados especializados en mediación. Programas con certificación oficial, metodología práctica y reconocimiento profesional."
>
  <div class="bg-crema min-h-screen">

    <!-- Hero Section Clean & Compact -->
    <section class="relative pt-20 pb-12 overflow-hidden bg-celeste">
      <div class="container mx-auto px-4 relative z-10">
        <div class="text-center text-white mb-12">
          <span class="inline-block py-1 px-3 rounded-full bg-white/10 text-white/90 text-sm font-semibold mb-4 border border-white/20">
            Formación Continua y Especializada
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight tracking-tight">
            Diplomados Especializados
          </h1>
          <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
            Programas de alta especialización con certificación oficial, diseñados para potenciar tu carrera profesional.
          </p>
        </div>

        <!-- Diplomados Grid - Integrado en el Hero/Header "Above the Fold" -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto relative z-20">
          {diplomadosFinales.map((diplomado) => (
            <article class={`bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 ${diplomado.destacado ? 'ring-2 ring-naranja relative' : 'border border-gray-100'}`}>
              
              {/* Imagen Compacta */}
              <div class="relative h-48 overflow-hidden group">
                <img
                  src={diplomado.imagen || 'https://images.unsplash.com/photo-1521791136064-7986c2920216?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'}
                  alt={diplomado.titulo}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-60"></div>

                {diplomado.destacado && (
                   <div class="absolute top-3 right-3 bg-naranja text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg flex items-center gap-1">
                     <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                     MÁS POPULAR
                   </div>
                )}
                
                <div class="absolute bottom-3 left-4 right-4">
                    <h3 class="text-xl font-bold text-white leading-tight mb-1 shadow-black drop-shadow-md">
                      {diplomado.titulo}
                    </h3>
                </div>
              </div>

              <div class="p-6">
                <!-- Información Clave Compacta -->
                <div class="flex items-center text-sm text-gray-500 mb-4 space-x-4">
                    <div class="flex items-center">
                        <svg class="w-4 h-4 mr-1.5 text-turquesa" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        {diplomado.duracion}
                    </div>
                    <div class="flex items-center">
                        <svg class="w-4 h-4 mr-1.5 text-turquesa" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        {diplomado.modalidad}
                    </div>
                </div>

                <p class="text-gray-600 text-sm leading-relaxed mb-6 line-clamp-2 h-10">
                  {diplomado.descripcion}
                </p>

                <div class="flex items-end justify-between mt-auto">
                    <div>
                        <span class="text-xs text-gray-400 block mb-1">Inversión desde</span>
                        <span class="text-lg font-bold text-naranja">{diplomado.precio}</span>
                    </div>

                    <a href={diplomado.url} class={`inline-flex items-center justify-center px-4 py-2 text-sm font-bold rounded-lg transition-all duration-300 ${diplomado.destacado ? 'bg-celeste hover:bg-turquesa text-white shadow-md hover:shadow-lg' : 'bg-gray-50 hover:bg-gray-100 text-gray-700 hover:text-gray-900'}`}>
                        Ver Programa
                        <svg class="ml-1.5 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Sección Por qué EMED -->
    <section class="py-20 relative z-10">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-6">
            ¿Por qué elegir EMED?
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Más de 20 años formando mediadores profesionales con excelencia y reconocimiento
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Item 1 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-celeste/10 rounded-full flex items-center justify-center text-celeste mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">+3000 Graduados</h3>
            <p class="text-sm text-gray-600">Mediadores formados exitosamente en nuestros programas</p>
          </div>

          <!-- Item 2 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-naranja/10 rounded-full flex items-center justify-center text-naranja mb-4">
               <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">20+ Años</h3>
            <p class="text-sm text-gray-600">De experiencia y liderazgo en formación de mediadores</p>
          </div>

          <!-- Item 3 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow">
             <div class="w-14 h-14 bg-turquesa/10 rounded-full flex items-center justify-center text-turquesa mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Acreditación Oficial</h3>
            <p class="text-sm text-gray-600">Programas certificados y reconocidos institucionalmente</p>
          </div>

          <!-- Item 4 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow">
             <div class="w-14 h-14 bg-amarillo/20 rounded-full flex items-center justify-center text-naranja mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Metodología Práctica</h3>
            <p class="text-sm text-gray-600">Aprendizaje basado en casos reales y experiencias</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección Garantías y Beneficios -->
    <section class="py-20 relative z-10">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-6">
              Tu inversión está protegida
            </h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">
              Estudia con total tranquilidad respaldado por nuestras garantías y beneficios exclusivos
            </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
            <!-- Card 1 -->
            <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow group">
               <div class="w-16 h-16 bg-verde/10 rounded-full flex items-center justify-center text-verde mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
               </div>
               <h3 class="text-xl font-bold text-gray-800 mb-3">Certificación Garantizada</h3>
               <p class="text-gray-600 leading-relaxed text-sm">Si cumples con los requisitos académicos, garantizamos tu certificación oficial</p>
            </div>

            <!-- Card 2 -->
            <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow group">
               <div class="w-16 h-16 bg-celeste/10 rounded-full flex items-center justify-center text-celeste mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
               </div>
               <h3 class="text-xl font-bold text-gray-800 mb-3">Apoyo Post-Graduación</h3>
               <p class="text-gray-600 leading-relaxed text-sm">Asesoría continua y networking con graduados para potenciar tu carrera</p>
            </div>

            <!-- Card 3 -->
            <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow group">
               <div class="w-16 h-16 bg-naranja/10 rounded-full flex items-center justify-center text-naranja mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
               </div>
               <h3 class="text-xl font-bold text-gray-800 mb-3">Material Actualizado</h3>
               <p class="text-gray-600 leading-relaxed text-sm">Contenidos constantemente actualizados según normativas vigentes</p>
            </div>

             <!-- Card 4 -->
            <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow group">
               <div class="w-16 h-16 bg-turquesa/10 rounded-full flex items-center justify-center text-turquesa mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path></svg>
               </div>
               <h3 class="text-xl font-bold text-gray-800 mb-3">Facilidades de Pago</h3>
               <p class="text-gray-600 leading-relaxed text-sm">Planes de financiamiento flexibles adaptados a tu situación, incluyendo cuotas sin interés</p>
            </div>

             <!-- Card 5 -->
            <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center hover:shadow-md transition-shadow group md:col-span-2 lg:col-span-2">
               <div class="w-16 h-16 bg-amarillo/20 rounded-full flex items-center justify-center text-naranja mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
               </div>
               <h3 class="text-xl font-bold text-gray-800 mb-3">Excelencia Académica</h3>
               <p class="text-gray-600 leading-relaxed text-sm max-w-lg mx-auto">Docentes con amplia experiencia práctica y reconocimiento en el área de mediación. Aprende de los mejores.</p>
            </div>
        </div>
      </div>
    </section>

    <!-- Sección Testimonios -->
    <section class="py-20 relative z-10">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-6">
            Lo que dicen nuestros graduados
          </h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            Testimonios reales de mediadores que transformaron su carrera profesional con EMED
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-center mb-6">
              <img src="https://images.unsplash.com/photo-1494790108755-2616b612b829?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&h=150&q=80" alt="María González" class="w-12 h-12 rounded-full mr-4 object-cover ring-2 ring-gray-100" />
              <div>
                <h4 class="font-bold text-gray-800">María González</h4>
                <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Mediadora Familiar</p>
              </div>
            </div>
            <p class="text-gray-600 leading-relaxed mb-4 text-sm italic">
              "El diplomado de Mediación Familiar cambió completamente mi perspectiva profesional. Los docentes son excepcionales y la metodología práctica me preparó para casos reales."
            </p>
            <div class="flex text-amarillo space-x-1">
               <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
               <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
               <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
               <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
               <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
          </div>


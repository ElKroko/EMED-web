---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/forms/ContactForm.astro';
import PlanEstudios from '../../components/sections/PlanEstudios.astro';
import MetodologiaHibrida from '../../components/sections/MetodologiaHibrida.astro';
import Diferenciadores from '../../components/sections/Diferenciadores.astro';
import FormacionOnline from '../../components/sections/FormacionOnline.astro';
import { getProductoPorSlug } from '../../lib/productos';

// Obtener datos del diplomado desde datos estáticos
const diplomadoWC = getProductoPorSlug('mediacion-familiar');

// Datos del diplomado
const titulo = diplomadoWC?.nombre || 'Diplomado en Mediación Familiar';
const descripcionCorta = diplomadoWC?.descripcion_corta || 'Especialízate en la resolución de conflictos familiares con técnicas específicas para dinámicas familiares complejas y casos de alta sensibilidad emocional.';
const duracion = diplomadoWC?.duracion || '220 horas';
const modalidad = diplomadoWC?.modalidad || 'Online + Presencial (Prácticas)';
const precio = diplomadoWC?.precio_formateado || 'desde $750.000';
const beneficios = diplomadoWC?.beneficios || [];
const temario = diplomadoWC?.temario || [];
const requisitos = diplomadoWC?.requisitos || [];
const certificacion = diplomadoWC?.certificacion || [];
const empleabilidad = diplomadoWC?.empleabilidad || [];
const diferenciadores = diplomadoWC?.diferenciadores || [];
const formacionOnline = diplomadoWC?.formacion_online || null;
const ctaMensaje = diplomadoWC?.cta_mensaje || '';
const duracionOnline = diplomadoWC?.duracion_online || '170 horas';
const duracionPresencial = diplomadoWC?.duracion_presencial || '50 horas';
const brochure = diplomadoWC?.brochure || null;
---

<Layout 
  title={`${titulo} - EMED | Certificación Ministerio de Justicia`}
  description={descripcionCorta}
>
  <div class="bg-crema min-h-screen">
  
    <!-- Hero del Programa -->
    <section class="hero-programa relative overflow-hidden">
      <!-- Imagen de fondo -->
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1609220136736-443140cffec6?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
          alt="Diplomado en Mediación Familiar"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/50"></div>
      </div>
      
      <div class="container mx-auto px-4 py-32 relative z-10">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <nav class="mb-8">
            <ol class="flex text-white/80 text-sm">
              <li><a href="/" class="hover:text-white">Inicio</a></li>
              <li class="mx-2">/</li>
              <li><a href="/diplomados" class="hover:text-white">Diplomados</a></li>
              <li class="mx-2">/</li>
              <li class="text-white">Mediación Familiar</li>
            </ol>
          </nav>
          
          <!-- Badges -->
          <div class="flex gap-3 mb-6">
            <span class="inline-block px-4 py-2 rounded-full text-sm font-bold text-white bg-celeste">
              Diplomado
            </span>
            <span class="inline-block bg-white/20 text-white px-4 py-2 rounded-full text-sm font-medium">
              {modalidad}
            </span>
            <span class="inline-block bg-gradient-to-r from-naranja to-amarillo text-white px-4 py-2 rounded-full text-sm font-bold">
              ⭐ MÁS POPULAR
            </span>
            <span class="inline-block bg-green-600 text-white px-4 py-2 rounded-full text-sm font-bold">
              ✓ MINJU
            </span>
          </div>
          
          <!-- Título y descripción -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
            {titulo}
          </h1>
          
          <p class="text-xl md:text-2xl text-white/90 mb-8 leading-relaxed">
            {descripcionCorta} <strong>Certificación oficial del Ministerio de Justicia</strong>.
          </p>
          
          <!-- Detalles rápidos -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{duracion}</div>
              <div class="text-white/80 text-sm">Duración</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{modalidad}</div>
              <div class="text-white/80 text-sm">Modalidad</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-celeste">{precio}</div>
              <div class="text-white/80 text-sm">Inversión</div>
            </div>
          </div>
          
          <!-- CTAs optimizados -->
          <div class="flex flex-col sm:flex-row gap-4">
            <button 
              onclick="scrollToContactForm()"
              class="inline-flex items-center justify-center px-6 py-3 md:px-8 md:py-4 font-bold text-base md:text-lg rounded-xl transition-all duration-200 shadow-xl bg-naranja hover:bg-amarillo text-white transform hover:scale-105"
            >
              <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.014 8.014 0 01-4.244-1.206L3 21l2.206-5.756A8.014 8.014 0 013 12a8 8 0 018-8c4.418 0 8 3.582 8 8z"></path>
              </svg>
              Hablar con un Asesor
            </button>
            <a 
              href="https://wa.me/56912345678?text=Hola,%20quiero%20información%20sobre%20el%20Diplomado%20en%20Mediación%20Familiar%20de%20EMED"
              target="_blank"
              class="inline-flex items-center justify-center px-6 py-3 md:px-8 md:py-4 bg-green-500 text-white font-bold text-base md:text-lg rounded-xl hover:bg-green-600 transition-all duration-200 shadow-xl transform hover:scale-105"
            >
              <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              WhatsApp Directo
            </a>
          </div>
        </div>
      </div>
      
      <!-- Forma orgánica inferior -->
      <div class="absolute bottom-0 left-0 right-0 h-24">
        <svg viewBox="0 0 1200 120" class="w-full h-full" preserveAspectRatio="none">
          <path d="M0,120 C300,80 500,60 600,80 C700,100 900,60 1200,80 L1200,120 Z" fill="#FEF7E8"/>
        </svg>
      </div>
    </section>

    <!-- Sección Brochure -->
    {brochure && (
      <section class="py-16 bg-gradient-to-r from-celeste/10 to-turquesa/10">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto text-center">
            <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-celeste/20">
              <div class="mb-6">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-r from-celeste to-turquesa rounded-full mb-4">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-gray-800 mb-3">
                  Descarga el Brochure Completo
                </h3>
                <p class="text-gray-600 text-lg mb-6">
                  Obtén toda la información detallada del diplomado, incluyendo programa completo, fechas, horarios y más.
                </p>
              </div>
              
              <a 
                href={brochure.url}
                download={brochure.filename || 'brochure-mediacion-familiar.pdf'}
                class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-celeste to-turquesa text-white font-bold text-lg rounded-xl hover:from-turquesa hover:to-celeste transition-all duration-300 shadow-lg transform hover:-translate-y-1 hover:shadow-xl"
              >
                <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Descargar Brochure PDF
                {brochure.filesize && (
                  <span class="ml-2 text-sm opacity-90">
                    ({Math.round(brochure.filesize / 1024 / 1024 * 10) / 10} MB)
                  </span>
                )}
              </a>
              
              <div class="mt-4 text-sm text-gray-500">
                📄 {brochure.title || 'Información completa del programa'}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Contenido del Programa -->
    <section class="py-20">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
          
          <!-- Contenido Principal -->
          <div class="lg:col-span-2 space-y-12">
            
            <!-- Descripción detallada -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <h2 class="text-3xl font-bold text-gray-800 mb-8">¿Por qué elegir nuestro Diplomado?</h2>
              
              <p class="text-lg text-gray-600 mb-6 leading-relaxed">
                Este diplomado está diseñado para profesionales que deseen especializarse en la mediación de conflictos familiares. Aborda desde los fundamentos teóricos hasta la práctica supervisada, <strong>cumpliendo con todos los requisitos del Ministerio de Justicia</strong> para el registro oficial de mediadores familiares.
              </p>

              <div class="bg-gradient-to-r from-celeste/10 to-turquesa/10 border border-celeste/30 rounded-lg p-6 mb-6">
                <h3 class="font-bold text-gray-800 mb-3 flex items-center">
                  <svg class="w-6 h-6 text-celeste mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Certificación Oficial
                </h3>
                <p class="text-gray-700">
                  Al completar exitosamente el diplomado, podrás inscribirte en el <strong>Registro de Mediadores Familiares del Ministerio de Justicia</strong>, habilitándote para ejercer profesionalmente la mediación familiar en Chile.
                </p>
              </div>

              <Diferenciadores items={diferenciadores} />
            </div>
            
            <!-- Temario -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <PlanEstudios modulos={temario} />
            </div>

            <!-- Formación Online -->
            {formacionOnline && (
              <div class="bg-white rounded-2xl p-8 shadow-lg">
                <FormacionOnline
                  etapaAsincronica={formacionOnline.etapa_asincronica}
                  etapaSincronica={formacionOnline.etapa_sincronica}
                />
              </div>
            )}

            <!-- Metodología -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <MetodologiaHibrida
                horasOnline={170}
                horasPresencial={50}
              />
            </div>

            
            <!-- Testimonios -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <h2 class="text-3xl font-bold text-gray-800 mb-8 flex items-center">
                <svg class="w-8 h-8 text-naranja mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>
                </svg>
                Lo que dicen nuestros egresados
              </h2>
              
              <div class="space-y-6">
                <div class="bg-gray-50 rounded-xl p-6">
                  <div class="flex items-center mb-4">
                    <div class="w-12 h-12 bg-celeste rounded-full flex items-center justify-center text-white font-bold text-lg mr-4">
                      MJ
                    </div>
                    <div>
                      <h4 class="font-semibold text-gray-800">María José González</h4>
                      <p class="text-gray-600 text-sm">Psicóloga • Mediadora Familiar Registrada</p>
                    </div>
                    <div class="ml-auto flex">
                      {[...Array(5)].map(() => (
                        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                        </svg>
                      ))}
                    </div>
                  </div>
                  <p class="text-gray-700 italic">"El diplomado me dio todas las herramientas necesarias para trabajar como mediadora familiar. La metodología práctica es excelente y la pasantía me permitió ganar confianza antes del registro oficial. Hoy trabajo en el centro de mediación de mi comuna."</p>
                </div>

                <div class="bg-gray-50 rounded-xl p-6">
                  <div class="flex items-center mb-4">
                    <div class="w-12 h-12 bg-celeste rounded-full flex items-center justify-center text-white font-bold text-lg mr-4">
                      CM
                    </div>
                    <div>
                      <h4 class="font-semibold text-gray-800">Carlos Mendoza</h4>
                      <p class="text-gray-600 text-sm">Abogado • Centro de Mediación Familiar Las Condes</p>
                    </div>
                    <div class="ml-auto flex">
                      {[...Array(5)].map(() => (
                        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                        </svg>
                      ))}
                    </div>
                  </div>
                  <p class="text-gray-700 italic">"Excelente formación teórica y práctica. Los docentes son profesionales con amplia experiencia en mediación familiar real. El enfoque en casos chilenos y la legislación nacional fue fundamental para mi éxito profesional."</p>
                </div>
              </div>
            </div>
            
          </div>
          
          <!-- Sidebar -->
          <div class="space-y-8">
            
            <!-- Información del Programa -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-8">Información del Programa</h3>
              
              <div class="space-y-4">
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-gray-600">Duración:</span>
                  <span class="font-semibold text-gray-800">{duracion}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-gray-600">Modalidad:</span>
                  <span class="font-semibold text-gray-800">{modalidad}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-gray-600">Nivel:</span>
                  <span class="font-semibold text-gray-800">Intermedio</span>
                </div>
                <div class="flex justify-between items-center py-2">
                  <span class="text-gray-600">Inversión:</span>
                  <span class="font-bold text-lg text-celeste">{precio}</span>
                </div>
              </div>
              
              <div class="mt-6">
                <button
                  onclick="scrollToContactForm()"
                  class="inline-flex items-center justify-center w-full px-4 py-3 md:px-6 md:py-4 font-bold text-sm md:text-base rounded-lg transition-all duration-300 text-white bg-naranja hover:bg-amarillo"
                >
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.014 8.014 0 01-4.244-1.206L3 21l2.206-5.756A8.014 8.014 0 013 12a8 8 0 018-8c4.418 0 8 3.582 8 8z"></path>
                  </svg>
                  Consultar con Asesor
                </button>
              </div>
              
              <!-- Urgency element -->
              <div class="mt-4 bg-gradient-to-r from-naranja/10 to-amarillo/10 border border-naranja/30 rounded-lg p-4">
                <div class="flex items-center mb-2">
                  <svg class="w-5 h-5 text-naranja mr-2 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-naranja font-semibold text-sm">¡Últimas plazas!</span>
                </div>
                <p class="text-gray-600 text-sm">Este es nuestro programa más solicitado. Quedan pocas vacantes para el próximo ciclo.</p>
              </div>
            </div>
            
            <!-- Beneficios -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-8">Beneficios Exclusivos</h3>
              
              <div class="space-y-3">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Certificación reconocida por el Ministerio de Justicia</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Práticas con casos reales supervisados</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Inserción en registro oficial de mediadores</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Metodología actualizada según normativa vigente</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Networking con profesionales del área</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Material de apoyo descargable</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Seguimiento post-certificación</span>
                </div>
              </div>
            </div>
            
            <!-- Requisitos -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-8">Requisitos de Ingreso</h3>
              
              <div class="space-y-3">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-turquesa mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">

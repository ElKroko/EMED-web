---
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../../components/forms/ContactForm.astro";
import MetodologiaHibrida from "../../components/sections/MetodologiaHibrida.astro";
import Diferenciadores from "../../components/sections/Diferenciadores.astro";
import FormacionOnline from "../../components/sections/FormacionOnline.astro";
import DownloadButtons from "../../components/sections/DownloadButtons.astro";
import PLAN_ESTUDIOS from "../../components/sections/PlanEstudios.astro";
import NewPlanEstudios from "../../components/sections/NewPlanEstudios.astro";
import FAQ from "../../components/sections/FAQ.astro";
import DocentesDiplomado from "../../components/sections/DocentesDiplomado.astro";
import MobileStickyCTA from "../../components/sections/MobileStickyCTA.astro";
import OtrosDiplomados from "../../components/sections/OtrosDiplomados.astro";
import { getProductoPorSlug } from "../../lib/productos";

// Obtener datos del diplomado desde datos estáticos
const diplomadoWC = getProductoPorSlug("mediacion-familiar");

// Datos del diplomado
const titulo = diplomadoWC?.nombre || "Diplomado en Mediación Familiar";
const descripcionCorta =
  diplomadoWC?.descripcion_corta ||
  "Fórmate como mediador familiar y ayuda a madres y padres a resolver sus conflictos con foco en el bienestar de sus hijos, protegiendo sus vínculos y su estabilidad emocional.";
const duracion = diplomadoWC?.duracion || "220 horas";
const modalidad = diplomadoWC?.modalidad || "Online + Presencial (Prácticas)";
const precio = diplomadoWC?.precio_formateado || "desde $725.000";
const beneficios = diplomadoWC?.beneficios || [];
const temario = diplomadoWC?.temario || [];
const requisitos = diplomadoWC?.requisitos || [];
const certificacion = diplomadoWC?.certificacion || [];
const empleabilidad = diplomadoWC?.empleabilidad || [];
const diferenciadores = diplomadoWC?.diferenciadores || [];
const formacionOnline = diplomadoWC?.formacion_online || null;
const ctaMensaje = diplomadoWC?.cta_mensaje || "";
const testimonios = diplomadoWC?.testimonios || [];
const faqs = diplomadoWC?.faqs || [];
const docentes = diplomadoWC?.docentes || [];
---

<Layout
  title={`${titulo} - EMED | Certificación Ministerio de Justicia`}
  description={descripcionCorta}
>
  <div class="bg-crema min-h-screen">
    <!-- Hero del Programa -->
    <section class="hero-programa relative overflow-hidden">
      <!-- Imagen de fondo -->
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1609220136736-443140cffec6?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
          alt="Diplomado en Mediación Familiar"
          class="w-full h-full object-cover"
        />
        <div
          class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/50"
        >
        </div>
      </div>

      <div class="container mx-auto px-4 py-20 md:py-32 relative z-10">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <nav class="mb-8">
            <ol class="flex text-white/80 text-sm">
              <li><a href="/" class="hover:text-white">Inicio</a></li>
              <li class="mx-2">/</li>
              <li>
                <a href="/diplomados" class="hover:text-white">Diplomados</a>
              </li>
              <li class="mx-2">/</li>
              <li class="text-white">Mediación Familiar</li>
            </ol>
          </nav>

          <!-- Badges -->
          <div class="flex flex-wrap gap-2 md:gap-3 mb-6">
            <span
              class="inline-block px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-bold text-white bg-celeste"
            >
              Diplomado
            </span>
            <span
              class="inline-block bg-white/20 text-white px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-medium"
            >
              {modalidad}
            </span>
            <span
              class="inline-block bg-gradient-to-r from-naranja to-amarillo text-white px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-bold"
            >
              ⭐ MÁS POPULAR
            </span>
            <span
              class="inline-block bg-green-600 text-white px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-bold"
            >
              ✓ MINJU
            </span>
          </div>

          <!-- Título y descripción -->
          <h1
            class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight"
          >
            {titulo}
          </h1>

          <p class="text-xl md:text-2xl text-white/90 mb-8 leading-relaxed">
            {descripcionCorta}
            <strong>Certificación oficial del Ministerio de Justicia</strong>.
          </p>

          <!-- Detalles rápidos -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{duracion}</div>
              <div class="text-white/80 text-sm">Duración</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{modalidad}</div>
              <div class="text-white/80 text-sm">Modalidad</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-celeste">{precio}</div>
              <div class="text-white/80 text-sm">Inversión</div>
            </div>
          </div>

          <!-- CTAs optimizados -->
          <div class="hero-buttons-container">
            <button
              onclick="scrollToContactForm()"
              class="btn-hero btn-hero-primary px-8 py-3 md:px-12 md:py-4 text-base md:text-lg"
            >
              <svg
                class="w-6 h-6 mr-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                ></path>
              </svg>
              Hablar con un Asesor
            </button>
            <a
              href="https://wa.me/56965620939?text=Hola,%20quiero%20información%20sobre%20el%20Diplomado%20en%20Mediación%20Familiar%20de%20EMED"
              target="_blank"
              class="btn-hero btn-hero-whatsapp px-8 py-3 md:px-12 md:py-4 text-base md:text-lg"
            >
              <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path>
              </svg>
              WhatsApp Directo
            </a>
          </div>
        </div>
      </div>

      <!-- Forma orgánica inferior -->
      <div class="absolute bottom-0 left-0 right-0 h-24">
        <svg
          viewBox="0 0 1200 120"
          class="w-full h-full"
          preserveAspectRatio="none"
        >
          <path
            d="M0,120 C300,80 500,60 600,80 C700,100 900,60 1200,80 L1200,120 Z"
            fill="#FEF7E8"></path>
        </svg>
      </div>
    </section>

    <!-- Contenido del Programa -->
    <section class="py-12 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
          <!-- Contenido Principal (Columna Izquierda) -->
          <div class="lg:col-span-2 space-y-12">
            <!-- 1. ¿Por qué elegir el diplomado? -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <h2
                class="text-2xl md:text-3xl font-bold text-gray-800"
                style="margin-bottom: 10px;"
              >
                ¿Por qué elegir nuestro Diplomado?
              </h2>

              <p class="text-lg text-gray-600 mb-6 leading-relaxed">
                Este diplomado está diseñado para <strong>profesionales</strong> que
                deseen especializarse en la <strong
                  >mediación de conflictos familiares</strong
                >. Aborda desde los fundamentos teóricos hasta la práctica
                supervisada, <strong
                  >cumpliendo con todos los requisitos del Ministerio de
                  Justicia</strong
                > para el registro oficial de mediadores familiares.
              </p>

              <div
                class="bg-gradient-to-r from-celeste/10 to-turquesa/10 border border-celeste/30 rounded-lg p-6 mb-6"
              >
                <h3 class="font-bold text-gray-800 mb-3 flex items-center">
                  <svg
                    class="w-6 h-6 text-celeste mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Certificación Oficial
                </h3>
                <p class="text-gray-700">
                  Nuestro Diplomado cumple con los requisitos de la Circular
                  3511 (2025) y cuenta con certificación oficial de IPCHILE,
                  <strong class="text-gray-800"
                    >Instituto de Educación Superior reconocido por el Estado</strong
                  >, lo que te permite acceder al Registro Único de Mediadores
                  (RUM) del Ministerio de Justicia.
                </p>
              </div>

              <Diferenciadores items={diferenciadores} />

              <div class="mt-8 border-t border-gray-100 pt-8">
                <h3 class="text-xl font-bold text-gray-800 mb-6">
                  Material Descargable
                </h3>
                <DownloadButtons
                  mallaUrl="/docs/diplomados/mediacion-familiar/malla.pdf"
                  calendarioUrl="/docs/diplomados/mediacion-familiar/brochure.pdf"
                  arancelesUrl="/docs/diplomados/mediacion-familiar/aranceles.pdf"
                  className="mt-4"
                />
              </div>
            </div>

            <!-- 2. Metodología -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <MetodologiaHibrida
                horasOnline={180}
                horasPresencial={40}
                detallesOnline={[
                  "Acceso ilimitado a Campus Virtual 24/7",
                  "Clases sincrónicas en vivo por Zoom",
                  "Material de estudio descargable",
                  "Actividades interactivas de autoaprendizaje",
                ]}
                detallesPresencial={[
                  "Semana de entrenamiento intensivo en Santiago",
                  "Role Playing con casos reales",
                  "Preparación específica pauta ECAME",
                  "Supervisión directa de docentes mediadores",
                ]}
              />
            </div>

            <!-- 3. Requisitos -->
            <div
              class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100"
            >
              <h2
                class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-3"
              >
                Requisitos de Ingreso
              </h2>
              <div class="grid md:grid-cols-2 gap-4">
                {
                  requisitos.map((item) => (
                    <div class="group flex items-start bg-gray-50 p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-teal-100 transition-all duration-300">
                      <div class="w-10 h-10 flex-shrink-0 bg-white rounded-lg shadow-sm flex items-center justify-center text-teal-600 mr-4 group-hover:scale-110 group-hover:bg-teal-50 transition-all duration-300">
                        <svg
                          class="w-5 h-5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                          />
                        </svg>
                      </div>
                      <span class="text-gray-700 font-medium pt-1 leading-snug">
                        {item}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>

            <!-- 4. Campo Laboral -->
            <div
              class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 relative overflow-hidden group hover:shadow-xl transition-all duration-300"
            >
              <h2
                class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-3"
              >
                Campo Laboral
              </h2>

              <p class="text-gray-600 mb-6 leading-relaxed relative z-10">
                Al completar tu formación, podrás desempeñarte profesionalmente
                en diversos ámbitos donde la mediación familiar es requerida y
                valorada.
              </p>

              <div class="grid md:grid-cols-2 gap-4 relative z-10">
                <!-- Centros de Mediación Familiar -->
                <div
                  class="group/item flex items-start bg-gradient-to-br from-gray-50 to-white p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-green-200 transition-all duration-300"
                >
                  <div
                    class="w-12 h-12 flex-shrink-0 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mr-4 group-hover/item:scale-110 group-hover/item:bg-green-50 group-hover/item:shadow-md transition-all duration-300"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <span class="text-gray-800 font-semibold block mb-1"
                      >Centros de Mediación Familiar</span
                    >
                    <span class="text-gray-500 text-sm"
                      >Centros licitados y privados a nivel nacional</span
                    >
                  </div>
                </div>

                <!-- Tribunales de Familia -->
                <div
                  class="group/item flex items-start bg-gradient-to-br from-gray-50 to-white p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-green-200 transition-all duration-300"
                >
                  <div
                    class="w-12 h-12 flex-shrink-0 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mr-4 group-hover/item:scale-110 group-hover/item:bg-green-50 group-hover/item:shadow-md transition-all duration-300"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <span class="text-gray-800 font-semibold block mb-1"
                      >Tribunales de Familia</span
                    >
                    <span class="text-gray-500 text-sm">
                      Te permite ejercer ante Tribunales de Familia vía Registro
                      Único de Mediadores.</span
                    >
                  </div>
                </div>

                <!-- Consultoría Independiente -->
                <div
                  class="group/item flex items-start bg-gradient-to-br from-gray-50 to-white p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-green-200 transition-all duration-300"
                >
                  <div
                    class="w-12 h-12 flex-shrink-0 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mr-4 group-hover/item:scale-110 group-hover/item:bg-green-50 group-hover/item:shadow-md transition-all duration-300"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <span class="text-gray-800 font-semibold block mb-1"
                      >Consultoría Independiente</span
                    >
                    <span class="text-gray-500 text-sm"
                      >Práctica privada con clientes directos</span
                    >
                  </div>
                </div>

                <!-- ONGs Especializadas -->
                <div
                  class="group/item flex items-start bg-gradient-to-br from-gray-50 to-white p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-green-200 transition-all duration-300"
                >
                  <div
                    class="w-12 h-12 flex-shrink-0 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mr-4 group-hover/item:scale-110 group-hover/item:bg-green-50 group-hover/item:shadow-md transition-all duration-300"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <span class="text-gray-800 font-semibold block mb-1"
                      >ONGs Especializadas</span
                    >
                    <span class="text-gray-500 text-sm"
                      >Organizaciones de apoyo familiar y social</span
                    >
                  </div>
                </div>

                <!-- Servicios Municipales -->
                <div
                  class="group/item flex items-start bg-gradient-to-br from-gray-50 to-white p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-green-200 transition-all duration-300 md:col-span-2"
                >
                  <div
                    class="w-12 h-12 flex-shrink-0 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mr-4 group-hover/item:scale-110 group-hover/item:bg-green-50 group-hover/item:shadow-md transition-all duration-300"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <span class="text-gray-800 font-semibold block mb-1"
                      >Servicios Municipales</span
                    >
                    <span class="text-gray-500 text-sm"
                      >Programas de mediación comunitaria y oficinas de familia
                      en municipalidades</span
                    >
                  </div>
                </div>
              </div>

              <!-- CTA para campo laboral -->
              <div class="mt-6 pt-6 border-t border-gray-100 relative z-10">
                <div
                  class="flex items-center justify-between bg-gradient-to-r from-green-50 to-teal-50 rounded-xl p-4 border border-green-100"
                >
                  <div class="flex items-center">
                    <div
                      class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center mr-3"
                    >
                      <svg
                        class="w-5 h-5 text-green-600"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                      </svg>
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-gray-800">
                        Alta demanda laboral
                      </p>
                      <p class="text-xs text-gray-500">
                        Campo en constante crecimiento en Chile
                      </p>
                    </div>
                  </div>
                  <span
                    class="hidden sm:inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700"
                  >
                    +500 mediadores activos
                  </span>
                </div>
              </div>
            </div>

            <!-- 5. Malla (Plan de Estudios) -->
            <!-- 5. Malla (Plan de Estudios) -->
            <NewPlanEstudios
              modulos={temario as any}
              tituloPrograma={titulo}
              pdfUrl="/docs/diplomados/mediacion-familiar/malla.pdf"
            />

            <!-- 6. Certificación -->
            <div
              class="bg-white rounded-2xl p-8 shadow-lg relative overflow-hidden group hover:shadow-xl transition-all duration-300"
            >
              <h2
                class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-3"
              >
                Certificación y Registro
              </h2>

              <div class="space-y-8 relative z-10">
                <!-- Main Certification Statement -->
                <div>
                  <p class="text-lg text-gray-700 leading-relaxed">
                    Nuestro programa de Mediación Familiar cuenta con la
                    certificación académica del <strong
                      class="text-gray-900 font-bold bg-yellow-50 px-2 py-0.5 rounded"
                      >Instituto Profesional IPChile</strong
                    >, una institución de reconocido prestigio.
                  </p>
                </div>

                <!-- Legal Validity Box -->
                <div
                  class="bg-gradient-to-br from-blue-50 to-white rounded-xl p-6 border border-blue-100 shadow-sm relative overflow-hidden"
                >
                  <div class="flex items-start">
                    <div class="flex-shrink-0 mt-1">
                      <svg
                        class="w-6 h-6 text-blue-600"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"></path>
                      </svg>
                    </div>
                    <div class="ml-4">
                      <h4 class="text-lg font-bold text-gray-900 mb-2">

---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/forms/ContactForm.astro';
import PlanEstudios from '../../components/sections/PlanEstudios.astro';
import Diferenciadores from '../../components/sections/Diferenciadores.astro';
import { getProductoPorSlug } from '../../lib/productos';

// Obtener datos del diplomado desde datos estáticos
const diplomadoWC = getProductoPorSlug('mediacion-escolar');

// Datos del diplomado
const titulo = diplomadoWC?.nombre || 'Diplomado en Mediación Escolar';
const descripcionCorta = diplomadoWC?.descripcion_corta || 'Aprende a mediar conflictos educativos trabajando con estudiantes, padres y equipos docentes en ambientes escolares complejos.';
const duracion = diplomadoWC?.duracion || '240 horas';
const modalidad = diplomadoWC?.modalidad || '100% online';
const precio = diplomadoWC?.precio_formateado || 'desde $450.000';
const beneficios = diplomadoWC?.beneficios || [];
const temario = diplomadoWC?.temario || [];
const requisitos = diplomadoWC?.requisitos || [];
const metodologia = diplomadoWC?.metodologia || [];
const certificacion = diplomadoWC?.certificacion || [];
const empleabilidad = diplomadoWC?.empleabilidad || [];
const brochure = diplomadoWC?.brochure || null;

// Nuevos campos específicos de Escolar
const tituloPersonal = (diplomadoWC as any)?.titulo_principal || 'Transformando la Convivencia Escolar';
const metodologiaAdaptada = (diplomadoWC as any)?.metodologia_adaptada || null;
const horariosCompatibles = (diplomadoWC as any)?.horarios_compatibles || '';
const certificacionDetallada = (diplomadoWC as any)?.certificacion_detallada || '';
const campoAplicacion = (diplomadoWC as any)?.campo_aplicacion || [];
const diferenciadores = (diplomadoWC as any)?.diferenciadores || [];
---

<Layout 
  title={`${titulo} - EMED | Resolución de Conflictos Educativos`}
  description={descripcionCorta}
>
  <div class="bg-crema min-h-screen">
  
    <!-- Hero del Programa -->
    <section class="hero-programa relative overflow-hidden">
      <!-- Imagen de fondo -->
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1544717297-fa95b6ee9643?ixlib=rb-4.0.3&auto=format&fit=crop&w=2069&q=80"
          alt="Diplomado en Mediación Escolar"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/50"></div>
      </div>
      
      <div class="container mx-auto px-4 py-32 relative z-10">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <nav class="mb-8">
            <ol class="flex text-white/80 text-sm">
              <li><a href="/" class="hover:text-white">Inicio</a></li>
              <li class="mx-2">/</li>
              <li><a href="/diplomados" class="hover:text-white">Diplomados</a></li>
              <li class="mx-2">/</li>
              <li class="text-white">Mediación Escolar</li>
            </ol>
          </nav>
          
          <!-- Badges -->
          <div class="flex gap-3 mb-6">
            <span class="inline-block px-4 py-2 rounded-full text-sm font-bold text-white bg-celeste">
              Diplomado
            </span>
            <span class="inline-block bg-white/20 text-white px-4 py-2 rounded-full text-sm font-medium">
              {modalidad}
            </span>
            <span class="inline-block bg-green-600 text-white px-4 py-2 rounded-full text-sm font-bold">
              ✓ MINEDUC
            </span>
          </div>
          
          <!-- Título y descripción -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
            {titulo}
          </h1>
          
          <p class="text-xl md:text-2xl text-white/90 mb-8 leading-relaxed">
            {descripcionCorta} <strong>Formación especializada para profesionales de la educación</strong>.
          </p>
          
          <!-- Detalles rápidos -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{duracion}</div>
              <div class="text-white/80 text-sm">Duración</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{modalidad}</div>
              <div class="text-white/80 text-sm">Modalidad</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-celeste">{precio}</div>
              <div class="text-white/80 text-sm">Inversión</div>
            </div>
          </div>
          
          <!-- CTAs optimizados -->
          <div class="flex flex-col sm:flex-row gap-4">
            <button 
              onclick="scrollToContactForm()"
              class="inline-flex items-center justify-center px-6 py-3 md:px-8 md:py-4 font-bold text-base md:text-lg rounded-xl transition-all duration-200 shadow-xl bg-celeste hover:bg-turquesa text-white transform hover:scale-105"
            >
              <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.014 8.014 0 01-4.244-1.206L3 21l2.206-5.756A8.014 8.014 0 013 12a8 8 0 018-8c4.418 0 8 3.582 8 8z"></path>
              </svg>
              Hablar con un Asesor
            </button>
            <a 
              href="https://wa.me/56912345678?text=Hola,%20quiero%20información%20sobre%20el%20Diplomado%20en%20Mediación%20Escolar%20de%20EMED"
              target="_blank"
              class="inline-flex items-center justify-center px-6 py-3 md:px-8 md:py-4 bg-green-500 text-white font-bold text-base md:text-lg rounded-xl hover:bg-green-600 transition-all duration-200 shadow-xl transform hover:scale-105"
            >
              <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              WhatsApp Directo
            </a>
          </div>
        </div>
      </div>
      
      <!-- Forma orgánica inferior -->
      <div class="absolute bottom-0 left-0 right-0 h-24">
        <svg viewBox="0 0 1200 120" class="w-full h-full" preserveAspectRatio="none">
          <path d="M0,120 C300,80 500,60 600,80 C700,100 900,60 1200,80 L1200,120 Z" fill="#FEF7E8"/>
        </svg>
      </div>
    </section>

    <!-- Sección Brochure -->
    {brochure && (
      <section class="py-16 bg-gradient-to-r from-celeste/10 to-turquesa/10">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto text-center">
            <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-celeste/20">
              <div class="mb-6">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-r from-celeste to-turquesa rounded-full mb-4">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-gray-800 mb-3">
                  Descarga el Brochure Completo
                </h3>
                <p class="text-gray-600 text-lg mb-6">
                  Obtén toda la información detallada del diplomado, incluyendo programa completo, fechas, horarios y más.
                </p>
              </div>
              
              <a 
                href={brochure.url}
                download={brochure.filename || 'brochure-mediacion-escolar.pdf'}
                class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-celeste to-turquesa text-white font-bold text-lg rounded-xl hover:from-turquesa hover:to-celeste transition-all duration-300 shadow-lg transform hover:-translate-y-1 hover:shadow-xl"
              >
                <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Descargar Brochure PDF
                {brochure.filesize && (
                  <span class="ml-2 text-sm opacity-90">
                    ({Math.round(brochure.filesize / 1024 / 1024 * 10) / 10} MB)
                  </span>
                )}
              </a>
              
              <div class="mt-4 text-sm text-gray-500">
                📄 {brochure.title || 'Información completa del programa'}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Contenido del Programa -->
    <section class="py-20">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
          
          <!-- Contenido Principal -->
          <div class="lg:col-span-2 space-y-12">
            
            <!-- Descripción detallada -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <h2 class="text-3xl font-bold text-gray-800 mb-8">{tituloPersonal}</h2>
              
              <p class="text-lg text-gray-600 mb-6 leading-relaxed">
                Formación especializada para profesionales de la educación que buscan implementar programas de mediación escolar efectivos. Incluye herramientas específicas para el trabajo con menores y metodologías adaptadas al contexto educativo chileno.
              </p>

              <div class="bg-gradient-to-r from-celeste/10 to-turquesa/10 border border-celeste/30 rounded-lg p-6 mb-6">
                <h3 class="font-bold text-gray-800 mb-3 flex items-center">
                  <svg class="w-6 h-6 text-celeste mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                  </svg>
                  100% Flexible y Online
                </h3>
                <p class="text-gray-700">
                  Modalidad completamente virtual que se adapta a los horarios de los profesionales de la educación, con contenido disponible 24/7 y clases sincrónicas opcionales.
                </p>
              </div>

              <h3 class="text-xl font-bold text-gray-800 mb-4">¿Por qué es esencial para tu establecimiento?</h3>
              <ul class="space-y-3">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600">Reduce significativamente los casos de bullying y acoso escolar</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600">Mejora el clima escolar y las relaciones interpersonales</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600">Fortalece la participación activa de padres y apoderados</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600">Desarrolla habilidades socioemocionales en los estudiantes</span>
                </li>
              </ul>
            </div>

            <!-- Diferenciadores -->
            {diferenciadores && diferenciadores.length > 0 && (
              <div class="bg-white rounded-2xl p-8 shadow-lg">
                <Diferenciadores items={diferenciadores} titulo="Lo que te diferenciará:" />
              </div>
            )}

            <!-- Plan de Estudios -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <PlanEstudios modulos={temario} />
            </div>

          </div>

          <!-- Sidebar -->
          <div class="space-y-8">

            <!-- Información del Programa -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-8">Información del Programa</h3>

              <div class="space-y-4">
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-gray-600">Duración:</span>
                  <span class="font-semibold text-gray-800">{duracion}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-gray-600">Modalidad:</span>
                  <span class="font-semibold text-gray-800">{modalidad}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-gray-600">Nivel:</span>
                  <span class="font-semibold text-gray-800">Básico</span>
                </div>
                <div class="flex justify-between items-center py-2">
                  <span class="text-gray-600">Inversión:</span>
                  <span class="font-bold text-lg text-celeste">{precio}</span>
                </div>
              </div>

              <div class="mt-6">
                <button
                  onclick="scrollToContactForm()"
                  class="inline-flex items-center justify-center w-full px-4 py-3 md:px-6 md:py-4 font-bold text-sm md:text-base rounded-lg transition-all duration-300 text-white bg-celeste hover:bg-turquesa"
                >
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-3.582 8-8 8a8.014 8.014 0 01-4.244-1.206L3 21l2.206-5.756A8.014 8.014 0 013 12a8 8 0 018-8c4.418 0 8 3.582 8 8z"></path>
                  </svg>
                  Consultar con Asesor
                </button>
              </div>
            </div>

            <!-- Beneficios -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-8">Beneficios Únicos</h3>
              
              <div class="space-y-3">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Flexibilidad horaria total para profesores</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Material descargable permanente</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Casos prácticos del ámbito educativo chileno</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Certificación válida para instituciones educativas</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Herramientas digitales incluidas</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-celeste mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Acceso a comunidad de práctica educativa</span>
                </div>
              </div>
            </div>
            
            <!-- Requisitos -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-8">Requisitos de Ingreso</h3>
              
              <div class="space-y-3">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-turquesa mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Título en educación o afines</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-turquesa mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Experiencia en establecimientos educacionales</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-turquesa mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Conocimiento básico de convivencia escolar</span>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-turquesa mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Acceso a internet estable</span>
                </div>
              </div>
            </div>

            <!-- Certificación -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                <svg class="w-6 h-6 text-amarillo mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2m0 0l4-4m-6 2a9 9 0 110 18 9 9 0 010-18z"></path>
                </svg>
                Certificación
              </h3>
              <p class="text-gray-600 leading-relaxed text-sm">
                <strong>Diploma de Especialización en Mediación Escolar</strong>, reconocido por instituciones educativas públicas y privadas de Chile.
              </p>
            </div>

            <!-- Empleabilidad -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                <svg class="w-6 h-6 text-verde mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0V6a2 2 0 012 2v6a2 2 0 01-2 2H6a2 2 0 01-2-2V8a2 2 0 012-2V6z"></path>
                </svg>
                Campo de Aplicación
              </h3>
              
              <div class="space-y-3">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-verde mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600 text-sm">Colegios y liceos públicos y privados</span>
                </div>
                <div class="flex items-start">

---
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../../components/forms/ContactForm.astro";
import MetodologiaOnline from "../../components/sections/MetodologiaOnline.astro";
import Diferenciadores from "../../components/sections/Diferenciadores.astro";
import DownloadButtons from "../../components/sections/DownloadButtons.astro";
import NewPlanEstudios from "../../components/sections/NewPlanEstudios.astro";
import DocentesDiplomado from "../../components/sections/DocentesDiplomado.astro";
import MobileStickyCTA from "../../components/sections/MobileStickyCTA.astro";
import { getProductoPorSlug } from "../../lib/productos";

// Obtener datos del diplomado desde datos estáticos
const diplomadoWC = getProductoPorSlug("mediacion-laboral");

// Datos del diplomado
const titulo = diplomadoWC?.nombre || "Diplomado en Mediación Laboral";
const descripcionCorta =
  diplomadoWC?.descripcion_corta ||
  "Desarrolla habilidades para resolver conflictos laborales y mejorar el clima organizacional en empresas y organizaciones.";
const duracion = diplomadoWC?.duracion || "240 horas";
const modalidad = diplomadoWC?.modalidad || "100% online";
const precio = diplomadoWC?.precio_formateado || "desde $480.000";
const beneficios = diplomadoWC?.beneficios || [];
const temario = diplomadoWC?.temario || [];
const requisitos = diplomadoWC?.requisitos || [];
const certificacion = diplomadoWC?.certificacion || [];
const empleabilidad = diplomadoWC?.empleabilidad || [];
const diferenciadores = diplomadoWC?.diferenciadores || [];
const ctaMensaje = diplomadoWC?.cta_mensaje || "";
const testimonios = diplomadoWC?.testimonios || [];
const docentes = diplomadoWC?.docentes || [];
---

<Layout
  title={`${titulo} - EMED | Resolución de Conflictos Organizacionales`}
  description={descripcionCorta}
>
  <div class="bg-crema min-h-screen">
    <!-- Hero del Programa -->
    <section class="hero-programa relative overflow-hidden">
      <!-- Imagen de fondo -->
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=2069&q=80"
          alt="Diplomado en Mediación Laboral"
          class="w-full h-full object-cover"
        />
        <div
          class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/50"
        >
        </div>
      </div>

      <div class="container mx-auto px-4 py-20 md:py-32 relative z-10">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <nav class="mb-8">
            <ol class="flex text-white/80 text-sm">
              <li><a href="/" class="hover:text-white">Inicio</a></li>
              <li class="mx-2">/</li>
              <li>
                <a href="/diplomados" class="hover:text-white">Diplomados</a>
              </li>
              <li class="mx-2">/</li>
              <li class="text-white">Mediación Laboral</li>
            </ol>
          </nav>

          <!-- Badges -->
          <div class="flex flex-wrap gap-2 md:gap-3 mb-6">
            <span
              class="inline-block px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-bold text-white bg-celeste"
            >
              Diplomado
            </span>
            <span
              class="inline-block bg-white/20 text-white px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-medium"
            >
              {modalidad}
            </span>
            <span
              class="inline-block bg-purple-600 text-white px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-bold"
            >
              ✓ RRHH
            </span>
          </div>

          <!-- Título y descripción -->
          <h1
            class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight"
          >
            {titulo}
          </h1>

          <p class="text-xl md:text-2xl text-white/90 mb-8 leading-relaxed">
            {descripcionCorta}
          </p>

          <!-- Detalles rápidos -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{duracion}</div>
              <div class="text-white/80 text-sm">Duración</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{modalidad}</div>
              <div class="text-white/80 text-sm">Modalidad</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-celeste">{precio}</div>
              <div class="text-white/80 text-sm">Inversión</div>
            </div>
          </div>

          <!-- CTAs optimizados -->
          <div class="hero-buttons-container">
            <button
              onclick="scrollToContactForm()"
              class="btn-hero btn-hero-primary px-8 py-3 md:px-12 md:py-4 text-base md:text-lg"
            >
              <svg
                class="w-6 h-6 mr-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                ></path>
              </svg>
              Hablar con un Asesor
            </button>
            <a
              href="https://wa.me/56912345678?text=Hola,%20quiero%20información%20sobre%20el%20Diplomado%20en%20Mediación%20Laboral%20de%20EMED"
              target="_blank"
              class="btn-hero btn-hero-whatsapp px-8 py-3 md:px-12 md:py-4 text-base md:text-lg"
            >
              <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path>
              </svg>
              WhatsApp Directo
            </a>
          </div>
        </div>
      </div>

      <!-- Forma orgánica inferior -->
      <div class="absolute bottom-0 left-0 right-0 h-24">
        <svg
          viewBox="0 0 1200 120"
          class="w-full h-full"
          preserveAspectRatio="none"
        >
          <path
            d="M0,120 C300,80 500,60 600,80 C700,100 900,60 1200,80 L1200,120 Z"
            fill="#FEF7E8"></path>
        </svg>
      </div>
    </section>

    <!-- Contenido del Programa -->
    <section class="py-12 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
          <!-- Contenido Principal (Columna Izquierda) -->
          <div class="lg:col-span-2 space-y-12">
            <!-- 1. ¿Por qué elegir el diplomado? -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <h2
                class="text-2xl md:text-3xl font-bold text-gray-800"
                style="margin-bottom: 10px;"
              >
                La Clave para un Mejor Clima Laboral
              </h2>

              <p class="text-lg text-gray-600 mb-6 leading-relaxed">
                Programa abierto a toda persona interesada en mejorar la
                convivencia laboral, aprendiendo a gestionar los conflictos con
                herramientas de mediación y un enfoque al diálogo que favorece
                el entendimiento, el respeto y relaciones de trabajo más sanas,
                en el marco de la Ley Karin.
              </p>

              <div
                class="bg-gradient-to-r from-celeste/10 to-turquesa/10 border border-celeste/30 rounded-lg p-6 mb-6"
              >
                <h3 class="font-bold text-gray-800 mb-3 flex items-center">
                  <svg
                    class="w-6 h-6 text-celeste mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                    ></path>
                  </svg>
                  Enfoque 100% Empresarial
                </h3>
                <p class="text-gray-700">
                  Metodología diseñada específicamente para el contexto
                  organizacional chileno, con casos reales de empresas y
                  herramientas aplicables inmediatamente en tu lugar de trabajo.
                </p>
              </div>

              <Diferenciadores
                items={diferenciadores}
                titulo="Te prepara para:"
              />

              <div class="mt-8 border-t border-gray-100 pt-8">
                <h3 class="text-xl font-bold text-gray-800 mb-6">
                  Material Descargable
                </h3>
                <DownloadButtons
                  mallaUrl="/docs/diplomados/mediacion-laboral/malla.pdf"
                  calendarioUrl="/docs/diplomados/mediacion-laboral/brochure.pdf"
                  arancelesUrl="/docs/diplomados/mediacion-laboral/aranceles.pdf"
                  className="mt-4"
                />
              </div>
            </div>

            <!-- 2. Ruta de Aprendizaje -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <h2
                class="text-3xl font-bold text-gray-800"
                style="margin-bottom: 10px;"
              >
                Ruta de Aprendizaje
              </h2>
              <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                La formación se organiza como una <strong
                  >ruta de aprendizaje en 3 etapas progresivas</strong
                >, donde cada curso es parte de un proceso continuo. Cada etapa
                habilita la siguiente, y el Diplomado se obtiene al completar
                todo el recorrido formativo.
              </p>

              <!-- Timeline Visual -->
              <div class="space-y-4">
                <!-- Curso 1 -->
                <div class="flex items-start">
                  <div
                    class="flex-shrink-0 w-12 h-12 rounded-full bg-purple-600 text-white flex items-center justify-center font-bold text-xl shadow-lg"
                  >
                    1
                  </div>
                  <div class="ml-4 flex-1">
                    <div
                      class="bg-gradient-to-r from-purple-600/10 to-transparent p-5 rounded-xl border-l-4 border-purple-600"
                    >
                      <h4 class="font-bold text-gray-800 text-lg">
                        CURSO 1 CLIMA LABORAL Y COMUNICACIÓN EFECTIVA EN LAS
                        ORGANIZACIONES
                      </h4>
                      <span
                        class="inline-block mt-2 px-3 py-1 bg-purple-600/20 text-purple-700 text-xs font-bold rounded-full uppercase tracking-wide"
                      >
                        Online Asincrónico
                      </span>
                      <p class="text-gray-600 text-sm mt-2">
                        Fundamentos teóricos en plataforma de estudio. Acceso
                        24/7, avanza a tu ritmo.
                      </p>
                    </div>
                  </div>
                </div>

                <!-- Conector -->
                <div
                  class="ml-6 w-0.5 h-6 bg-gradient-to-b from-purple-600 to-indigo-600"
                >
                </div>

                <!-- Curso 2 -->
                <div class="flex items-start">
                  <div
                    class="flex-shrink-0 w-12 h-12 rounded-full bg-indigo-600 text-white flex items-center justify-center font-bold text-xl shadow-lg"
                  >
                    2
                  </div>
                  <div class="ml-4 flex-1">
                    <div
                      class="bg-gradient-to-r from-indigo-600/10 to-transparent p-5 rounded-xl border-l-4 border-indigo-600"
                    >
                      <h4 class="font-bold text-gray-800 text-lg">
                        CURSO 2 EL ARTE DE MEDIAR: ESTRATEGIAS, MEDIACIÓN Y
                        BIENESTAR
                      </h4>
                      <span
                        class="inline-block mt-2 px-3 py-1 bg-indigo-600/20 text-indigo-700 text-xs font-bold rounded-full uppercase tracking-wide"
                      >
                        Online Asincrónico
                      </span>
                      <p class="text-gray-600 text-sm mt-2">
                        Herramientas y competencias de mediación organizacional.
                      </p>
                    </div>
                  </div>
                </div>

                <!-- Conector -->
                <div
                  class="ml-6 w-0.5 h-6 bg-gradient-to-b from-indigo-600 to-naranja"
                >
                </div>

                <!-- Ciclo de Diplomado -->
                <div class="flex items-start">
                  <div
                    class="flex-shrink-0 w-12 h-12 rounded-full bg-naranja text-white flex items-center justify-center font-bold text-xl shadow-lg"
                  >
                    3
                  </div>
                  <div class="ml-4 flex-1">
                    <div
                      class="bg-gradient-to-r from-naranja/10 to-transparent p-5 rounded-xl border-l-4 border-naranja"
                    >
                      <h4 class="font-bold text-gray-800 text-lg">
                        Ciclo de Diplomado: Jornadas en Vivo
                      </h4>
                      <span
                        class="inline-block mt-2 px-3 py-1 bg-naranja/20 text-naranja text-xs font-bold rounded-full uppercase tracking-wide"
                      >
                        Sincrónico por Zoom
                      </span>
                      <p class="text-gray-600 text-sm mt-2">
                        Aplicación práctica con docentes expertos. Talleres de
                        casos y técnicas de mediación.
                      </p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Nota informativa -->
              <div
                class="mt-8 p-5 bg-gradient-to-r from-purple-50 to-indigo-50 border border-purple-200 rounded-xl flex items-start shadow-sm"
              >
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center"
                >
                  <svg
                    class="w-5 h-5 text-purple-600"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div class="ml-4">
                  <p class="text-purple-800 font-bold text-lg">
                    Este Diplomado integra toda la ruta de aprendizaje
                  </p>
                  <p class="text-purple-700 text-sm mt-1">
                    Al inscribirte, accedes a todas las etapas del proceso
                    formativo: <strong
                      >Curso 1, Curso 2 y el Ciclo de Certificación</strong
                    >, incluidos en una sola matrícula.
                  </p>
                </div>
              </div>
            </div>

            <!-- 3. Metodología -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
              <MetodologiaOnline
                items={[
                  {
                    titulo: "Formación Asincrónica",
                    color: "celeste",
                    items: [
                      "Acceso 24/7 a plataforma de estudio",
                      "Material didáctico y videos",
                      "Cuestionarios de evaluación",
                      "Avanza a tu propio ritmo",
                    ],
                  },
                  {
                    titulo: "Formación Sincrónica",
                    color: "turquesa",
                    items: [
                      "Jornadas en vivo por Zoom",
                      "Talleres prácticos con docentes",
                      "Análisis de casos reales",
                      "Taller de casos y certificación",
                    ],
                  },
                ]}
              />
            </div>

            <!-- 3. Requisitos -->
            <div
              class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100"
            >
              <h3
                class="text-2xl font-bold text-gray-800 mb-8 flex items-center"
              >
                <span
                  class="w-8 h-8 rounded-lg bg-teal-100 text-teal-600 flex items-center justify-center mr-3"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path></svg
                  >
                </span>
                Requisitos de Ingreso
              </h3>
              <div class="grid md:grid-cols-2 gap-4">
                {
                  requisitos.map((item) => (
                    <div class="group flex items-start bg-gray-50 p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-teal-100 transition-all duration-300">
                      <div class="w-10 h-10 flex-shrink-0 bg-white rounded-lg shadow-sm flex items-center justify-center text-teal-600 mr-4 group-hover:scale-110 group-hover:bg-teal-50 transition-all duration-300">
                        <svg
                          class="w-5 h-5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                          />
                        </svg>
                      </div>
                      <span class="text-gray-700 font-medium pt-1 leading-snug">
                        {item}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>

            <!-- 4. Campo Laboral -->
            <div
              class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 relative overflow-hidden group hover:shadow-xl transition-all duration-300"
            >
              <!-- Decorative Background Icon -->
              <div
                class="absolute top-0 right-0 p-6 opacity-[0.03] group-hover:opacity-[0.06] transition-opacity duration-300 pointer-events-none"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-48 h-48"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path
                    d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"
                  ></path>
                </svg>
              </div>

              <h3
                class="text-2xl font-bold text-gray-800 mb-4 flex items-center relative z-10"
              >
                <span
                  class="w-10 h-10 rounded-lg bg-gradient-to-br from-purple-100 to-indigo-100 text-purple-600 flex items-center justify-center mr-3 shadow-sm"
                >
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                </span>
                Campo de Aplicación
              </h3>

              <p class="text-gray-600 mb-6 leading-relaxed relative z-10">
                Al completar tu formación, podrás desempeñarte profesionalmente
                en diversos ámbitos donde la mediación laboral es requerida y
                valorada.
              </p>

              <div class="grid md:grid-cols-2 gap-4 relative z-10">
                <!-- Departamentos de RRHH -->
                <div
                  class="group/item flex items-start bg-gradient-to-br from-gray-50 to-white p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-purple-200 transition-all duration-300"
                >
                  <div
                    class="w-12 h-12 flex-shrink-0 bg-white rounded-xl shadow-sm flex items-center justify-center text-purple-600 mr-4 group-hover/item:scale-110 group-hover/item:bg-purple-50 group-hover/item:shadow-md transition-all duration-300"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <span class="text-gray-800 font-semibold block mb-1"
                      >Departamentos de RRHH</span
                    >
                    <span class="text-gray-500 text-sm"
                      >Gestión de conflictos internos en empresas</span
                    >
                  </div>
                </div>

                <!-- Consultorías Empresariales -->
                <div
                  class="group/item flex items-start bg-gradient-to-br from-gray-50 to-white p-4 rounded-xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-purple-200 transition-all duration-300"
                >
                  <div
                    class="w-12 h-12 flex-shrink-0 bg-white rounded-xl shadow-sm flex items-center justify-center text-purple-600 mr-4 group-hover/item:scale-110 group-hover/item:bg-purple-50 group-hover/item:shadow-md transition-all duration-300"
                  >
                    <svg
                      class="w-6 h-6"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"

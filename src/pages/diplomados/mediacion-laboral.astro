    <!-- Formulario Contextual -->
    <section id="contact-form" class="py-16 bg-crema">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
              ¿Listo para transformar el clima laboral de tu empresa?
            </h2>
            <p class="text-xl text-gray-600">
              {ctaMensaje}
            </p>
          </div>

          <ContactForm
            type="contacto"
            program={titulo}
            source="mediacion-laboral"
            title="Consulta sobre Mediación Laboral"
            subtitle="Completa tus datos y un asesor especializado te contactará en las próximas 2 horas"
            showUrgency={true}
            className="bg-white"
          />
        </div>
      </div>
    </section>
  </div>

  <MobileStickyCTA
    title={titulo}
    price={precio}
    duration={duracion}
    modality={modalidad}
    whatsappLink="https://wa.me/56912345678?text=Hola,%20quiero%20información%20sobre%20el%20Diplomado%20en%20Mediación%20Laboral%20de%20EMED"
  />
  <script>
    // Función para scroll suave al formulario
    function scrollToContactForm() {
      const contactForm = document.getElementById("contact-form");
      if (contactForm) {
        contactForm.scrollIntoView({
          behavior: "smooth",
        });
      }
    }
  </script>

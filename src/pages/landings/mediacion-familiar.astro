    window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-437494561');
  </script>

  <style is:global>
    /* ─── Reset & Base ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; }

    /* ─── Color tokens ─── */
    :root {
      --celeste: #00A6B1;
      --celeste-dark: #008a94;
      --turquesa: #7EC5D6;
      --crema: #FEF7E8;
      --text-dark: #1a2e35;
      --text-body: #374151;
      --text-muted: #6B7280;
      --wa-green: #25D366;
      --sidebar-w: 260px;
    }

    /* ─── Sidebar ─── */
    .lnd-sidebar {
      position: fixed;
      top: 0; left: 0;
      width: var(--sidebar-w);
      height: 100vh;
      background: var(--celeste);
      display: flex;
      flex-direction: column;
      z-index: 200;
      box-shadow: 4px 0 20px rgba(0,166,177,0.25);
    }

    .lnd-sidebar-logo {
      padding: 28px 24px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.15);
      flex-shrink: 0;
    }
    .lnd-sidebar-logo img {
      height: 40px;
      width: auto;
      filter: brightness(0) invert(1);
    }

    .lnd-sidebar-nav {
      flex: 1;
      padding: 24px 0;
      overflow-y: auto;
      position: relative;
    }
    .lnd-sidebar-nav::before {
      content: '';
      position: absolute;
      left: 35px;
      top: 36px;
      bottom: 36px;
      width: 2px;
      background: rgba(255,255,255,0.2);
    }

    .lnd-nav-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 10px 24px;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      position: relative;
    }
    .lnd-nav-item:hover .lnd-nav-dot { background: white; transform: scale(1.2); }
    .lnd-nav-item:hover .lnd-nav-label { color: white; }

    .lnd-nav-dot {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.5);
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 10px;
      font-weight: 700;
      color: rgba(255,255,255,0.6);
      transition: all 0.25s;
      position: relative;
      z-index: 1;
    }
    .lnd-nav-item.active .lnd-nav-dot {
      background: white;
      border-color: white;
      color: var(--celeste);
      box-shadow: 0 0 0 4px rgba(255,255,255,0.2);
      transform: scale(1.1);
    }

    .lnd-nav-label {
      font-size: 12px;
      font-weight: 600;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.03em;
      transition: color 0.2s;
      line-height: 1.3;
    }
    .lnd-nav-item.active .lnd-nav-label { color: white; }

    .lnd-sidebar-bottom {
      padding: 20px 16px 24px;
      border-top: 1px solid rgba(255,255,255,0.15);
      flex-shrink: 0;
    }

    .lnd-btn-wa {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 12px 16px;
      background: var(--wa-green);
      color: white;
      border-radius: 12px;
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.2s;
      box-shadow: 0 4px 12px rgba(37,211,102,0.35);
    }
    .lnd-btn-wa:hover { background: #1da851; transform: translateY(-1px); }

    /* Mobile sidebar toggle */
    .lnd-sidebar-toggle {
      display: none;
      position: fixed;
      top: 16px; left: 16px;
      z-index: 300;
      width: 44px; height: 44px;
      background: var(--celeste);
      border: none;
      border-radius: 10px;
      cursor: pointer;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(0,166,177,0.4);
      color: white;
    }
    .lnd-sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 190;
    }

    /* ─── Slides container ─── */
    .lnd-slides-wrap {
      margin-left: var(--sidebar-w);
      width: calc(100% - var(--sidebar-w));
      height: 100vh;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }

    .lnd-slide {
      height: 100vh;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      display: flex;
      align-items: center;
      overflow: hidden;
      position: relative;
    }

    .lnd-slide-inner {
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 60px;
    }

    /* alternating backgrounds */
    .lnd-slide:nth-child(odd)  { background: #ffffff; }
    .lnd-slide:nth-child(even) { background: var(--crema); }
    .lnd-slide.lnd-slide--hero { background: none !important; }

    /* ─── Two-column layouts ─── */
    .lnd-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .lnd-cols--6-4 { grid-template-columns: 6fr 4fr; }
    .lnd-cols--4-6 { grid-template-columns: 4fr 6fr; }

    /* ─── Typography ─── */
    .lnd-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--celeste);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .lnd-eyebrow::before {
      content: '';
      display: inline-block;
      width: 24px;
      height: 2px;
      background: var(--celeste);
    }

    .lnd-title {
      font-size: clamp(28px, 3vw, 42px);
      font-weight: 800;
      color: var(--text-dark);
      line-height: 1.15;
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    .lnd-title .accent { color: var(--celeste); }

    .lnd-body {
      font-size: 16px;
      color: var(--text-body);
      line-height: 1.75;
      margin-bottom: 24px;
    }

    /* ─── Slide 1 / Hero ─── */
    .lnd-hero-bg {
      position: absolute;
      inset: 0;
      background: url('/images/pages/hero-mediadores.webp') center/cover no-repeat;
    }
    .lnd-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(105deg, rgba(0,40,50,0.88) 0%, rgba(0,80,90,0.7) 60%, rgba(0,166,177,0.45) 100%);
    }
    .lnd-slide--hero .lnd-slide-inner { position: relative; z-index: 2; color: white; }

    .lnd-hero-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 24px;
    }
    .lnd-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.04em;
    }
    .lnd-badge--white  { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; }
    .lnd-badge--teal   { background: var(--celeste); color: white; }
    .lnd-badge--green  { background: #10B981; color: white; }

    .lnd-hero-title {
      font-size: clamp(38px, 5vw, 64px);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
      color: white;
    }
    .lnd-hero-sub {
      font-size: 18px;
      line-height: 1.65;
      color: rgba(255,255,255,0.88);
      margin-bottom: 36px;
      max-width: 560px;
    }

    .lnd-hero-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      margin-bottom: 36px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 16px;
      overflow: hidden;
      max-width: 540px;
      backdrop-filter: blur(8px);
    }
    .lnd-stat {
      padding: 18px 20px;
      border-right: 1px solid rgba(255,255,255,0.15);
      text-align: center;
    }
    .lnd-stat:last-child { border-right: none; }
    .lnd-stat-val {
      font-size: 22px;
      font-weight: 800;
      color: white;
      line-height: 1.1;
      margin-bottom: 4px;
    }
    .lnd-stat-lbl { font-size: 11px; color: rgba(255,255,255,0.65); font-weight: 500; }

    .lnd-authority-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 36px;
    }
    .lnd-authority-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 10px;
      font-size: 12px;
      font-weight: 600;
      color: rgba(255,255,255,0.9);
      background: rgba(255,255,255,0.07);
    }

    .lnd-ctas { display: flex; gap: 14px; flex-wrap: wrap; }

    .lnd-btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      background: var(--celeste);
      color: white;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: 0 4px 20px rgba(0,166,177,0.4);
    }
    .lnd-btn-primary:hover { background: var(--celeste-dark); transform: translateY(-2px); }

    .lnd-btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      background: rgba(255,255,255,0.1);
      color: white;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid rgba(255,255,255,0.3);
      cursor: pointer;
      transition: all 0.2s;
      backdrop-filter: blur(4px);
    }
    .lnd-btn-ghost:hover { background: rgba(255,255,255,0.18); transform: translateY(-2px); }

    /* ─── Requirements ─── */
    .lnd-req-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
    .lnd-req-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 16px 20px;
      background: #f8fafb;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
      transition: all 0.2s;
    }
    .lnd-req-item:hover { background: white; box-shadow: 0 4px 16px rgba(0,0,0,0.06); border-color: #d1fae5; }
    .lnd-req-icon {
      width: 36px; height: 36px;
      flex-shrink: 0;
      background: #d1fae5;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: #059669;
    }
    .lnd-req-text { font-size: 15px; color: var(--text-body); font-weight: 500; line-height: 1.5; }

    .lnd-img-panel {
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.12);
      aspect-ratio: 4/5;
      position: relative;
    }
    .lnd-img-panel img { width: 100%; height: 100%; object-fit: cover; }
    .lnd-img-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 24px;
      background: linear-gradient(transparent, rgba(0,30,40,0.85));
    }
    .lnd-img-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      background: var(--celeste);
      color: white;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .lnd-img-sub { font-size: 14px; color: rgba(255,255,255,0.85); font-weight: 500; }

    /* ─── Mode cards ─── */
    .lnd-mode-cards { display: flex; flex-direction: column; gap: 16px; }
    .lnd-mode-card {
      padding: 20px 24px;
      border-radius: 14px;
      border-left: 4px solid var(--celeste);
      background: white;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .lnd-mode-card--presencial { border-left-color: var(--turquesa); }
    .lnd-mode-card-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }
    .lnd-mode-card-icon {
      width: 38px; height: 38px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .lnd-mode-card .lnd-mode-card-icon { background: #e0f7fa; color: var(--celeste); }
    .lnd-mode-card--presencial .lnd-mode-card-icon { background: #e3f6fb; color: var(--turquesa); }
    .lnd-mode-card-title { font-size: 15px; font-weight: 700; color: var(--text-dark); }
    .lnd-mode-card-hours { font-size: 12px; font-weight: 600; color: var(--celeste); margin-left: auto; }
    .lnd-mode-card--presencial .lnd-mode-card-hours { color: var(--turquesa); }
    .lnd-mode-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .lnd-mode-list li { font-size: 13px; color: var(--text-body); display: flex; gap: 8px; align-items: flex-start; }
    .lnd-mode-list li::before { content: '·'; color: var(--celeste); font-weight: 900; flex-shrink: 0; }

    /* ─── Video placeholder ─── */
    .lnd-video-ph {
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.14);
      aspect-ratio: 16/9;
      background: #f0f4f8;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      border: 2px dashed #d1d5db;
      position: relative;
    }
    .lnd-video-ph iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
    .lnd-video-ph-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 32px;
      text-align: center;
    }
    .lnd-video-play {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: var(--celeste);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 8px 24px rgba(0,166,177,0.4);
    }
    .lnd-video-lbl { font-size: 13px; color: var(--text-muted); font-weight: 600; }
    .lnd-video-note { font-size: 11px; color: #9ca3af; }
    .lnd-video-caption { text-align: center; font-size: 12px; color: var(--text-muted); margin-top: 12px; }

    /* ─── Practice items ─── */
    .lnd-practice-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
    .lnd-practice-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 16px 20px;
      background: #f8fafb;
      border-left: 3px solid var(--celeste);
      border-radius: 0 12px 12px 0;
      border-top: 1px solid #e5e7eb;
      border-right: 1px solid #e5e7eb;
      border-bottom: 1px solid #e5e7eb;
    }

    /* ─── Campo laboral grid ─── */
    .lnd-campo-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 8px;
    }
    .lnd-campo-card {
      padding: 20px 18px;
      border-radius: 14px;
      background: white;
      border: 1px solid #e5e7eb;
      transition: all 0.22s;
      text-align: center;
    }
    .lnd-campo-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); border-color: #a7f3d0; transform: translateY(-2px); }
    .lnd-campo-card-icon {
      width: 44px; height: 44px;
      margin: 0 auto 12px;
      border-radius: 12px;
      background: #e0f7fa;
      display: flex; align-items: center; justify-content: center;
      color: var(--celeste);
    }
    .lnd-campo-card-title { font-size: 13px; font-weight: 700; color: var(--text-dark); margin-bottom: 4px; }
    .lnd-campo-card-sub { font-size: 11px; color: var(--text-muted); line-height: 1.4; }

    /* ─── Certification ─── */
    .lnd-cert-badges {
      display: flex;
      gap: 16px;
      margin: 24px 0;
      flex-wrap: wrap;
    }
    .lnd-cert-badge {
      flex: 1;
      min-width: 130px;
      padding: 20px 16px;
      border-radius: 14px;
      background: white;
      border: 1px solid #e5e7eb;
      text-align: center;
      box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }
    .lnd-cert-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      background: #e0f7fa;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 10px;
      color: var(--celeste);
    }
    .lnd-cert-title { font-size: 12px; font-weight: 700; color: var(--text-dark); margin-bottom: 4px; }
    .lnd-cert-sub { font-size: 11px; color: var(--text-muted); }

    .lnd-hours-bar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e5e7eb;
      margin: 20px 0;
    }
    .lnd-hours-cell { padding: 16px 20px; text-align: center; }
    .lnd-hours-cell:first-child { background: #e0f7fa; border-right: 1px solid #e5e7eb; }
    .lnd-hours-cell:last-child { background: #f0fdf4; }
    .lnd-hours-num { font-size: 28px; font-weight: 900; color: var(--celeste); }
    .lnd-hours-lbl { font-size: 12px; color: var(--text-muted); font-weight: 500; }

    .lnd-docentes { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .lnd-docente-card {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 12px;
      background: white;
      border: 1px solid #e5e7eb;
    }
    .lnd-docente-avatar {
      width: 44px; height: 44px;
      border-radius: 10px;
      object-fit: cover;
      flex-shrink: 0;
      background: #e0f7fa;
    }
    .lnd-docente-name { font-size: 13px; font-weight: 700; color: var(--text-dark); }
    .lnd-docente-role { font-size: 11px; color: var(--text-muted); }

    /* ─── Aranceles slide ─── */
    .lnd-price-block { margin-bottom: 24px; }
    .lnd-price-from { font-size: 13px; color: var(--text-muted); font-weight: 500; margin-bottom: 4px; }
    .lnd-price-main { font-size: 48px; font-weight: 900; color: var(--celeste); line-height: 1; }
    .lnd-price-note { font-size: 13px; color: var(--text-muted); margin-top: 6px; }

    .lnd-downloads { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .lnd-download-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 12px;

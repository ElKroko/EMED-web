---
// Landing page rediseñada — Diplomado en Mediación Familiar
// Ruta: /landings/mediacion-familiar
// Layout: slides a pantalla completa + sidebar izquierda con progreso
import ContactForm from "../../components/forms/ContactForm.astro";
import "../../styles/global.css";
import claudiaTassara from "../../assets/images/docentes/claudia-tassara.webp";
import juanPabloLetelier from "../../assets/images/docentes/juan-pablo-letelier.webp";
import mariaNataliaCastro from "../../assets/images/docentes/maria-natalia-castro.webp";
import constanzaNavarrete from "../../assets/images/docentes/constanza-navarrete.webp";
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <title>Diplomado en Mediación Familiar | EMED — Certificación Ministerio de Justicia</title>
  <meta name="description" content="Especialízate en la resolución de conflictos familiares con técnicas específicas y casos de alta sensibilidad emocional. Certificación oficial del Ministerio de Justicia.">
  <meta property="og:title" content="Diplomado en Mediación Familiar - EMED | Certificación MINJU">
  <meta property="og:description" content="20 años formando mediadores. +6.000 egresados. Certificación oficial del Ministerio de Justicia.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">

  <!-- Facebook Pixel -->
